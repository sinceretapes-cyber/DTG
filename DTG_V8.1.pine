//@version=6
indicator("DTG V8.1", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500, dynamic_requests=true)

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  DTG DZ STRATEGY — Tidied & Enhanced                                     ║
// ║  Core logic preserved · Modern dashboard · Multi-TF bias · Auto-discount ║
// ║  3-Step System: Bias → Zone Touch → Signal                               ║
// ╚═══════════════════════════════════════════════════════════════════════════╝


// ─────────────────────────────────────────────────────────────────────────────
// §1  INPUTS
// ─────────────────────────────────────────────────────────────────────────────

// ── SIGNALS ──
grpSig        = "Signals"
showLabel     = input.string("Buy / Sell", "Signal Style", options=["Buy / Sell", "Symbol", "Off"], inline="S1", group=grpSig)
showMax       = input.int(1, "Signals on Chart", minval=1, maxval=500, inline="S1", group=grpSig)
enableEM1     = input.bool(true, "EM1 — 3-Candle Reversal", group=grpSig, tooltip="Original 3-candle reversal pattern")
enableEM2     = input.bool(true, "EM2 — Engulfing",           group=grpSig, tooltip="Bullish/bearish engulfing candle")
enableEM3     = input.bool(true, "EM3 — Inside-Bar Break",    group=grpSig, tooltip="Inside-bar consolidation broken in bias direction")
enableEM4     = input.bool(true, "EM4 — Pin Bar / Rejection", group=grpSig, tooltip="Rejection wick candle (body in far end of range, long wick the other side)")
buy_c         = input.color(color.new(#056656, 0), "Buy",  inline="S2", group=grpSig)
sell_c        = input.color(color.new(#b22833, 0), "Sell", inline="S2", group=grpSig)
txt_c         = input.color(color.new(color.white, 0), "Text", inline="S2", group=grpSig)
inputSpread   = input.int(3, "Spread Buffer", minval=0, maxval=20, group=grpSig, tooltip="Spread pips added to entry and SL buffer")

// ── VISUALS ──
grpVis        = "Visuals"
showTable     = input.bool(true, "Dashboard", inline="V1", group=grpVis)
dashSize      = input.string("normal", "Size", options=["tiny","small","normal","large"], inline="V1", group=grpVis)
showRR        = input.bool(true, "RR Boxes on Chart", group=grpVis, tooltip="Show Entry/SL/TP1/TP2 boxes during active trades")
showHistory   = input.bool(true, "Show Last Trade", group=grpVis, tooltip="Keep the last completed trade visible on chart with W/BE/L label")
tradingWindow = input.bool(true, "Trading Window Background", inline="V2", group=grpVis)
TW_color      = input.color(color.new(color.gray, 85), "", inline="V2", group=grpVis)
enableFib     = input.bool(true, "Discount Zones", group=grpVis)
autoDiscount  = input.bool(true, "Auto-Escalate Zones", group=grpVis, tooltip="Automatically selects the best discount zone across 4H→6H→8H→12H→D→W. Turn off to use manual Base Timeframe.")
base_tf       = input.timeframe("240", "Manual Zone TF", options=["60","120","180","240","360","480","600","720","D","W","M"], group=grpVis, tooltip="Only used when Auto-Escalate is OFF")
bull_fill     = input.color(color.new(color.green, 80), "Bull Fill",  inline="V3", group=grpVis)
bear_fill     = input.color(color.new(color.red, 80),   "Bear Fill",  inline="V3", group=grpVis)
bull_border   = input.color(color.green, "Bull Border", inline="V4", group=grpVis)
bear_border   = input.color(color.red,   "Bear Border", inline="V4", group=grpVis)
line_width    = input.int(1, "Zone Mid Line", minval=1, maxval=6, inline="V5", group=grpVis)

// ── RISK ──
grpRisk       = "Risk Management"
accountSize   = input.float(10000, "Account Size", minval=100, step=500, group=grpRisk)
acctCurrency  = input.string("USD", "Account Currency", options=["USD", "AUD", "EUR", "GBP"], group=grpRisk, tooltip="Select your account currency. Lot sizes auto-adjust using live exchange rates.")
riskPct       = input.string("1%", "Risk Per Trade", options=["0.5%", "1%", "2%", "3%"], group=grpRisk)

// ── SYSTEM RULES ──
grpSystem       = "System Rules"
excludeNonTW    = input.bool(true, "Signals During Window Only", group=grpSystem, tooltip="Only fire entry signals during the trading window (H4 candles 3-5)")
windowTapsOnly  = input.bool(true, "Zone Taps During Window Only", group=grpSystem, tooltip="Step 2 zone touch only counts during the trading window. Off = taps count any time.")
oneTradePerDay  = input.bool(true, "One Trade Per Day", group=grpSystem, tooltip="After a winning trade (TP2 hit), no more signals for the day. SL/BE trades allow retries.")
requireZoneTap  = input.bool(true, "Require Zone Tap for Signal", group=grpSystem, tooltip="Enforce Step 2: signals only fire after a discount zone has been tapped. Turn off to allow signals without a zone tap.")

// ── CONFLUENCE ──
grpConf        = "Zone Confluence"
minZoneConf    = input.int(2, "Min Zone Confluence", minval=1, maxval=20, group=grpConf, tooltip="Minimum pattern fires accumulated in a zone before a signal can trigger from that zone. Counts only fires while price is touching the zone.")
showZoneScore  = input.bool(true, "Show Zone Score on Chart", group=grpConf, tooltip="Appends the per-zone pattern tally to the zone label (e.g. 4H Discount · Σ3).")

// ── EM4 PIN BAR THRESHOLDS (from DTG Rejection Wicks) ──
grpEM4         = "EM4 — Pin Bar Thresholds"
em4_bodyPct    = input.float(33.0, "Body Position %", minval=5, maxval=50, step=1, group=grpEM4, tooltip="Body must close within this % of candle range from the rejection end. Lower = stricter.")
em4_wickRatio  = input.float(1.5,  "Min Wick:Body Ratio", minval=1.0, step=0.1, group=grpEM4, tooltip="Rejection wick must be at least this many times the body size.")
em4_atrLen     = input.int(14, "ATR Length", minval=1, group=grpEM4)
em4_minAtrPct  = input.float(40.0, "Min Candle Size (% of ATR)", minval=0, step=5, group=grpEM4, tooltip="Candle range must be at least this % of ATR. 0 = disabled.")

// ── STATISTICS ──
grpStats     = "Statistics"
showStats    = input.bool(true, "Performance Stats", group=grpStats, tooltip="Show win rate, expectancy, profit factor, and streak on the dashboard when no trade is active.")
statsScope   = input.string("All Time", "Scope", options=["Today", "All Time"], group=grpStats, tooltip="Today: count only trades that closed since last daily reset. All Time: every tracked trade.")
statsMax     = input.int(200, "Max Trades Tracked", minval=20, maxval=500, group=grpStats, tooltip="Ring buffer size. Oldest trade is dropped once full.")


// ─────────────────────────────────────────────────────────────────────────────
// §4  UTILITY FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────

f_DTG_algo(_lname, _lbar, _lval, _lpos, _lcol, _lstyle, _ltext, _ltextc, _lsize) =>
    array.push(_lname, label.new(x=_lbar, y=_lval, yloc=_lpos, color=_lcol, style=_lstyle, text=_ltext, textcolor=_ltextc, size=_lsize))

f_LABEL_truncate(_ArrayL, _NumToKeepL) =>
    if array.size(_ArrayL) >= _NumToKeepL + 1
        label.delete(array.shift(_ArrayL))

BiasV(v1)      => v1 > 0 ? 1 : v1 < 0 ? -1 : 0
BiasC(c1)      => c1 > 0 ? buy_c : c1 < 0 ? sell_c : color.yellow


// ─────────────────────────────────────────────────────────────────────────────
// §6  H4 COUNTER & FILTER FLAGS
// ─────────────────────────────────────────────────────────────────────────────

var int H4_counter = 0
if timeframe.change("D")
    H4_counter := 1
if timeframe.change("240") and not timeframe.change("D")
    H4_counter := nz(H4_counter) + 1

int  TmF            = timeframe.multiplier
bool intradayFilter = timeframe.isintraday and TmF <= 240
bool mergedTW       = intradayFilter and (H4_counter >= 3 and H4_counter <= 5)
bool XAU            = str.contains(str.upper(syminfo.ticker), "XAU")
bool XAG            = str.contains(str.upper(syminfo.ticker), "XAG")
bool FX             = syminfo.type == "forex"
bool isCrypto       = syminfo.type == "crypto"
bool isIndex        = str.contains(syminfo.ticker, "US30") or str.contains(syminfo.ticker, "NAS100") or str.contains(syminfo.ticker, "SPX500") or str.contains(syminfo.ticker, "US500") or str.contains(syminfo.ticker, "DE40") or str.contains(syminfo.ticker, "UK100") or str.contains(syminfo.ticker, "JP225") or str.contains(syminfo.ticker, "AUS200")
bool isOil          = str.contains(syminfo.ticker, "USOIL") or str.contains(syminfo.ticker, "UKOIL") or str.contains(syminfo.ticker, "WTI") or str.contains(syminfo.ticker, "BRENT") or str.contains(syminfo.ticker, "CL") or str.contains(syminfo.ticker, "BCO")
bool XAU_XAG        = XAU or XAG
bool assetsFilter   = true
bool intradayTF     = timeframe.isintraday and (not XAU_XAG ? TmF >= 15 : true)
bool buLTF_XAU_XAG  = XAU_XAG and TmF < 15
bool beLTF_XAU_XAG  = XAU_XAG and TmF < 15

bgcolor(tradingWindow and mergedTW ? TW_color : na)


// ─────────────────────────────────────────────────────────────────────────────
// §7  EMA & MARKET DATA
// ─────────────────────────────────────────────────────────────────────────────

ema8       = ta.ema(close, 8)
ema20      = ta.ema(close, 20)
trend_avg  = (ema8 + ema20) / 2
pct_change = 100 * (ema8 - ema20) / trend_avg

spread_tick = syminfo.mintick * (XAU ? 100 : (XAG ? 1000 : (FX ? 10 : 0)))
digits      = int(math.log10(1 / syminfo.mintick) - 1)
TF_num      = timeframe.isintraday ? (TmF < 60 ? TmF : math.round(TmF / 60, 0)) : TmF
TF_HRmn     = timeframe.isintraday ? (TmF < 60 ? "minute timeframe." : "hour timeframe.") : "minute timeframe."
TF_txt      = str.tostring(TF_num, "") + " " + TF_HRmn


// ─────────────────────────────────────────────────────────────────────────────
// §8  TRADE STATE (UDT — user-defined types)
// ─────────────────────────────────────────────────────────────────────────────
// UDTs group related state into a single named record instead of scattering
// ~45 top-level `var` declarations. Behaviourally identical to the old flat
// vars — each field is initialised to the exact same value (na / false / 0)
// the old declarations used. All downstream code now reads/writes fields like
// `trade.entry` instead of `trade_Entry`.

// ── Active trade being tracked on the current day ──
type TradeState
    int    bar          = na
    int    triggerBar   = na
    int    time         = na
    string status       = na
    float  entry        = na
    float  sl           = na
    float  tp1          = na
    float  tp2          = na
    color  bias         = na
    string model        = na
    string zoneTF       = na
    bool   tp1hit       = false

// ── Discount-zone snapshot frozen at signal time ──
type ZoneSnapshot
    float  zt           = na
    float  zb           = na
    int    openTime     = na
    int    closeTime    = na
    string tfLabel      = na
    int    bias         = 0

// ── Background monitor — Triggered trade carried past a day roll ──
type BgTrade
    float  entry        = na
    float  sl           = na
    float  tp1          = na
    float  tp2          = na
    int    bar          = na
    int    time         = na
    int    dir          = 0
    string model        = na
    string zoneTF       = na
    bool   active       = false
    bool   tp1hit       = false

// ── Completed-trade record — one per closed trade in the trades[] array ──
// outcome: +1 = TP2 win, 0 = 1:1 secured (TP1 hit, then entry), -1 = SL loss
// rMultiple: realized R — +2 for win, +1 for 1:1, -1 for loss
type TradeRecord
    int    bar          = na
    int    exitBar      = na
    int    time         = na
    int    exitTime     = na
    float  entry        = na
    float  sl           = na
    float  tp1          = na
    float  tp2          = na
    int    dir          = 0
    int    outcome      = 0
    float  rMultiple    = 0.0
    string model        = na
    string zoneTF       = na

// ── Per-zone pattern confluence counters ──
// Accumulated ONLY while price is actively touching the zone (low ≤ zoneTop AND
// high ≥ zoneBottom). Reset on zone rollover or invalidation. Weekly is not
// tracked (signal-ineligible per system rules + saves state/compute).
type ZoneConfluence
    int em1   = 0
    int em2   = 0
    int em3   = 0
    int em4   = 0
    int total = 0

var TradeState    trade = TradeState.new()
var ZoneSnapshot  zone  = ZoneSnapshot.new()
var BgTrade       bg    = BgTrade.new()
var ZoneConfluence conf_4h  = ZoneConfluence.new()
var ZoneConfluence conf_6h  = ZoneConfluence.new()
var ZoneConfluence conf_8h  = ZoneConfluence.new()
var ZoneConfluence conf_12h = ZoneConfluence.new()
var ZoneConfluence conf_D   = ZoneConfluence.new()

// ── Trade history array — ring buffer, oldest trimmed once `statsMax` reached ──
var array<TradeRecord> trades = array.new<TradeRecord>()
// ── Day boundary for "Today" scope — stamped on each daily reset ──
var int todayStartTime = na

// ── 3-STEP SYSTEM STATE ──
var bool stepTwoMet        = false
var int  stepTwoBias       = 0
var bool dailyProfitTaken  = false

// Dashboard sticky flags — declared early so EM1 gate (§10) can read them
var bool dashStk_4h  = false
var bool dashStk_6h  = false
var bool dashStk_8h  = false
var bool dashStk_12h = false
var bool dashStk_D   = false
var bool dashStk_W   = false

bool buySignal  = false
bool sellSignal = false

// Daily reset — full system reset at start of each new day.
// If a Triggered trade is still live, move it to background monitoring so it can
// still complete (TP2/SL) across day boundaries. Main system resets freely.
if timeframe.change("D")
    todayStartTime := time
    if trade.status == "Triggered" and not na(trade.entry)
        bg.entry  := trade.entry
        bg.sl     := trade.sl
        bg.tp1    := trade.tp1
        bg.tp2    := trade.tp2
        bg.bar    := trade.bar
        bg.time   := trade.time
        bg.dir    := trade.bias == buy_c ? 1 : -1
        bg.model  := trade.model
        bg.zoneTF := trade.zoneTF
        bg.tp1hit := trade.tp1hit
        bg.active := true
    stepTwoMet       := false
    stepTwoBias      := 0
    dailyProfitTaken := false
    trade.status     := "Scanning"
    trade.bar        := na
    trade.triggerBar := na
    trade.time       := na
    trade.entry      := na
    trade.sl         := na
    trade.tp1        := na
    trade.tp2        := na
    trade.bias       := na
    trade.model      := na
    trade.zoneTF     := na
    trade.tp1hit     := false
    zone.zt          := na
    zone.zb          := na
    zone.openTime    := na
    zone.closeTime   := na
    zone.tfLabel     := na
    zone.bias        := 0

// ── BACKGROUND TRADE MONITOR ──
// Tracks old Triggered trades that survived the daily reset. Runs every bar.
// When TP2 or SL is hit, captures to history and clears. Does NOT block new signals.
// Outcomes: +1 = Win (TP2), 0 = 1:1 Secured (TP1 hit, then back to entry), -1 = Loss
if bg.active
    bool bg_isBuy     = bg.dir == 1
    bool bg_wasTP1hit = bg.tp1hit
    bool bg_checkTP1  = (bg_isBuy and high > bg.tp1) or (not bg_isBuy and low < bg.tp1)
    if bg_checkTP1
        bg.tp1hit := true
    bool bg_hitTP2 = (bg_isBuy and high > bg.tp2) or (not bg_isBuy and low < bg.tp2)
    bool bg_hitSL  = not bg_wasTP1hit and ((bg_isBuy and low < bg.sl) or (not bg_isBuy and high > bg.sl))
    bool bg_hitBE  = bg_wasTP1hit and ((bg_isBuy and low < bg.entry) or (not bg_isBuy and high > bg.entry))
    if bg_hitTP2 or bg_hitBE or bg_hitSL
        int   bgOutcome = bg_hitTP2 ? 1 : bg_hitBE ? 0 : -1
        float bgRmult   = bgOutcome == 1 ? 2.0 : bgOutcome == 0 ? 1.0 : -1.0
        TradeRecord rec = TradeRecord.new(bar=bg.bar, exitBar=bar_index, time=bg.time, exitTime=time, entry=bg.entry, sl=bg.sl, tp1=bg.tp1, tp2=bg.tp2, dir=bg.dir, outcome=bgOutcome, rMultiple=bgRmult, model=bg.model, zoneTF=bg.zoneTF)
        array.push(trades, rec)
        if array.size(trades) > statsMax
            array.shift(trades)
        bg.active := false
        bg.tp1hit := false


// ─────────────────────────────────────────────────────────────────────────────
// §8b  MULTI-TF DATA — Consolidated
// ─────────────────────────────────────────────────────────────────────────────

[open_4h, close_4h, high_4h, low_4h]     = request.security(syminfo.tickerid, "240", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_6h, close_6h, high_6h, low_6h]     = request.security(syminfo.tickerid, "360", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_8h, close_8h, high_8h, low_8h]     = request.security(syminfo.tickerid, "480", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_12h, close_12h, high_12h, low_12h] = request.security(syminfo.tickerid, "720", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_Db, close_Db, high_Db, low_Db]     = request.security(syminfo.tickerid, "D",   [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_Wb, close_Wb, high_Wb, low_Wb]     = request.security(syminfo.tickerid, "W",   [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)

f_tf_bias(c, o) => c > o ? 1 : c < o ? -1 : 0

bias_4h  = f_tf_bias(close_4h, open_4h)
bias_6h  = f_tf_bias(close_6h, open_6h)
bias_8h  = f_tf_bias(close_8h, open_8h)
bias_12h = f_tf_bias(close_12h, open_12h)
bias_D   = f_tf_bias(close_Db, open_Db)
bias_W   = f_tf_bias(close_Wb, open_Wb)

sum_bias   = bias_4h + bias_6h + bias_8h + bias_12h + bias_D + bias_W
biasLabel  = sum_bias >= 2 ? "Bullish" : sum_bias <= -2 ? "Bearish" : "Neutral"
biasColor  = sum_bias >= 2 ? color.new(color.green, 0) : sum_bias <= -2 ? color.new(color.red, 0) : color.new(color.yellow, 0)

int overallBias = sum_bias >= 2 ? 1 : sum_bias <= -2 ? -1 : 0

color H4_c = BiasC(close_4h - open_4h)
int   mult = BiasV(close_4h - open_4h)

// ── EXCHANGE RATE (single conditional call) ──
// Only one of the three rates is needed at any time — fetch the one that matches
// the selected account currency. Saves 2 request.security calls vs V8.1.
string fxSym   = acctCurrency == "AUD" ? "FX:AUDUSD" : acctCurrency == "GBP" ? "FX:GBPUSD" : "FX:EURUSD"
float  fxClose = request.security(fxSym, "D", close, barmerge.gaps_off, barmerge.lookahead_on)
float  fxRate  = acctCurrency == "AUD" ? nz(fxClose, 0.65) : acctCurrency == "EUR" ? nz(fxClose, 1.08) : acctCurrency == "GBP" ? nz(fxClose, 1.27) : 1.0


// ─────────────────────────────────────────────────────────────────────────────
// §9  PATTERN DETECTION — EM1 / EM2 / EM3 / EM4 (all on chart TF)
// ─────────────────────────────────────────────────────────────────────────────
// Each model fires independently. Detection runs every bar (cheap arithmetic).
// The zone-touch gate and confluence threshold happen in §10 — detection here
// is pure pattern recognition with no bias/zone/system awareness.

// ── Common filters shared by all models ──
bool filt_common_buy  = (excludeNonTW ? mergedTW : true) and assetsFilter and intradayTF and (buLTF_XAU_XAG ? mult >= 0 : true) and overallBias == 1
bool filt_common_sell = (excludeNonTW ? mergedTW : true) and assetsFilter and intradayTF and (beLTF_XAU_XAG ? mult <= 0 : true) and overallBias == -1

// ── EM1 — original 3-candle reversal ──
// Buy: bearish [3] → bullish [2] → bullish [1] with HH+HL
bool em1_buy_raw  = close[3] < open[3] and close[2] > open[2] and close[1] > open[1] and high[1] > high[2] and low[1] > low[2] and pct_change > 0.006
bool em1_sell_raw = close[3] > open[3] and close[2] < open[2] and close[1] < open[1] and low[1]  < low[2]  and high[1] < high[2] and pct_change < -0.006
bool em1_buy  = em1_buy_raw  and filt_common_buy
bool em1_sell = em1_sell_raw and filt_common_sell

// ── EM2 — engulfing ──
// Buy: bearish [2] fully engulfed by bullish [1]. Body of [1] ≥ body of [2].
bool em2_buy_raw  = close[2] < open[2] and close[1] > open[1] and close[1] > open[2] and open[1] < close[2] and (close[1] - open[1]) >= (open[2] - close[2])
bool em2_sell_raw = close[2] > open[2] and close[1] < open[1] and close[1] < open[2] and open[1] > close[2] and (open[1] - close[1]) >= (close[2] - open[2])
bool em2_buy  = em2_buy_raw  and filt_common_buy
bool em2_sell = em2_sell_raw and filt_common_sell

// ── EM3 — inside-bar break ──
// Setup: [2] is inside bar of [3] (high[2]≤high[3] AND low[2]≥low[3]).
// Break: [1] closes beyond [2] in bias direction. SL is mother-bar low/high.
bool em3_isInside = high[2] <= high[3] and low[2] >= low[3]
bool em3_buy_raw  = em3_isInside and close[1] > high[2] and close[1] > open[1]
bool em3_sell_raw = em3_isInside and close[1] < low[2]  and close[1] < open[1]
bool em3_buy  = em3_buy_raw  and filt_common_buy
bool em3_sell = em3_sell_raw and filt_common_sell

// ── EM4 — pin bar / rejection wick (user's DTG Rejection Wicks logic, inlined) ──
// Uses close[1]/open[1]/high[1]/low[1] — detects on the most recently closed candle.
float em4_range     = high[1] - low[1]
float em4_bodyLow   = math.min(close[1], open[1])
float em4_bodyHigh  = math.max(close[1], open[1])
float em4_bodySize  = em4_bodyHigh - em4_bodyLow
float em4_upperWick = high[1] - em4_bodyHigh
float em4_lowerWick = em4_bodyLow - low[1]
float em4_atrVal    = ta.atr(em4_atrLen)
float em4_threshold = em4_bodyPct * 0.01
float em4_atrFactor = em4_minAtrPct * 0.01
bool  em4_valid     = em4_range > 0
bool  em4_passesAtr = em4_minAtrPct == 0 or em4_range >= em4_atrVal * em4_atrFactor
// Bullish rejection (algebra identical to DTG Rejection Wicks, division removed):
// Original: (1 - (bodyLow - low)/range) <= threshold  ⇔  (high - bodyLow) <= threshold*range
bool em4_buy_raw  = em4_valid and em4_passesAtr and (high[1] - em4_bodyLow) <= em4_threshold * em4_range and (em4_bodySize > 0 ? em4_lowerWick / em4_bodySize >= em4_wickRatio : em4_lowerWick > em4_upperWick)
bool em4_sell_raw = em4_valid and em4_passesAtr and (em4_bodyHigh - low[1]) <= em4_threshold * em4_range and (em4_bodySize > 0 ? em4_upperWick / em4_bodySize >= em4_wickRatio : em4_upperWick > em4_lowerWick)
bool em4_buy  = em4_buy_raw  and filt_common_buy
bool em4_sell = em4_sell_raw and filt_common_sell

// ── Aggregate: did ANY pattern fire on this bar (direction-aware)? ──
// Used only for zone-tap confluence counting. Actual signal selection uses per-model flags.
bool anyPatternBuy  = (enableEM1 and em1_buy)  or (enableEM2 and em2_buy)  or (enableEM3 and em3_buy)  or (enableEM4 and em4_buy)
bool anyPatternSell = (enableEM1 and em1_sell) or (enableEM2 and em2_sell) or (enableEM3 and em3_sell) or (enableEM4 and em4_sell)

// Legacy aggregates kept so the rest of §10 (validBuy/validSell/rawBuy/rawSell gates) reads naturally.
buySignal  := anyPatternBuy
sellSignal := anyPatternSell


// (§10 SIGNAL LABELS & TRADE ENTRY and §12 TRADE STATUS MACHINE have been
// relocated to run AFTER §13 so the per-zone confluence counters are
// up-to-date on the signal bar. See below after §13.)


// ─────────────────────────────────────────────────────────────────────────────
// §13  AUTO-ESCALATING DISCOUNT ZONES
// ─────────────────────────────────────────────────────────────────────────────

// Fib 50%-75% zone based on each TF's own candle direction
f_discountZone(float lo, float hi, int candleBias) =>
    float rng = hi - lo
    float zt = na
    float zb = na
    if candleBias == 1
        zt := hi - 0.5  * rng
        zb := hi - 0.75 * rng
    else if candleBias == -1
        zb := lo + 0.5  * rng
        zt := lo + 0.75 * rng
    [zt, zb]

[zt_4h,  zb_4h]  = f_discountZone(low_4h,  high_4h,  bias_4h)
[zt_6h,  zb_6h]  = f_discountZone(low_6h,  high_6h,  bias_6h)
[zt_8h,  zb_8h]  = f_discountZone(low_8h,  high_8h,  bias_8h)
[zt_12h, zb_12h] = f_discountZone(low_12h, high_12h, bias_12h)
[zt_Db,  zb_Db]  = f_discountZone(low_Db,  high_Db,  bias_D)
[zt_Wb,  zb_Wb]  = f_discountZone(low_Wb,  high_Wb,  bias_W)

// Invalidation uses chart timeframe automatically
f_zoneInvalid(float zt, float zb, int candleBias) =>
    bool inv = false
    if candleBias == 1 and not na(zb)
        float lower = math.min(zt, zb)
        inv := close[2] < lower and close[1] < lower
    else if candleBias == -1 and not na(zt)
        float upper = math.max(zt, zb)
        inv := close[2] > upper and close[1] > upper
    inv

// Native HTF timing — replaces 6 request.security() calls in V8.1.
// time(tf) returns the current HTF candle open time; time_close(tf) its close.
// timeframe.change(tf) detects rollover. Same values, zero security cost.
int time_now_4h  = time("240")
int time_now_6h  = time("360")
int time_now_8h  = time("480")
int time_now_12h = time("720")
int time_now_D   = time("D")
int time_now_W   = time("W")

bool new_4h  = timeframe.change("240")
bool new_6h  = timeframe.change("360")
bool new_8h  = timeframe.change("480")
bool new_12h = timeframe.change("720")
bool new_D   = timeframe.change("D")
bool new_W   = timeframe.change("W")

var bool locked_4h  = false
var bool locked_6h  = false
var bool locked_8h  = false
var bool locked_12h = false
var bool locked_D   = false
var bool locked_W   = false

// Pre-compute every ta.change() unconditionally so each one evaluates on every bar.
// Inlining them into an `or` expression lets Pine short-circuit and skip calls,
// which breaks the series-history guarantee ta.change() relies on.
float chg_zt_4h  = ta.change(zt_4h)
float chg_zb_4h  = ta.change(zb_4h)
float chg_zt_6h  = ta.change(zt_6h)
float chg_zb_6h  = ta.change(zb_6h)
float chg_zt_8h  = ta.change(zt_8h)
float chg_zb_8h  = ta.change(zb_8h)
float chg_zt_12h = ta.change(zt_12h)
float chg_zb_12h = ta.change(zb_12h)
float chg_zt_D   = ta.change(zt_Db)
float chg_zb_D   = ta.change(zb_Db)
float chg_zt_W   = ta.change(zt_Wb)
float chg_zb_W   = ta.change(zb_Wb)

bool newZone_4h  = chg_zt_4h  != 0 or chg_zb_4h  != 0
bool newZone_6h  = chg_zt_6h  != 0 or chg_zb_6h  != 0
bool newZone_8h  = chg_zt_8h  != 0 or chg_zb_8h  != 0
bool newZone_12h = chg_zt_12h != 0 or chg_zb_12h != 0
bool newZone_D   = chg_zt_D   != 0 or chg_zb_D   != 0
bool newZone_W   = chg_zt_W   != 0 or chg_zb_W   != 0

// Zone rollover — clear lock, sticky touch, AND confluence counters.
// Confluence reset: a brand-new HTF candle makes all previous pattern fires
// irrelevant (new zone, new context, start counting fresh).
if newZone_4h
    locked_4h := false
    dashStk_4h := false
    conf_4h.em1 := 0, conf_4h.em2 := 0, conf_4h.em3 := 0, conf_4h.em4 := 0, conf_4h.total := 0
if newZone_6h
    locked_6h := false
    dashStk_6h := false
    conf_6h.em1 := 0, conf_6h.em2 := 0, conf_6h.em3 := 0, conf_6h.em4 := 0, conf_6h.total := 0
if newZone_8h
    locked_8h := false
    dashStk_8h := false
    conf_8h.em1 := 0, conf_8h.em2 := 0, conf_8h.em3 := 0, conf_8h.em4 := 0, conf_8h.total := 0
if newZone_12h
    locked_12h := false
    dashStk_12h := false
    conf_12h.em1 := 0, conf_12h.em2 := 0, conf_12h.em3 := 0, conf_12h.em4 := 0, conf_12h.total := 0
if newZone_D
    locked_D := false
    dashStk_D := false
    conf_D.em1  := 0, conf_D.em2  := 0, conf_D.em3  := 0, conf_D.em4  := 0, conf_D.total  := 0
if newZone_W
    locked_W := false
    dashStk_W := false

// Zone invalidation — clear lock, sticky touch, AND confluence counters.
// Invalidated history is no longer useful evidence for future setups.
if f_zoneInvalid(zt_4h, zb_4h, bias_4h)
    locked_4h := true
    dashStk_4h := false
    conf_4h.em1 := 0, conf_4h.em2 := 0, conf_4h.em3 := 0, conf_4h.em4 := 0, conf_4h.total := 0
if f_zoneInvalid(zt_6h, zb_6h, bias_6h)
    locked_6h := true
    dashStk_6h := false
    conf_6h.em1 := 0, conf_6h.em2 := 0, conf_6h.em3 := 0, conf_6h.em4 := 0, conf_6h.total := 0
if f_zoneInvalid(zt_8h, zb_8h, bias_8h)
    locked_8h := true
    dashStk_8h := false
    conf_8h.em1 := 0, conf_8h.em2 := 0, conf_8h.em3 := 0, conf_8h.em4 := 0, conf_8h.total := 0
if f_zoneInvalid(zt_12h, zb_12h, bias_12h)
    locked_12h := true
    dashStk_12h := false
    conf_12h.em1 := 0, conf_12h.em2 := 0, conf_12h.em3 := 0, conf_12h.em4 := 0, conf_12h.total := 0
if f_zoneInvalid(zt_Db, zb_Db, bias_D)
    locked_D := true
    dashStk_D := false
    conf_D.em1  := 0, conf_D.em2  := 0, conf_D.em3  := 0, conf_D.em4  := 0, conf_D.total  := 0
if f_zoneInvalid(zt_Wb, zb_Wb, bias_W)
    locked_W := true
    dashStk_W := false

f_matches(int candleBias, int ovBias) => ovBias != 0 and candleBias == ovBias

m_4h  = f_matches(bias_4h,  overallBias) and not locked_4h
m_6h  = f_matches(bias_6h,  overallBias) and not locked_6h
m_8h  = f_matches(bias_8h,  overallBias) and not locked_8h
m_12h = f_matches(bias_12h, overallBias) and not locked_12h
m_D   = f_matches(bias_D,   overallBias) and not locked_D
m_W   = f_matches(bias_W,   overallBias) and not locked_W

f_getZT(int z) => z == 1 ? zt_4h : z == 2 ? zt_6h : z == 3 ? zt_8h : z == 4 ? zt_12h : z == 5 ? zt_Db : z == 6 ? zt_Wb : na
f_getZB(int z) => z == 1 ? zb_4h : z == 2 ? zb_6h : z == 3 ? zb_8h : z == 4 ? zb_12h : z == 5 ? zb_Db : z == 6 ? zb_Wb : na

f_touching(float zt, float zb) =>
    not na(zt) and not na(zb) and low <= math.max(zt, zb) and high >= math.min(zt, zb)

bool touch_4h  = m_4h  and f_touching(zt_4h,  zb_4h)
bool touch_6h  = m_6h  and f_touching(zt_6h,  zb_6h)
bool touch_8h  = m_8h  and f_touching(zt_8h,  zb_8h)
bool touch_12h = m_12h and f_touching(zt_12h, zb_12h)
bool touch_D   = m_D   and f_touching(zt_Db,  zb_Db)
bool touch_W   = m_W   and f_touching(zt_Wb,  zb_Wb)

int touchCount = (touch_4h ? 1 : 0) + (touch_6h ? 1 : 0) + (touch_8h ? 1 : 0) + (touch_12h ? 1 : 0) + (touch_D ? 1 : 0) + (touch_W ? 1 : 0)

// ── CONFLUENCE COUNTING ──
// Increment a zone's pattern counters ONLY when:
//   1. The PATTERN'S confirmation candle (bar [1]) physically touched that zone
//   2. A pattern fired on this bar (confirmed via §9 detection at bar close)
//   3. Zone is bias-aligned and not locked (m_* handles this)
// We check bar [1] touch — not current bar — because every pattern (EM1-4) is
// confirmed on bar [1], and price may have rejected fully out of the zone by
// the current bar (common for strong pin bar / engulfing rejections).
// Weekly deliberately omitted — signal-ineligible per system rules.
// Overlap note: a single bar can increment multiple counters (e.g. an engulfing
// pin bar bumps both em2 and em4). Each model is scored separately —
// intentional: two patterns agreeing = stronger evidence than one.
bool patFire_em1 = enableEM1 and (em1_buy or em1_sell)
bool patFire_em2 = enableEM2 and (em2_buy or em2_sell)
bool patFire_em3 = enableEM3 and (em3_buy or em3_sell)
bool patFire_em4 = enableEM4 and (em4_buy or em4_sell)

f_patternBarTouched(float zt, float zb) =>
    not na(zt) and not na(zb) and low[1] <= math.max(zt, zb) and high[1] >= math.min(zt, zb)

bool patTouch_4h  = m_4h  and f_patternBarTouched(zt_4h,  zb_4h)
bool patTouch_6h  = m_6h  and f_patternBarTouched(zt_6h,  zb_6h)
bool patTouch_8h  = m_8h  and f_patternBarTouched(zt_8h,  zb_8h)
bool patTouch_12h = m_12h and f_patternBarTouched(zt_12h, zb_12h)
bool patTouch_D   = m_D   and f_patternBarTouched(zt_Db,  zb_Db)

if patTouch_4h
    if patFire_em1
        conf_4h.em1 := conf_4h.em1 + 1
        conf_4h.total := conf_4h.total + 1
    if patFire_em2
        conf_4h.em2 := conf_4h.em2 + 1
        conf_4h.total := conf_4h.total + 1
    if patFire_em3
        conf_4h.em3 := conf_4h.em3 + 1
        conf_4h.total := conf_4h.total + 1
    if patFire_em4
        conf_4h.em4 := conf_4h.em4 + 1
        conf_4h.total := conf_4h.total + 1
if patTouch_6h
    if patFire_em1
        conf_6h.em1 := conf_6h.em1 + 1
        conf_6h.total := conf_6h.total + 1
    if patFire_em2
        conf_6h.em2 := conf_6h.em2 + 1
        conf_6h.total := conf_6h.total + 1
    if patFire_em3
        conf_6h.em3 := conf_6h.em3 + 1
        conf_6h.total := conf_6h.total + 1
    if patFire_em4
        conf_6h.em4 := conf_6h.em4 + 1
        conf_6h.total := conf_6h.total + 1
if patTouch_8h
    if patFire_em1
        conf_8h.em1 := conf_8h.em1 + 1
        conf_8h.total := conf_8h.total + 1
    if patFire_em2
        conf_8h.em2 := conf_8h.em2 + 1
        conf_8h.total := conf_8h.total + 1
    if patFire_em3
        conf_8h.em3 := conf_8h.em3 + 1
        conf_8h.total := conf_8h.total + 1
    if patFire_em4
        conf_8h.em4 := conf_8h.em4 + 1
        conf_8h.total := conf_8h.total + 1
if patTouch_12h
    if patFire_em1
        conf_12h.em1 := conf_12h.em1 + 1
        conf_12h.total := conf_12h.total + 1
    if patFire_em2
        conf_12h.em2 := conf_12h.em2 + 1
        conf_12h.total := conf_12h.total + 1
    if patFire_em3
        conf_12h.em3 := conf_12h.em3 + 1
        conf_12h.total := conf_12h.total + 1
    if patFire_em4
        conf_12h.em4 := conf_12h.em4 + 1
        conf_12h.total := conf_12h.total + 1
if patTouch_D
    if patFire_em1
        conf_D.em1 := conf_D.em1 + 1
        conf_D.total := conf_D.total + 1
    if patFire_em2
        conf_D.em2 := conf_D.em2 + 1
        conf_D.total := conf_D.total + 1
    if patFire_em3
        conf_D.em3 := conf_D.em3 + 1
        conf_D.total := conf_D.total + 1
    if patFire_em4
        conf_D.em4 := conf_D.em4 + 1
        conf_D.total := conf_D.total + 1


// ── STICKY TOUCH FLAGS (dashboard) ──
if touch_4h
    dashStk_4h := true
if touch_6h
    dashStk_6h := true
if touch_8h
    dashStk_8h := true
if touch_12h
    dashStk_12h := true
if touch_D
    dashStk_D := true
if touch_W
    dashStk_W := true

if not m_4h
    dashStk_4h := false
if not m_6h
    dashStk_6h := false
if not m_8h
    dashStk_8h := false
if not m_12h
    dashStk_12h := false
if not m_D
    dashStk_D := false
if not m_W
    dashStk_W := false

// ── 3-STEP SYSTEM: STEP 2 — Zone Touch Tracking ──
// Weekly zone is excluded from Step-2 eligibility — only 4H/6H/8H/12H/Daily
// taps can arm the system. A weekly-only tap must not flip stepTwoMet.
bool tapInWindow = windowTapsOnly ? mergedTW : true
int  signalTouchCount = (touch_4h ? 1 : 0) + (touch_6h ? 1 : 0) + (touch_8h ? 1 : 0) + (touch_12h ? 1 : 0) + (touch_D ? 1 : 0)
if signalTouchCount > 0 and overallBias != 0 and tapInWindow
    stepTwoMet  := true
    stepTwoBias := overallBias

bool anyDashTouched = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D or dashStk_W
// Signal-eligible touch set (weekly excluded) — used to de-arm Step 2 when no
// signalable zone remains. If only weekly is still touched, Step 2 goes idle.
bool anyDashTouchedSignalable = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D
if stepTwoMet and not anyDashTouchedSignalable
    stepTwoMet  := false
    stepTwoBias := 0

bool stepTwoValid = stepTwoMet and stepTwoBias == overallBias and overallBias != 0

// Active zone selection
int activeZone = anyDashTouched ? (dashStk_4h ? 1 : dashStk_6h ? 2 : dashStk_8h ? 3 : dashStk_12h ? 4 : dashStk_D ? 5 : dashStk_W ? 6 : 0) : (m_4h ? 1 : m_6h ? 2 : m_8h ? 3 : m_12h ? 4 : m_D ? 5 : m_W ? 6 : 0)
float activeZT = f_getZT(activeZone)
float activeZB = f_getZB(activeZone)

string activeZoneStr = activeZone == 1 ? "4H" : activeZone == 2 ? "6H" : activeZone == 3 ? "8H" : activeZone == 4 ? "12H" : activeZone == 5 ? "Daily" : activeZone == 6 ? "Weekly" : "None"

int ms_4h  = 240  * 60 * 1000
int ms_6h  = 360  * 60 * 1000
int ms_8h  = 480  * 60 * 1000
int ms_12h = 720  * 60 * 1000
int ms_D   = 1440 * 60 * 1000
int ms_W   = 7 * 1440 * 60 * 1000

int activeOpenTime  = activeZone == 1 ? time_now_4h : activeZone == 2 ? time_now_6h : activeZone == 3 ? time_now_8h : activeZone == 4 ? time_now_12h : activeZone == 5 ? time_now_D : activeZone == 6 ? time_now_W : na
int activeMS        = activeZone == 1 ? ms_4h : activeZone == 2 ? ms_6h : activeZone == 3 ? ms_8h : activeZone == 4 ? ms_12h : activeZone == 5 ? ms_D : activeZone == 6 ? ms_W : 0
int activeCloseTime = not na(activeOpenTime) ? activeOpenTime + activeMS : na

// Shared predicate — trade is "frozen-zone" live iff a live trade exists AND risk
// is still on the line (TP1 not yet secured). Used by both §13 and §16.
bool tradeFrozen = (trade.status == "Active" or trade.status == "Triggered") and not na(zone.zt) and not trade.tp1hit

// ── SINGLE DISCOUNT BOX: shows as soon as zone is valid ──
autoZoneClr    = overallBias == 1 ? bull_fill : overallBias == -1 ? bear_fill : color.new(color.yellow, 80)
autoZoneBorder = overallBias == 1 ? bull_border : overallBias == -1 ? bear_border : color.yellow
autoMidClr     = overallBias == 1 ? color.new(color.green, 30) : overallBias == -1 ? color.new(color.red, 30) : color.new(color.yellow, 30)

var box  autoBox = na
var label autoLbl = na
var line  autoMid = na

if barstate.islast and autoDiscount
    box.delete(autoBox)
    label.delete(autoLbl)
    line.delete(autoMid)
    if activeZone != 0 and not na(activeZT) and not na(activeZB) and not na(activeOpenTime) and not tradeFrozen
        autoBox := box.new(activeOpenTime, activeZT, activeCloseTime, activeZB, xloc=xloc.bar_time, border_color=autoZoneBorder, bgcolor=autoZoneClr, border_width=1, border_style=line.style_dashed)
        // Zone label includes confluence score when enabled — e.g. "4H Discount · Σ3"
        int liveConfTotal = activeZone == 1 ? conf_4h.total : activeZone == 2 ? conf_6h.total : activeZone == 3 ? conf_8h.total : activeZone == 4 ? conf_12h.total : activeZone == 5 ? conf_D.total : 0
        string activeScoreTxt = showZoneScore and liveConfTotal > 0 ? " · Σ" + str.tostring(liveConfTotal) : ""
        autoLbl := label.new(activeCloseTime, math.avg(activeZT, activeZB), activeZoneStr + " Discount" + activeScoreTxt, xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=autoZoneBorder, style=label.style_label_left, size=size.small)
        float midPrice = math.avg(activeZT, activeZB)
        autoMid := line.new(activeOpenTime, midPrice, activeCloseTime, midPrice, xloc=xloc.bar_time, color=autoMidClr, width=2, style=line.style_solid)


// ─────────────────────────────────────────────────────────────────────────────
// §10  SIGNAL LABELS & TRADE ENTRY  (relocated — runs after §13 so per-zone
//       confluence counters include THIS bar's pattern fire)
// ─────────────────────────────────────────────────────────────────────────────

var DTG_Signal = array.new_label()
label_size = showLabel == "Symbol" ? size.auto : size.tiny
buy_style  = showLabel == "Symbol" ? label.style_triangleup   : label.style_label_up
sell_style = showLabel == "Symbol" ? label.style_triangledown : label.style_label_down

// ── 3-STEP SYSTEM GATE ──
// Step 1 (bias)    — overallBias != 0
// Step 2 (zone tap) — stepTwoMet AND current tapped zone still present
// Step 3 (pattern) — any enabled EM fires this bar
// Plus: the tapped zone's confluence must be ≥ minZoneConf.
// Weekly zones are excluded from every one of these (handled at sticky-flag level).
bool em_hasTouchedZones = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D
bool em_stepTwoValid    = requireZoneTap ? (stepTwoMet and stepTwoBias == overallBias and overallBias != 0 and em_hasTouchedZones) : (overallBias != 0)
bool em_systemReady     = em_stepTwoValid and (not oneTradePerDay or not dailyProfitTaken)
bool em_allowed         = trade.status != "Triggered" and em_systemReady

// ── CONFLUENCE CHECK ──
// Use the active zone's confluence counter (weekly returns na → treated as 0).
int activeConfTotal = activeZone == 1 ? conf_4h.total : activeZone == 2 ? conf_6h.total : activeZone == 3 ? conf_8h.total : activeZone == 4 ? conf_12h.total : activeZone == 5 ? conf_D.total : 0
bool confluenceMet  = activeConfTotal >= minZoneConf

// ── PER-MODEL FINAL FLAGS ──
// Each model passes the system gate + confluence + its own enable toggle.
bool fire_em1_buy  = enableEM1 and em1_buy  and em_allowed and confluenceMet and showLabel != "Off"
bool fire_em1_sell = enableEM1 and em1_sell and em_allowed and confluenceMet and showLabel != "Off"
bool fire_em2_buy  = enableEM2 and em2_buy  and em_allowed and confluenceMet and showLabel != "Off"
bool fire_em2_sell = enableEM2 and em2_sell and em_allowed and confluenceMet and showLabel != "Off"
bool fire_em3_buy  = enableEM3 and em3_buy  and em_allowed and confluenceMet and showLabel != "Off"
bool fire_em3_sell = enableEM3 and em3_sell and em_allowed and confluenceMet and showLabel != "Off"
bool fire_em4_buy  = enableEM4 and em4_buy  and em_allowed and confluenceMet and showLabel != "Off"
bool fire_em4_sell = enableEM4 and em4_sell and em_allowed and confluenceMet and showLabel != "Off"

// ── Tiebreaker: tightest SL wins (best R:R) ──
// Each model defines its own entry/SL based on its pattern anatomy.
// When multiple fire on the same bar, the one with the smallest |entry−SL|
// pays the user the best R:R. Deterministic, doesn't need extra inputs.
// Entries/SL formulas (all rounded to syminfo.mintick downstream):
//   EM1/EM2 buy  — entry = high[1] + spread, SL = low[1]  − 3·spread
//   EM1/EM2 sell — entry = low[1]  − spread, SL = high[1] + 3·spread
//   EM3 buy      — entry = high[1] + spread, SL = low[3]  − 3·spread (mother-bar low)
//   EM3 sell     — entry = low[1]  − spread, SL = high[3] + 3·spread (mother-bar high)
//   EM4 buy      — entry = high[1] + spread, SL = low[1]  − 3·spread (wick tip below)
//   EM4 sell     — entry = low[1]  − spread, SL = high[1] + 3·spread (wick tip above)
// Note: EM1/EM2/EM4 share the same entry/SL formula (diff is just pattern),
// so tiebreak among those three is indistinguishable — we use declaration
// order (EM1 → EM2 → EM4). EM3 uses mother-bar low/high so its SL distance
// differs; if it wins on tightest-SL basis, it's selected.

// Calculate candidate SL distances for tiebreaker
float sp   = spread_tick
float em1_buy_entry  = high[1] + inputSpread * sp, em1_buy_sl  = low[1]  - 3 * sp
float em1_sell_entry = low[1]  - inputSpread * sp, em1_sell_sl = high[1] + 3 * sp
float em3_buy_sl     = low[3]  - 3 * sp
float em3_sell_sl    = high[3] + 3 * sp

// Pick winner: build (model, entry, SL, text) from whichever has the tightest SL
string chosen_model = na
float  chosen_entry = na
float  chosen_sl    = na
color  chosen_bias  = na
bool   isBuy        = false
if fire_em1_buy or fire_em2_buy or fire_em3_buy or fire_em4_buy
    isBuy := true
    // Smallest entry − SL wins. For EM1/EM2/EM4 (same formula) → EM1 wins by declaration order.
    float cand_em1_dist = fire_em1_buy ? (em1_buy_entry - em1_buy_sl) : 1e20
    float cand_em2_dist = fire_em2_buy ? (em1_buy_entry - em1_buy_sl) : 1e20
    float cand_em3_dist = fire_em3_buy ? (em1_buy_entry - em3_buy_sl) : 1e20
    float cand_em4_dist = fire_em4_buy ? (em1_buy_entry - em1_buy_sl) : 1e20
    float min_dist = math.min(math.min(cand_em1_dist, cand_em2_dist), math.min(cand_em3_dist, cand_em4_dist))
    if fire_em1_buy and cand_em1_dist == min_dist
        chosen_model := "EM1"
        chosen_entry := em1_buy_entry, chosen_sl := em1_buy_sl
    else if fire_em2_buy and cand_em2_dist == min_dist
        chosen_model := "EM2"
        chosen_entry := em1_buy_entry, chosen_sl := em1_buy_sl
    else if fire_em4_buy and cand_em4_dist == min_dist
        chosen_model := "EM4"
        chosen_entry := em1_buy_entry, chosen_sl := em1_buy_sl
    else if fire_em3_buy and cand_em3_dist == min_dist
        chosen_model := "EM3"
        chosen_entry := em1_buy_entry, chosen_sl := em3_buy_sl
    chosen_bias := buy_c
else if fire_em1_sell or fire_em2_sell or fire_em3_sell or fire_em4_sell
    isBuy := false
    float cand_em1_dist = fire_em1_sell ? (em1_sell_sl - em1_sell_entry) : 1e20
    float cand_em2_dist = fire_em2_sell ? (em1_sell_sl - em1_sell_entry) : 1e20
    float cand_em3_dist = fire_em3_sell ? (em3_sell_sl - em1_sell_entry) : 1e20
    float cand_em4_dist = fire_em4_sell ? (em1_sell_sl - em1_sell_entry) : 1e20
    float min_dist = math.min(math.min(cand_em1_dist, cand_em2_dist), math.min(cand_em3_dist, cand_em4_dist))
    if fire_em1_sell and cand_em1_dist == min_dist
        chosen_model := "EM1"
        chosen_entry := em1_sell_entry, chosen_sl := em1_sell_sl
    else if fire_em2_sell and cand_em2_dist == min_dist
        chosen_model := "EM2"
        chosen_entry := em1_sell_entry, chosen_sl := em1_sell_sl
    else if fire_em4_sell and cand_em4_dist == min_dist
        chosen_model := "EM4"
        chosen_entry := em1_sell_entry, chosen_sl := em1_sell_sl
    else if fire_em3_sell and cand_em3_dist == min_dist
        chosen_model := "EM3"
        chosen_entry := em1_sell_entry, chosen_sl := em3_sell_sl
    chosen_bias := sell_c

// ── FIRE THE TRADE if a model was chosen ──
if not na(chosen_model)
    trade.bar        := bar_index
    trade.triggerBar := na
    trade.time       := time
    trade.status     := "Active"
    trade.entry      := math.round(chosen_entry, digits)
    trade.sl         := math.round(chosen_sl,    digits)
    trade.tp1        := math.round(2 * trade.entry - trade.sl, digits)
    trade.tp2        := math.round(3 * trade.entry - 2 * trade.sl, digits)
    trade.bias       := chosen_bias
    trade.model      := chosen_model
    trade.tp1hit     := false
    string lbl_text = showLabel == "Symbol" ? "" : chosen_model
    if isBuy
        f_DTG_algo(DTG_Signal, bar_index, low,  yloc.belowbar, buy_c,  buy_style,  lbl_text, txt_c, label_size)
    else
        f_DTG_algo(DTG_Signal, bar_index, high, yloc.abovebar, sell_c, sell_style, lbl_text, txt_c, label_size)
    alert(chosen_model + " " + (isBuy ? "buy" : "sell") + " setup on the " + TF_txt + " Consult data table before proceeding.", alert.freq_once_per_bar)

f_LABEL_truncate(DTG_Signal, showMax)

// ── RAW PATTERN ALERTS (no system gate) — for users who want pattern-only alerts ──
bool rawBuy  = (buySignal)  and trade.status != "Triggered" and overallBias == 1
bool rawSell = (sellSignal) and trade.status != "Triggered" and overallBias == -1

bool validBuy  = not na(chosen_model) and isBuy
bool validSell = not na(chosen_model) and not isBuy

alertcondition(validBuy or validSell,  title="System Signal",  message="DTG V8: Valid SYSTEM signal. Check dashboard for trade details.")
alertcondition(rawBuy or rawSell,      title="Pattern Signal", message="DTG V8: EM pattern detected (system rules not applied).")


// ─────────────────────────────────────────────────────────────────────────────
// §12  TRADE STATUS MACHINE  (relocated with §10)
// ─────────────────────────────────────────────────────────────────────────────

if trade.status == "Active" and (bar_index - nz(trade.bar)) == 0
    if trade.bias == sell_c and low < trade.entry
        trade.status     := "Triggered"
        trade.triggerBar := bar_index
    else if trade.bias == buy_c and high > trade.entry
        trade.status     := "Triggered"
        trade.triggerBar := bar_index
    else
        trade.status := "Active"

if trade.status == "Active" and (bar_index - nz(trade.bar)) == 1
    trade.status := "Invalid"

if trade.status == "Invalid"
    if bar_index - nz(trade.bar) > 1
        trade.status := "Scanning"

// Triggered = live trade. Only exits on TP2, SL, or BE (entry) hit.
// V8.1 FIX #1: wasTP1hit snapshot prevents same-bar TP1+BE race.
// V8.1 FIX #2: gate with bar_index > trade.triggerBar — skip the trigger bar
//              so a pre-trigger wick through SL isn't counted as a loss.
if trade.status == "Triggered" and bar_index > nz(trade.triggerBar)
    bool wasTP1hit = trade.tp1hit
    bool checkTP1  = (trade.bias == buy_c and high > trade.tp1) or (trade.bias == sell_c and low < trade.tp1)
    if checkTP1
        trade.tp1hit := true
    bool hitTP2 = (trade.bias == sell_c and low < trade.tp2) or (trade.bias == buy_c and high > trade.tp2)
    bool hitSL  = not wasTP1hit and ((trade.bias == sell_c and high > trade.sl) or (trade.bias == buy_c and low < trade.sl))
    bool hitBE  = wasTP1hit and ((trade.bias == buy_c and low < trade.entry) or (trade.bias == sell_c and high > trade.entry))
    if hitTP2 or hitBE or hitSL
        if hitTP2
            dailyProfitTaken := true
        int   outcomeCode = hitTP2 ? 1 : hitBE ? 0 : -1
        float rMult       = outcomeCode == 1 ? 2.0 : outcomeCode == 0 ? 1.0 : -1.0
        TradeRecord rec = TradeRecord.new(bar=trade.bar, exitBar=bar_index, time=trade.time, exitTime=time, entry=trade.entry, sl=trade.sl, tp1=trade.tp1, tp2=trade.tp2, dir=trade.bias == buy_c ? 1 : -1, outcome=outcomeCode, rMultiple=rMult, model=trade.model, zoneTF=trade.zoneTF)
        array.push(trades, rec)
        if array.size(trades) > statsMax
            array.shift(trades)
        trade.status := "Scanning"
        trade.tp1hit := false

if na(trade.status)
    trade.status := "None"

noSignal_Bias = (trade.status == "Scanning" or trade.status == "None") ? H4_c : trade.bias


// ─────────────────────────────────────────────────────────────────────────────
// §14  DISCOUNT ZONE TOUCH SUMMARY (dashboard string)
// ─────────────────────────────────────────────────────────────────────────────

string touchZonesStr = ""
if dashStk_4h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "4H"
if dashStk_6h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "6H"
if dashStk_8h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "8H"
if dashStk_12h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "12H"
if dashStk_D
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "D"
if dashStk_W
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "W"
if touchZonesStr == ""
    touchZonesStr := "None"


// ─────────────────────────────────────────────────────────────────────────────
// §15  TRADE ZONE SNAPSHOT
// ─────────────────────────────────────────────────────────────────────────────

if (trade.status == "Active" or trade.status == "Triggered") and trade.bar == bar_index and activeZone != 0
    zone.zt        := activeZT
    zone.zb        := activeZB
    zone.openTime  := activeOpenTime
    zone.closeTime := activeCloseTime
    zone.tfLabel   := activeZoneStr
    zone.bias      := overallBias
    // Stamp the source zone TF onto the trade record too — surfaces in stats
    // so users can see win-rate segmented by zone TF.
    trade.zoneTF   := activeZoneStr

if trade.status == "Scanning" or trade.status == "None"
    zone.zt        := na
    zone.zb        := na
    zone.openTime  := na
    zone.closeTime := na
    zone.tfLabel   := na
    zone.bias      := 0


// ─────────────────────────────────────────────────────────────────────────────
// §16  FIXED R:R BOXES + TRADE ZONE BOX
// ─────────────────────────────────────────────────────────────────────────────

var box   rrBoxSL  = na
var box   rrBoxTP1 = na
var box   rrBoxTP2 = na
var line  rrEntry  = na
var label rrTP1lbl = na
var box   tradeZoneBox = na
var label tradeZoneLbl = na
var line  tradeZoneMid = na

bool hasActiveTrade = (trade.status == "Active" or trade.status == "Triggered") and not na(trade.entry) and not na(trade.bar)

if barstate.islast and showRR
    box.delete(rrBoxSL),  box.delete(rrBoxTP1), box.delete(rrBoxTP2)
    line.delete(rrEntry)
    label.delete(rrTP1lbl)

    if hasActiveTrade
        int rr_left  = trade.bar
        int rr_right = bar_index + 15

        if trade.bias == buy_c
            float sl_bottom = trade.tp1hit ? trade.entry : trade.sl
            color sl_bg     = trade.tp1hit ? color.new(#FF9100, 92) : color.new(#FF1744, 88)
            color sl_bdr    = trade.tp1hit ? color.new(#FF9100, 60) : color.new(#FF1744, 60)
            rrBoxSL  := box.new(rr_left, trade.entry, rr_right, sl_bottom, border_color=sl_bdr, bgcolor=sl_bg, border_width=1)
            rrBoxTP1 := box.new(rr_left, trade.tp1,   rr_right, trade.entry, border_color=color.new(#00C853, 60), bgcolor=color.new(#00C853, 88), border_width=1)
            rrBoxTP2 := box.new(rr_left, trade.tp2,   rr_right, trade.tp1,   border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 92), border_width=1)
            rrEntry  := line.new(rr_left, trade.entry, rr_right, trade.entry, color=color.new(#FFFFFF, 30), style=line.style_solid, width=2)
            if trade.tp1hit
                rrTP1lbl := label.new(rr_right, trade.tp1, "1:1 ✓", color=color.new(#00C853, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

        else if trade.bias == sell_c
            float sl_top = trade.tp1hit ? trade.entry : trade.sl
            color sl_bg  = trade.tp1hit ? color.new(#FF9100, 92) : color.new(#FF1744, 88)
            color sl_bdr = trade.tp1hit ? color.new(#FF9100, 60) : color.new(#FF1744, 60)
            rrBoxSL  := box.new(rr_left, sl_top,      rr_right, trade.entry, border_color=sl_bdr, bgcolor=sl_bg, border_width=1)
            rrBoxTP1 := box.new(rr_left, trade.entry, rr_right, trade.tp1,   border_color=color.new(#00C853, 60), bgcolor=color.new(#00C853, 88), border_width=1)
            rrBoxTP2 := box.new(rr_left, trade.tp1,   rr_right, trade.tp2,   border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 92), border_width=1)
            rrEntry  := line.new(rr_left, trade.entry, rr_right, trade.entry, color=color.new(#FFFFFF, 30), style=line.style_solid, width=2)
            if trade.tp1hit
                rrTP1lbl := label.new(rr_right, trade.tp1, "1:1 ✓", color=color.new(#00C853, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

if barstate.islast and autoDiscount
    box.delete(tradeZoneBox)
    label.delete(tradeZoneLbl)
    line.delete(tradeZoneMid)
    if tradeFrozen and not na(zone.zb) and not na(zone.openTime)
        color tzFill   = zone.bias == 1 ? bull_fill : zone.bias == -1 ? bear_fill : color.new(color.yellow, 80)
        color tzBorder = zone.bias == 1 ? bull_border : zone.bias == -1 ? bear_border : color.yellow
        color tzMidClr = zone.bias == 1 ? color.new(color.green, 30) : zone.bias == -1 ? color.new(color.red, 30) : color.new(color.yellow, 30)
        // Frozen zone label — includes confluence score from the zone that fired the trade
        int frozenConfTotal = zone.tfLabel == "4H" ? conf_4h.total : zone.tfLabel == "6H" ? conf_6h.total : zone.tfLabel == "8H" ? conf_8h.total : zone.tfLabel == "12H" ? conf_12h.total : zone.tfLabel == "Daily" ? conf_D.total : 0
        string frozenScoreTxt = showZoneScore and frozenConfTotal > 0 ? " · Σ" + str.tostring(frozenConfTotal) : ""
        string tzLabel = (na(zone.tfLabel) ? "" : zone.tfLabel) + " Discount" + frozenScoreTxt
        tradeZoneBox := box.new(zone.openTime, zone.zt, zone.closeTime, zone.zb, xloc=xloc.bar_time, border_color=tzBorder, bgcolor=tzFill, border_width=1, border_style=line.style_solid)
        tradeZoneLbl := label.new(zone.closeTime, math.avg(zone.zt, zone.zb), tzLabel, xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=tzBorder, style=label.style_label_left, size=size.small)
        float tzMid = math.avg(zone.zt, zone.zb)
        tradeZoneMid := line.new(zone.openTime, tzMid, zone.closeTime, tzMid, xloc=xloc.bar_time, color=tzMidClr, width=2, style=line.style_solid)


// ─────────────────────────────────────────────────────────────────────────────
// §16b  TRADE HISTORY — draw completed trades on chart
// ─────────────────────────────────────────────────────────────────────────────

var box   lastBoxSL  = na
var box   lastBoxTP1 = na
var box   lastBoxTP2 = na
var line  lastEntry  = na
var label lastLbl    = na

if barstate.islast and showHistory
    box.delete(lastBoxSL), box.delete(lastBoxTP1), box.delete(lastBoxTP2)
    line.delete(lastEntry)
    label.delete(lastLbl)

    // Read the most recently closed trade from the ring buffer.
    if array.size(trades) > 0
        TradeRecord last = array.last(trades)
        if not na(last.time) and not na(last.exitTime)
            bool  isWin    = last.outcome == 1
            bool  isBE     = last.outcome == 0
            color slBG     = color.new(#FF1744, 92)
            color tp1BG    = color.new(#00C853, 92)
            color tp2BG    = color.new(#00E676, 94)
            int   minWidth = timeframe.in_seconds() * 1000 * 3
            int   hLeft    = last.time
            int   hRight   = math.max(last.exitTime, last.time + minWidth)

            if last.dir == 1
                lastBoxSL  := box.new(hLeft, last.entry, hRight, last.sl,    xloc=xloc.bar_time, border_color=color.new(#FF1744, 70), bgcolor=slBG,  border_width=1)
                lastBoxTP1 := box.new(hLeft, last.tp1,   hRight, last.entry, xloc=xloc.bar_time, border_color=color.new(#00C853, 70), bgcolor=tp1BG, border_width=1)
                lastBoxTP2 := box.new(hLeft, last.tp2,   hRight, last.tp1,   xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)
            else
                lastBoxSL  := box.new(hLeft, last.sl,    hRight, last.entry, xloc=xloc.bar_time, border_color=color.new(#FF1744, 70), bgcolor=slBG,  border_width=1)
                lastBoxTP1 := box.new(hLeft, last.entry, hRight, last.tp1,   xloc=xloc.bar_time, border_color=color.new(#00C853, 70), bgcolor=tp1BG, border_width=1)
                lastBoxTP2 := box.new(hLeft, last.tp1,   hRight, last.tp2,   xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)

            lastEntry := line.new(hLeft, last.entry, hRight, last.entry, xloc=xloc.bar_time, color=color.new(#FFFFFF, 60), style=line.style_dotted, width=1)

            string outTxt  = isWin ? "W" : isBE ? "1:1" : "L"
            color  outLblC = isWin ? color.new(#00C853, 20) : isBE ? color.new(#00C853, 30) : color.new(#FF1744, 20)
            int    lblTime = int(math.avg(hLeft, hRight))
            float  lblY    = last.tp2
            if last.dir == 1
                lastLbl := label.new(lblTime, lblY, outTxt, xloc=xloc.bar_time, color=outLblC, textcolor=color.white, style=label.style_label_down, size=size.tiny)
            else
                lastLbl := label.new(lblTime, lblY, outTxt, xloc=xloc.bar_time, color=outLblC, textcolor=color.white, style=label.style_label_up, size=size.tiny)


// ─────────────────────────────────────────────────────────────────────────────
// §17  ORIGINAL DISCOUNT ZONE BOX (draws when auto is off)
// ─────────────────────────────────────────────────────────────────────────────

int   extend_bars = 50
[tf_open, tf_high, tf_low, tf_close] = request.security(syminfo.tickerid, base_tf, [open[1], high[1], low[1], close[1]], barmerge.gaps_off, barmerge.lookahead_off)
int   tf_time_open = request.security(syminfo.tickerid, base_tf, time[1], barmerge.gaps_off, barmerge.lookahead_off)

int  base_ms       = timeframe.in_seconds(base_tf) * 1000
int  tf_time_close = tf_time_open + base_ms
bool new_tf        = timeframe.change(base_tf)

var box  fib_box  = na
var line fib_line = na

int right_time = tf_time_close + extend_bars * base_ms

if new_tf
    if not enableFib or autoDiscount
        if not na(fib_box)
            box.delete(fib_box)
            fib_box := na
        if not na(fib_line)
            line.delete(fib_line)
            fib_line := na
    else
        if not na(fib_box)
            box.delete(fib_box)
        if not na(fib_line)
            line.delete(fib_line)

        bool  is_bull  = tf_close > tf_open
        bool  is_bear  = tf_close < tf_open
        float tf_range = tf_high - tf_low

        float bull_p05  = tf_low + tf_range * 0.50
        float bull_p618 = tf_low + tf_range * 0.382
        float bull_p75  = tf_low + tf_range * 0.25

        float bear_p05  = tf_high - tf_range * 0.50
        float bear_p618 = tf_high - tf_range * 0.382
        float bear_p75  = tf_high - tf_range * 0.25

        float a          = na
        float b          = na
        float mid_price  = na
        color fill_col   = na
        color border_col = na

        if is_bull
            a          := bull_p05
            b          := bull_p75
            mid_price  := bull_p618
            fill_col   := bull_fill
            border_col := bull_border
        else if is_bear
            a          := bear_p05
            b          := bear_p75
            mid_price  := bear_p618
            fill_col   := bear_fill
            border_col := bear_border

        float top_price    = math.max(a, b)
        float bottom_price = math.min(a, b)

        if not na(top_price) and not na(bottom_price) and not na(mid_price)
            fib_box := box.new(left=tf_time_close, top=top_price, right=right_time, bottom=bottom_price, xloc=xloc.bar_time)
            box.set_bgcolor(fib_box, fill_col)
            box.set_border_color(fib_box, border_col)
            box.set_border_width(fib_box, 1)

            fib_line := line.new(x1=tf_time_close, y1=mid_price, x2=right_time, y2=mid_price, xloc=xloc.bar_time)
            line.set_color(fib_line, border_col)
            line.set_width(fib_line, line_width)

if barstate.islast and autoDiscount
    if not na(fib_box)
        box.delete(fib_box)
        fib_box := na
    if not na(fib_line)
        line.delete(fib_line)
        fib_line := na


// ─────────────────────────────────────────────────────────────────────────────
// §17b  PERFORMANCE STATS — computed on last bar from `trades[]`
// ─────────────────────────────────────────────────────────────────────────────
// Scope=Today counts only records whose exit time is ≥ todayStartTime (the
// current day's reset). Scope=All Time iterates the whole buffer. Current
// streak walks from the newest record backwards while outcome sign is stable.
//   rMultiple: +2 = TP2 win, +1 = 1:1 secured, -1 = SL
//   Profit factor = sum of positive R / abs(sum of negative R)
//   Expectancy    = average rMultiple per trade
//   Streak text prefixes: "W" winning, "L" losing, "—" empty

int   stats_total  = 0
int   stats_wins   = 0
int   stats_ones   = 0
int   stats_losses = 0
float stats_sumR   = 0.0
float stats_gross  = 0.0
float stats_loss   = 0.0

if showStats and barstate.islast and array.size(trades) > 0
    int n = array.size(trades)
    for i = 0 to n - 1
        TradeRecord r = array.get(trades, i)
        bool inScope = statsScope == "All Time" or (not na(todayStartTime) and not na(r.exitTime) and r.exitTime >= todayStartTime)
        if inScope
            stats_total  += 1
            stats_sumR   += r.rMultiple
            if r.outcome == 1
                stats_wins += 1
            else if r.outcome == 0
                stats_ones += 1
            else
                stats_losses += 1
            if r.rMultiple > 0
                stats_gross += r.rMultiple
            else
                stats_loss  += -r.rMultiple

// Streak sign: look at the newest in-scope record. Walk back while outcome
// stays in the same "winning" / "losing" bucket (1:1 counts as neutral-winning
// since it closes at BE+TP1, so we group outcome >= 0 as the winning side).
int   stats_streak     = 0
int   stats_streakSign = 0
if showStats and barstate.islast and array.size(trades) > 0
    int n2 = array.size(trades)
    int walkIdx = n2 - 1
    // Skip any out-of-scope records at the tail
    if statsScope == "Today"
        while walkIdx >= 0
            TradeRecord tail = array.get(trades, walkIdx)
            bool inS = not na(todayStartTime) and not na(tail.exitTime) and tail.exitTime >= todayStartTime
            if inS
                break
            walkIdx -= 1
    if walkIdx >= 0
        TradeRecord head = array.get(trades, walkIdx)
        stats_streakSign := head.outcome >= 0 ? 1 : -1
        stats_streak     := 1
        walkIdx          -= 1
        while walkIdx >= 0
            TradeRecord r2 = array.get(trades, walkIdx)
            bool inS2 = statsScope == "All Time" or (not na(todayStartTime) and not na(r2.exitTime) and r2.exitTime >= todayStartTime)
            if not inS2
                break
            int thisSign = r2.outcome >= 0 ? 1 : -1
            if thisSign != stats_streakSign
                break
            stats_streak += 1
            walkIdx      -= 1

float stats_winRate    = stats_total > 0 ? 100.0 * (stats_wins + stats_ones) / stats_total : na
float stats_expectancy = stats_total > 0 ? stats_sumR / stats_total : na
float stats_pf         = stats_loss > 0 ? stats_gross / stats_loss : (stats_gross > 0 ? 999.0 : na)


// ─────────────────────────────────────────────────────────────────────────────
// §18  DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────

// ── System state string for dashboard ──
string systemStateStr = ""
color  systemStateClr = color.new(color.gray, 0)

if dailyProfitTaken and oneTradePerDay
    systemStateStr := "✓ Complete"
    systemStateClr := color.new(#00E676, 0)
else if not stepTwoValid and overallBias == 0
    systemStateStr := "No Bias"
    systemStateClr := color.new(color.yellow, 0)
else if not stepTwoValid and overallBias != 0
    systemStateStr := "Awaiting"
    systemStateClr := color.new(color.orange, 0)
else if stepTwoValid
    systemStateStr := "Ready"
    systemStateClr := color.new(#00E5FF, 0)

color step1Clr  = overallBias != 0 ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)
color step2Clr  = stepTwoValid and anyDashTouched ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)
bool  showTrade = trade.status == "Active" or trade.status == "Triggered"
color step3Clr  = showTrade ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)

// Dashboard build is confined to the last bar — all historical bars would
// paint identical values that are immediately overwritten, so doing it once
// on `islast` is a big runtime saver with zero visual change.
if showTable and barstate.islast
    color baseBG     = color.new(#111122, 0)
    color titleBG    = color.new(#0a0a1a, 0)
    color titleTxt   = color.new(#8899bb, 0)
    color labelTxt   = color.new(#7a7a9e, 0)
    color valueTxt   = color.new(#e8e8f0, 0)
    color dividerBG  = color.new(#1e1e38, 0)
    color frameBG    = color.new(#1e1e38, 0)
    color dotBG      = color.new(#111122, 0)

    tblSize = dashSize == "tiny" ? size.tiny : dashSize == "small" ? size.small : dashSize == "large" ? size.large : size.normal
    dotSize = dashSize == "large" ? size.normal : dashSize == "normal" ? size.small : size.tiny

    var table main_table = table.new(position.top_right, 3, 11, bgcolor=baseBG, border_color=frameBG, border_width=0, frame_color=frameBG, frame_width=1)

    table.cell(main_table, 0, 0, "", bgcolor=titleBG)
    table.cell(main_table, 1, 0, "DTG", text_color=valueTxt, text_size=tblSize, bgcolor=titleBG, text_halign=text.align_right)
    table.cell(main_table, 2, 0, "STRATEGY", text_color=titleTxt, text_size=tblSize, bgcolor=titleBG, text_halign=text.align_left)

    table.cell(main_table, 0, 1, "●", text_color=step1Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 1, "Bias", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 1, biasLabel, text_color=valueTxt, text_size=tblSize, bgcolor=color.new(biasColor, 30), text_halign=text.align_center)

    discClr = touchZonesStr != "None" ? biasColor : color.new(color.gray, 0)
    discTxtSize = str.length(touchZonesStr) > 12 ? size.tiny : str.length(touchZonesStr) > 5 ? size.small : tblSize
    table.cell(main_table, 0, 2, "●", text_color=step2Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 2, "Touched", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 2, touchZonesStr, text_color=valueTxt, text_size=discTxtSize, bgcolor=color.new(discClr, 30), text_halign=text.align_center)

    table.cell(main_table, 0, 3, "●", text_color=step3Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 3, "Signal", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 3, trade.status, text_color=valueTxt, text_size=tblSize, bgcolor=color.new(noSignal_Bias, 30), text_halign=text.align_center)

    table.cell(main_table, 0, 4, "", bgcolor=dividerBG)
    table.cell(main_table, 1, 4, "System", text_color=labelTxt, text_size=tblSize, bgcolor=dividerBG, text_halign=text.align_right)
    table.cell(main_table, 2, 4, systemStateStr, text_color=color.white, text_size=tblSize, bgcolor=color.new(systemStateClr, 20), text_halign=text.align_center)

    // Row 5 — Model + Confluence (combined). Shows the EM that fired (or "—" when
    // scanning), plus the confluence score of the relevant zone. While scanning,
    // the active zone's live score is shown so you can see confluence building.
    int dashConfTotal = 0
    string dashConfZone = ""
    if showTrade and not na(trade.zoneTF)
        dashConfTotal := trade.zoneTF == "4H" ? conf_4h.total : trade.zoneTF == "6H" ? conf_6h.total : trade.zoneTF == "8H" ? conf_8h.total : trade.zoneTF == "12H" ? conf_12h.total : trade.zoneTF == "Daily" ? conf_D.total : 0
        dashConfZone := trade.zoneTF
    else
        dashConfTotal := activeZone == 1 ? conf_4h.total : activeZone == 2 ? conf_6h.total : activeZone == 3 ? conf_8h.total : activeZone == 4 ? conf_12h.total : activeZone == 5 ? conf_D.total : 0
        dashConfZone := activeZone == 1 ? "4H" : activeZone == 2 ? "6H" : activeZone == 3 ? "8H" : activeZone == 4 ? "12H" : activeZone == 5 ? "D" : ""
    string modelStr = (showTrade and not na(trade.model) ? trade.model : "—") + (dashConfTotal > 0 ? " · Σ" + str.tostring(dashConfTotal) + (dashConfZone != "" ? " " + dashConfZone : "") : "")
    color  modelClr = trade.bias
    table.cell(main_table, 0, 5, "", bgcolor=baseBG)
    table.cell(main_table, 1, 5, "Model", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 5, modelStr, text_color=valueTxt, text_size=tblSize, bgcolor=showTrade ? color.new(modelClr, 35) : baseBG, text_halign=text.align_center)

    if showTrade
        float riskPctVal_d = riskPct == "0.5%" ? 0.005 : riskPct == "1%" ? 0.01 : riskPct == "2%" ? 0.02 : 0.03
        float riskAmount_d = accountSize * riskPctVal_d
        float riskUSD_d    = riskAmount_d * fxRate
        float slDist_d     = math.abs(trade.entry - trade.sl)
        float rPL_d = 0.0
        string lotUnit_d = "lots"
        if XAU
            rPL_d := slDist_d * 100
        else if XAG
            rPL_d := slDist_d * 5000
        else if isOil
            rPL_d := slDist_d * 1000
        else if isCrypto
            rPL_d := slDist_d * 1.0
            lotUnit_d := syminfo.basecurrency
        else if isIndex
            float idxPV = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
            rPL_d := slDist_d * idxPV
        else if FX
            bool isJPY_d = str.contains(syminfo.ticker, "JPY")
            float pipSz_d = isJPY_d ? 0.01 : 0.0001
            rPL_d := (slDist_d / pipSz_d) * 10.0
        else
            float fallbackPV = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
            rPL_d := slDist_d * fallbackPV
        float lotVal_d = rPL_d > 0 ? math.max(0.01, math.round(riskUSD_d / rPL_d, isCrypto ? 4 : 2)) : 0.01

        color tradeCellBG = color.new(trade.bias, 55)
        table.cell(main_table, 0, 6, "", bgcolor=baseBG)
        table.cell(main_table, 1, 6, "Entry",     text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 6, str.tostring(trade.entry, format.mintick), text_color=valueTxt, text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 7, "", bgcolor=baseBG)
        string slValue_d = trade.tp1hit ? "Moved To BE" : str.tostring(trade.sl, format.mintick)
        color  slCellBG  = trade.tp1hit ? color.new(#FF9100, 45) : tradeCellBG
        table.cell(main_table, 1, 7, "SL",        text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 7, slValue_d,   text_color=valueTxt, text_size=tblSize, bgcolor=slCellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 8, "", bgcolor=baseBG)
        color  tp1CellBG  = trade.tp1hit ? color.new(#00C853, 35) : tradeCellBG
        string tp1Value_d = trade.tp1hit ? "Secured" : str.tostring(trade.tp1, format.mintick)
        table.cell(main_table, 1, 8, "TP1",       text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 8, tp1Value_d,  text_color=valueTxt, text_size=tblSize, bgcolor=tp1CellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 9, "", bgcolor=baseBG)
        table.cell(main_table, 1, 9, "TP2",       text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 9, str.tostring(trade.tp2, format.mintick), text_color=valueTxt, text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 10, "", bgcolor=baseBG)
        table.cell(main_table, 1, 10, "Lots",     text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 10, str.tostring(lotVal_d, isCrypto ? "#.####" : "#.##") + " " + lotUnit_d, text_color=color.new(#00E5FF, 0), text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
    else if showStats and stats_total > 0
        // Performance stats occupy rows 6-10 when no trade is active.
        // Colors key to outcome: green for positive expectancy/PF>1, red otherwise.
        color statsPosBG = color.new(#00C853, 70)
        color statsNegBG = color.new(#FF1744, 70)
        color statsNeuBG = color.new(#5A5A8F, 70)

        // Row 6 — Total trades (scope-aware)
        string scopeTag = statsScope == "Today" ? " (Today)" : ""
        table.cell(main_table, 0, 6, "", bgcolor=baseBG)
        table.cell(main_table, 1, 6, "Trades" + scopeTag, text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 6, str.tostring(stats_total), text_color=valueTxt, text_size=tblSize, bgcolor=statsNeuBG, text_halign=text.align_center)

        // Row 7 — Win rate (W+1:1 as "closes at profit or BE+")
        color wrBG = stats_winRate >= 50 ? statsPosBG : statsNegBG
        string wrText = na(stats_winRate) ? "—" : str.tostring(stats_winRate, "#.0") + "%"
        table.cell(main_table, 0, 7, "", bgcolor=baseBG)
        table.cell(main_table, 1, 7, "Win Rate", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 7, wrText, text_color=valueTxt, text_size=tblSize, bgcolor=wrBG, text_halign=text.align_center)

        // Row 8 — Expectancy in R
        color exBG = stats_expectancy > 0 ? statsPosBG : stats_expectancy < 0 ? statsNegBG : statsNeuBG
        string exText = na(stats_expectancy) ? "—" : (stats_expectancy >= 0 ? "+" : "") + str.tostring(stats_expectancy, "#.##") + "R"
        table.cell(main_table, 0, 8, "", bgcolor=baseBG)
        table.cell(main_table, 1, 8, "Expectancy", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 8, exText, text_color=valueTxt, text_size=tblSize, bgcolor=exBG, text_halign=text.align_center)

        // Row 9 — Profit factor
        color pfBG = na(stats_pf) ? statsNeuBG : stats_pf >= 1.5 ? statsPosBG : stats_pf >= 1.0 ? statsNeuBG : statsNegBG
        string pfText = na(stats_pf) ? "—" : stats_pf >= 999 ? "∞" : str.tostring(stats_pf, "#.##")
        table.cell(main_table, 0, 9, "", bgcolor=baseBG)
        table.cell(main_table, 1, 9, "Profit Factor", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 9, pfText, text_color=valueTxt, text_size=tblSize, bgcolor=pfBG, text_halign=text.align_center)

        // Row 10 — Current streak with W/L prefix
        color stBG = stats_streakSign > 0 ? statsPosBG : stats_streakSign < 0 ? statsNegBG : statsNeuBG
        string stText = stats_streak == 0 ? "—" : (stats_streakSign > 0 ? "W" : "L") + str.tostring(stats_streak)
        table.cell(main_table, 0, 10, "", bgcolor=baseBG)
        table.cell(main_table, 1, 10, "Streak", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 10, stText, text_color=valueTxt, text_size=tblSize, bgcolor=stBG, text_halign=text.align_center)
    else
        // No active trade and no stats to show — blank rows 6-10 (Model row 5 stays)
        table.clear(main_table, 0, 6, 2, 10)

// ─────────────────────────────────────────────────────────────────────────────
// §19  END
// ─────────────────────────────────────────────────────────────────────────────
