//@version=6
indicator("DTG V8.1", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500, dynamic_requests=true)

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  DTG DZ STRATEGY — Tidied & Enhanced                                     ║
// ║  Core logic preserved · Modern dashboard · Multi-TF bias · Auto-discount ║
// ║  3-Step System: Bias → Zone Touch → Signal                               ║
// ╚═══════════════════════════════════════════════════════════════════════════╝


// ─────────────────────────────────────────────────────────────────────────────
// §1  INPUTS
// ─────────────────────────────────────────────────────────────────────────────

// ── SIGNALS ──
grpSig        = "Signals"
showLabel     = input.string("Buy / Sell", "Signal Style", options=["Buy / Sell", "Symbol", "Off"], inline="S1", group=grpSig)
showMax       = input.int(1, "Signals on Chart", minval=1, maxval=500, inline="S1", group=grpSig)
enableEM1     = input.bool(true, "EM1 — Pattern Entry", group=grpSig, tooltip="Original 3-candle pattern signal")
buy_c         = input.color(color.new(#056656, 0), "Buy",  inline="S2", group=grpSig)
sell_c        = input.color(color.new(#b22833, 0), "Sell", inline="S2", group=grpSig)
txt_c         = input.color(color.new(color.white, 0), "Text", inline="S2", group=grpSig)
inputSpread   = input.int(3, "Spread Buffer", minval=0, maxval=20, group=grpSig, tooltip="Spread pips added to entry and SL buffer")

// ── VISUALS ──
grpVis        = "Visuals"
showTable     = input.bool(true, "Dashboard", inline="V1", group=grpVis)
dashSize      = input.string("normal", "Size", options=["tiny","small","normal","large"], inline="V1", group=grpVis)
showRR        = input.bool(true, "RR Boxes on Chart", group=grpVis, tooltip="Show Entry/SL/TP1/TP2 boxes during active trades")
showHistory   = input.bool(true, "Show Last Trade", group=grpVis, tooltip="Keep the last completed trade visible on chart with W/BE/L label")
tradingWindow = input.bool(true, "Trading Window Background", inline="V2", group=grpVis)
TW_color      = input.color(color.new(color.gray, 85), "", inline="V2", group=grpVis)
enableFib     = input.bool(true, "Discount Zones", group=grpVis)
autoDiscount  = input.bool(true, "Auto-Escalate Zones", group=grpVis, tooltip="Automatically selects the best discount zone across 4H→6H→8H→12H→D→W. Turn off to use manual Base Timeframe.")
base_tf       = input.timeframe("240", "Manual Zone TF", options=["60","120","180","240","360","480","600","720","D","W","M"], group=grpVis, tooltip="Only used when Auto-Escalate is OFF")
bull_fill     = input.color(color.new(color.green, 80), "Bull Fill",  inline="V3", group=grpVis)
bear_fill     = input.color(color.new(color.red, 80),   "Bear Fill",  inline="V3", group=grpVis)
bull_border   = input.color(color.green, "Bull Border", inline="V4", group=grpVis)
bear_border   = input.color(color.red,   "Bear Border", inline="V4", group=grpVis)
line_width    = input.int(1, "Zone Mid Line", minval=1, maxval=6, inline="V5", group=grpVis)

// ── RISK ──
grpRisk       = "Risk Management"
accountSize   = input.float(10000, "Account Size", minval=100, step=500, group=grpRisk)
acctCurrency  = input.string("USD", "Account Currency", options=["USD", "AUD", "EUR", "GBP"], group=grpRisk, tooltip="Select your account currency. Lot sizes auto-adjust using live exchange rates.")
riskPct       = input.string("1%", "Risk Per Trade", options=["0.5%", "1%", "2%", "3%"], group=grpRisk)

// ── SYSTEM RULES ──
grpSystem       = "System Rules"
excludeNonTW    = input.bool(true, "Signals During Window Only", group=grpSystem, tooltip="Only fire entry signals during the trading window (H4 candles 3-5)")
windowTapsOnly  = input.bool(true, "Zone Taps During Window Only", group=grpSystem, tooltip="Step 2 zone touch only counts during the trading window. Off = taps count any time.")
oneTradePerDay  = input.bool(true, "One Trade Per Day", group=grpSystem, tooltip="After a winning trade (TP2 hit), no more signals for the day. SL/BE trades allow retries.")
requireZoneTap  = input.bool(true, "Require Zone Tap for Signal", group=grpSystem, tooltip="Enforce Step 2: signals only fire after a discount zone has been tapped. Turn off to allow signals without a zone tap.")


// ─────────────────────────────────────────────────────────────────────────────
// §4  UTILITY FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────

f_DTG_algo(_lname, _lbar, _lval, _lpos, _lcol, _lstyle, _ltext, _ltextc, _lsize) =>
    array.push(_lname, label.new(x=_lbar, y=_lval, yloc=_lpos, color=_lcol, style=_lstyle, text=_ltext, textcolor=_ltextc, size=_lsize))

f_LABEL_truncate(_ArrayL, _NumToKeepL) =>
    if array.size(_ArrayL) >= _NumToKeepL + 1
        label.delete(array.shift(_ArrayL))

BiasV(v1)      => v1 > 0 ? 1 : v1 < 0 ? -1 : 0
BiasC(c1)      => c1 > 0 ? buy_c : c1 < 0 ? sell_c : color.yellow


// ─────────────────────────────────────────────────────────────────────────────
// §6  H4 COUNTER & FILTER FLAGS
// ─────────────────────────────────────────────────────────────────────────────

var int H4_counter = 0
if timeframe.change("D")
    H4_counter := 1
if timeframe.change("240") and not timeframe.change("D")
    H4_counter := nz(H4_counter) + 1

int  TmF            = timeframe.multiplier
bool intradayFilter = timeframe.isintraday and TmF <= 240
bool mergedTW       = intradayFilter and (H4_counter >= 3 and H4_counter <= 5)
bool XAU            = str.contains(str.upper(syminfo.ticker), "XAU")
bool XAG            = str.contains(str.upper(syminfo.ticker), "XAG")
bool FX             = syminfo.type == "forex"
bool isCrypto       = syminfo.type == "crypto"
bool isIndex        = str.contains(syminfo.ticker, "US30") or str.contains(syminfo.ticker, "NAS100") or str.contains(syminfo.ticker, "SPX500") or str.contains(syminfo.ticker, "US500") or str.contains(syminfo.ticker, "DE40") or str.contains(syminfo.ticker, "UK100") or str.contains(syminfo.ticker, "JP225") or str.contains(syminfo.ticker, "AUS200")
bool isOil          = str.contains(syminfo.ticker, "USOIL") or str.contains(syminfo.ticker, "UKOIL") or str.contains(syminfo.ticker, "WTI") or str.contains(syminfo.ticker, "BRENT") or str.contains(syminfo.ticker, "CL") or str.contains(syminfo.ticker, "BCO")
bool XAU_XAG        = XAU or XAG
bool assetsFilter   = true
bool intradayTF     = timeframe.isintraday and (not XAU_XAG ? TmF >= 15 : true)
bool buLTF_XAU_XAG  = XAU_XAG and TmF < 15
bool beLTF_XAU_XAG  = XAU_XAG and TmF < 15

bgcolor(tradingWindow and mergedTW ? TW_color : na)


// ─────────────────────────────────────────────────────────────────────────────
// §7  EMA & MARKET DATA
// ─────────────────────────────────────────────────────────────────────────────

ema8       = ta.ema(close, 8)
ema20      = ta.ema(close, 20)
trend_avg  = (ema8 + ema20) / 2
pct_change = 100 * (ema8 - ema20) / trend_avg

spread_tick = syminfo.mintick * (XAU ? 100 : (XAG ? 1000 : (FX ? 10 : 0)))
digits      = int(math.log10(1 / syminfo.mintick) - 1)
TF_num      = timeframe.isintraday ? (TmF < 60 ? TmF : math.round(TmF / 60, 0)) : TmF
TF_HRmn     = timeframe.isintraday ? (TmF < 60 ? "minute timeframe." : "hour timeframe.") : "minute timeframe."
TF_txt      = str.tostring(TF_num, "") + " " + TF_HRmn


// ─────────────────────────────────────────────────────────────────────────────
// §8  TRADE STATE (persistent vars)
// ─────────────────────────────────────────────────────────────────────────────

var int    trade_Bar        = na
var int    trade_TriggerBar = na
var int    trade_Time       = na
var string trade_Status     = na
var float  trade_Entry      = na
var float  trade_SL         = na
var float  trade_TP1        = na
var float  trade_TP2        = na
var color  trade_Bias       = na
var string trade_Model      = na
var bool   trade_TP1hit     = false

// Snapshot of the discount zone at signal time — persists for trade lifetime
var float  tradeZone_ZT    = na
var float  tradeZone_ZB    = na
var int    tradeZone_Open  = na
var int    tradeZone_Close = na
var string tradeZone_TF    = na
var int    tradeZone_Bias  = 0

// ── 3-STEP SYSTEM STATE ──
var bool stepTwoMet        = false
var int  stepTwoBias       = 0
var bool dailyProfitTaken  = false

// ── LAST TRADE HISTORY (single completed trade) ──
var int   last_bar      = na
var int   last_exitBar  = na
var int   last_time     = na
var int   last_exitTime = na
var float last_entry    = na
var float last_sl       = na
var float last_tp1      = na
var float last_tp2      = na
var int   last_dir      = 0
var int   last_outcome  = 0
var bool  last_valid    = false

// ── BACKGROUND TRADE MONITOR ──
var float bg_entry  = na
var float bg_sl     = na
var float bg_tp1    = na
var float bg_tp2    = na
var int   bg_bar    = na
var int   bg_time   = na
var int   bg_dir    = 0
var bool  bg_active = false
var bool  bg_tp1hit = false

// Dashboard sticky flags — declared early so EM1 gate (§10) can read them
var bool dashStk_4h  = false
var bool dashStk_6h  = false
var bool dashStk_8h  = false
var bool dashStk_12h = false
var bool dashStk_D   = false
var bool dashStk_W   = false

bool buySignal  = false
bool sellSignal = false

// Daily reset — full system reset at start of each new day.
// If a Triggered trade is still live, move it to background monitoring so it can
// still complete (TP2/SL) across day boundaries. Main system resets freely.
if timeframe.change("D")
    if trade_Status == "Triggered" and not na(trade_Entry)
        bg_entry  := trade_Entry
        bg_sl     := trade_SL
        bg_tp1    := trade_TP1
        bg_tp2    := trade_TP2
        bg_bar    := trade_Bar
        bg_time   := trade_Time
        bg_dir    := trade_Bias == buy_c ? 1 : -1
        bg_tp1hit := trade_TP1hit
        bg_active := true
    stepTwoMet       := false
    stepTwoBias      := 0
    dailyProfitTaken := false
    trade_Status     := "Scanning"
    trade_Bar        := na
    trade_TriggerBar := na
    trade_Time       := na
    trade_Entry      := na
    trade_SL         := na
    trade_TP1        := na
    trade_TP2        := na
    trade_Bias       := na
    trade_Model      := na
    trade_TP1hit     := false
    tradeZone_ZT     := na
    tradeZone_ZB     := na
    tradeZone_Open   := na
    tradeZone_Close  := na
    tradeZone_TF     := na
    tradeZone_Bias   := 0

// ── BACKGROUND TRADE MONITOR ──
// Tracks old Triggered trades that survived the daily reset. Runs every bar.
// When TP2 or SL is hit, captures to history and clears. Does NOT block new signals.
// Outcomes: +1 = Win (TP2), 0 = 1:1 Secured (TP1 hit, then back to entry), -1 = Loss
if bg_active
    bool bg_isBuy     = bg_dir == 1
    bool bg_wasTP1hit = bg_tp1hit
    bool bg_checkTP1  = (bg_isBuy and high > bg_tp1) or (not bg_isBuy and low < bg_tp1)
    if bg_checkTP1
        bg_tp1hit := true
    bool bg_hitTP2 = (bg_isBuy and high > bg_tp2) or (not bg_isBuy and low < bg_tp2)
    bool bg_hitSL  = not bg_wasTP1hit and ((bg_isBuy and low < bg_sl) or (not bg_isBuy and high > bg_sl))
    bool bg_hitBE  = bg_wasTP1hit and ((bg_isBuy and low < bg_entry) or (not bg_isBuy and high > bg_entry))
    if bg_hitTP2 or bg_hitBE or bg_hitSL
        if showHistory
            last_bar := bg_bar, last_exitBar := bar_index
            last_time := bg_time, last_exitTime := time
            last_entry := bg_entry, last_sl := bg_sl
            last_tp1 := bg_tp1, last_tp2 := bg_tp2
            last_dir := bg_dir
            last_outcome := bg_hitTP2 ? 1 : bg_hitBE ? 0 : -1
            last_valid := true
        bg_active := false
        bg_tp1hit := false


// ─────────────────────────────────────────────────────────────────────────────
// §8b  MULTI-TF DATA — Consolidated
// ─────────────────────────────────────────────────────────────────────────────

[open_4h, close_4h, high_4h, low_4h]     = request.security(syminfo.tickerid, "240", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_6h, close_6h, high_6h, low_6h]     = request.security(syminfo.tickerid, "360", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_8h, close_8h, high_8h, low_8h]     = request.security(syminfo.tickerid, "480", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_12h, close_12h, high_12h, low_12h] = request.security(syminfo.tickerid, "720", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_Db, close_Db, high_Db, low_Db]     = request.security(syminfo.tickerid, "D",   [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_Wb, close_Wb, high_Wb, low_Wb]     = request.security(syminfo.tickerid, "W",   [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)

f_tf_bias(c, o) => c > o ? 1 : c < o ? -1 : 0

bias_4h  = f_tf_bias(close_4h, open_4h)
bias_6h  = f_tf_bias(close_6h, open_6h)
bias_8h  = f_tf_bias(close_8h, open_8h)
bias_12h = f_tf_bias(close_12h, open_12h)
bias_D   = f_tf_bias(close_Db, open_Db)
bias_W   = f_tf_bias(close_Wb, open_Wb)

sum_bias   = bias_4h + bias_6h + bias_8h + bias_12h + bias_D + bias_W
biasLabel  = sum_bias >= 2 ? "Bullish" : sum_bias <= -2 ? "Bearish" : "Neutral"
biasColor  = sum_bias >= 2 ? color.new(color.green, 0) : sum_bias <= -2 ? color.new(color.red, 0) : color.new(color.yellow, 0)

int overallBias = sum_bias >= 2 ? 1 : sum_bias <= -2 ? -1 : 0

color H4_c = BiasC(close_4h - open_4h)
int   mult = BiasV(close_4h - open_4h)

// ── EXCHANGE RATE (single conditional call) ──
// Only one of the three rates is needed at any time — fetch the one that matches
// the selected account currency. Saves 2 request.security calls vs V8.1.
string fxSym   = acctCurrency == "AUD" ? "FX:AUDUSD" : acctCurrency == "GBP" ? "FX:GBPUSD" : "FX:EURUSD"
float  fxClose = request.security(fxSym, "D", close, barmerge.gaps_off, barmerge.lookahead_on)
float  fxRate  = acctCurrency == "AUD" ? nz(fxClose, 0.65) : acctCurrency == "EUR" ? nz(fxClose, 1.08) : acctCurrency == "GBP" ? nz(fxClose, 1.27) : 1.0


// ─────────────────────────────────────────────────────────────────────────────
// §9  BUY / SELL CONDITIONS (EM1 — with bias direction filter)
// ─────────────────────────────────────────────────────────────────────────────

buyC1  = close[3] < open[3]
buyC2  = close[2] > open[2]
buyC3  = close[1] > open[1]
buyC4a = high[1] > high[2]
buyC4b = low[1] > low[2]
buySignal := buyC1 and buyC2 and buyC3 and buyC4a and buyC4b and (pct_change > 0.006) and (excludeNonTW ? mergedTW : true) and assetsFilter and intradayTF and (buLTF_XAU_XAG ? mult >= 0 : true) and overallBias == 1

sellC1  = close[3] > open[3]
sellC2  = close[2] < open[2]
sellC3  = close[1] < open[1]
sellC4a = low[1] < low[2]
sellC4b = high[1] < high[2]
sellSignal := sellC1 and sellC2 and sellC3 and sellC4a and sellC4b and (pct_change < -0.006) and (excludeNonTW ? mergedTW : true) and assetsFilter and intradayTF and (beLTF_XAU_XAG ? mult <= 0 : true) and overallBias == -1


// ─────────────────────────────────────────────────────────────────────────────
// §10  SIGNAL LABELS & TRADE ENTRY
// ─────────────────────────────────────────────────────────────────────────────

var DTG_Signal = array.new_label()
label_size = showLabel == "Symbol" ? size.auto : size.tiny
buy_style  = showLabel == "Symbol" ? label.style_triangleup   : label.style_label_up
sell_style = showLabel == "Symbol" ? label.style_triangledown : label.style_label_down
em1_text   = showLabel == "Symbol" ? "" : "EM1"

// ── 3-STEP SYSTEM GATE (EM1) ──
bool em1_hasTouchedZones = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D or dashStk_W
bool em1_stepTwoValid = requireZoneTap ? (stepTwoMet and stepTwoBias == overallBias and overallBias != 0 and em1_hasTouchedZones) : (overallBias != 0)
bool em1_systemReady  = em1_stepTwoValid and (not oneTradePerDay or not dailyProfitTaken)
bool em1_allowed      = trade_Status != "Triggered" and em1_systemReady

bool validBuy  = buySignal and enableEM1 and em1_allowed and showLabel != "Off"
bool validSell = sellSignal and enableEM1 and em1_allowed and showLabel != "Off"

// Raw pattern signals (no system gate) — for alertcondition
bool rawBuy  = buySignal and enableEM1 and trade_Status != "Triggered" and overallBias == 1
bool rawSell = sellSignal and enableEM1 and trade_Status != "Triggered" and overallBias == -1

if validBuy
    trade_Bar        := bar_index
    trade_TriggerBar := na
    trade_Time       := time
    trade_Status     := "Active"
    trade_Entry      := math.round(high[1] + inputSpread * spread_tick, digits)
    trade_SL         := math.round(low[1] - 3 * spread_tick, digits)
    trade_TP1        := math.round(2 * trade_Entry - trade_SL, digits)
    trade_TP2        := math.round(3 * trade_Entry - 2 * trade_SL, digits)
    trade_Bias       := buy_c
    trade_Model      := "EM1"
    trade_TP1hit     := false
    f_DTG_algo(DTG_Signal, bar_index, low, yloc.belowbar, buy_c, buy_style, em1_text, txt_c, label_size)
    alert("EM1 buy setup on the " + TF_txt + " Consult data table before proceeding.", alert.freq_once_per_bar)

if validSell
    trade_Bar        := bar_index
    trade_TriggerBar := na
    trade_Time       := time
    trade_Status     := "Active"
    trade_Entry      := math.round(low[1] - inputSpread * spread_tick, digits)
    trade_SL          := math.round(high[1] + 3 * spread_tick, digits)
    trade_TP1        := math.round(2 * trade_Entry - trade_SL, digits)
    trade_TP2        := math.round(3 * trade_Entry - 2 * trade_SL, digits)
    trade_Bias       := sell_c
    trade_Model      := "EM1"
    trade_TP1hit     := false
    f_DTG_algo(DTG_Signal, bar_index, high, yloc.abovebar, sell_c, sell_style, em1_text, txt_c, label_size)
    alert("EM1 sell setup on the " + TF_txt + " Consult data table before proceeding.", alert.freq_once_per_bar)

f_LABEL_truncate(DTG_Signal, showMax)

alertcondition(validBuy or validSell,  title="System Signal",  message="DTG V8: Valid SYSTEM signal. Check dashboard for trade details.")
alertcondition(rawBuy or rawSell,      title="Pattern Signal", message="DTG V8: EM1 pattern detected (system rules not applied).")


// ─────────────────────────────────────────────────────────────────────────────
// §12  TRADE STATUS MACHINE
// ─────────────────────────────────────────────────────────────────────────────

if trade_Status == "Active" and (bar_index - nz(trade_Bar)) == 0
    if trade_Bias == sell_c and low < trade_Entry
        trade_Status     := "Triggered"
        trade_TriggerBar := bar_index
    else if trade_Bias == buy_c and high > trade_Entry
        trade_Status     := "Triggered"
        trade_TriggerBar := bar_index
    else
        trade_Status := "Active"

if trade_Status == "Active" and (bar_index - nz(trade_Bar)) == 1
    trade_Status := "Invalid"

if trade_Status == "Invalid"
    if bar_index - nz(trade_Bar) > 1
        trade_Status := "Scanning"

// Triggered = live trade. Only exits on TP2, SL, or BE (entry) hit.
// V8.1 FIX #1: wasTP1hit snapshot prevents same-bar TP1+BE race.
// V8.1 FIX #2: gate with bar_index > trade_TriggerBar — skip the trigger bar
//              so a pre-trigger wick through SL isn't counted as a loss.
if trade_Status == "Triggered" and bar_index > nz(trade_TriggerBar)
    bool wasTP1hit = trade_TP1hit
    bool checkTP1  = (trade_Bias == buy_c and high > trade_TP1) or (trade_Bias == sell_c and low < trade_TP1)
    if checkTP1
        trade_TP1hit := true
    bool hitTP2 = (trade_Bias == sell_c and low < trade_TP2) or (trade_Bias == buy_c and high > trade_TP2)
    bool hitSL  = not wasTP1hit and ((trade_Bias == sell_c and high > trade_SL) or (trade_Bias == buy_c and low < trade_SL))
    bool hitBE  = wasTP1hit and ((trade_Bias == buy_c and low < trade_Entry) or (trade_Bias == sell_c and high > trade_Entry))
    if hitTP2 or hitBE or hitSL
        if hitTP2
            dailyProfitTaken := true
        if showHistory
            last_bar := trade_Bar, last_exitBar := bar_index
            last_time := trade_Time, last_exitTime := time
            last_entry := trade_Entry, last_sl := trade_SL
            last_tp1 := trade_TP1, last_tp2 := trade_TP2
            last_dir := trade_Bias == buy_c ? 1 : -1
            last_outcome := hitTP2 ? 1 : hitBE ? 0 : -1
            last_valid := true
        trade_Status := "Scanning"
        trade_TP1hit := false

if na(trade_Status)
    trade_Status := "None"

noSignal_Bias = (trade_Status == "Scanning" or trade_Status == "None") ? H4_c : trade_Bias


// ─────────────────────────────────────────────────────────────────────────────
// §13  AUTO-ESCALATING DISCOUNT ZONES
// ─────────────────────────────────────────────────────────────────────────────

// Fib 50%-75% zone based on each TF's own candle direction
f_discountZone(float lo, float hi, int candleBias) =>
    float rng = hi - lo
    float zt = na
    float zb = na
    if candleBias == 1
        zt := hi - 0.5  * rng
        zb := hi - 0.75 * rng
    else if candleBias == -1
        zb := lo + 0.5  * rng
        zt := lo + 0.75 * rng
    [zt, zb]

[zt_4h,  zb_4h]  = f_discountZone(low_4h,  high_4h,  bias_4h)
[zt_6h,  zb_6h]  = f_discountZone(low_6h,  high_6h,  bias_6h)
[zt_8h,  zb_8h]  = f_discountZone(low_8h,  high_8h,  bias_8h)
[zt_12h, zb_12h] = f_discountZone(low_12h, high_12h, bias_12h)
[zt_Db,  zb_Db]  = f_discountZone(low_Db,  high_Db,  bias_D)
[zt_Wb,  zb_Wb]  = f_discountZone(low_Wb,  high_Wb,  bias_W)

// Invalidation uses chart timeframe automatically
f_zoneInvalid(float zt, float zb, int candleBias) =>
    bool inv = false
    if candleBias == 1 and not na(zb)
        float lower = math.min(zt, zb)
        inv := close[2] < lower and close[1] < lower
    else if candleBias == -1 and not na(zt)
        float upper = math.max(zt, zb)
        inv := close[2] > upper and close[1] > upper
    inv

// Native HTF timing — replaces 6 request.security() calls in V8.1.
// time(tf) returns the current HTF candle open time; time_close(tf) its close.
// timeframe.change(tf) detects rollover. Same values, zero security cost.
int time_now_4h  = time("240")
int time_now_6h  = time("360")
int time_now_8h  = time("480")
int time_now_12h = time("720")
int time_now_D   = time("D")
int time_now_W   = time("W")

bool new_4h  = timeframe.change("240")
bool new_6h  = timeframe.change("360")
bool new_8h  = timeframe.change("480")
bool new_12h = timeframe.change("720")
bool new_D   = timeframe.change("D")
bool new_W   = timeframe.change("W")

var bool locked_4h  = false
var bool locked_6h  = false
var bool locked_8h  = false
var bool locked_12h = false
var bool locked_D   = false
var bool locked_W   = false

bool newZone_4h  = ta.change(zt_4h)  != 0 or ta.change(zb_4h)  != 0
bool newZone_6h  = ta.change(zt_6h)  != 0 or ta.change(zb_6h)  != 0
bool newZone_8h  = ta.change(zt_8h)  != 0 or ta.change(zb_8h)  != 0
bool newZone_12h = ta.change(zt_12h) != 0 or ta.change(zb_12h) != 0
bool newZone_D   = ta.change(zt_Db)  != 0 or ta.change(zb_Db)  != 0
bool newZone_W   = ta.change(zt_Wb)  != 0 or ta.change(zb_Wb)  != 0

if newZone_4h
    locked_4h := false
    dashStk_4h := false
if newZone_6h
    locked_6h := false
    dashStk_6h := false
if newZone_8h
    locked_8h := false
    dashStk_8h := false
if newZone_12h
    locked_12h := false
    dashStk_12h := false
if newZone_D
    locked_D := false
    dashStk_D := false
if newZone_W
    locked_W := false
    dashStk_W := false

if f_zoneInvalid(zt_4h, zb_4h, bias_4h)
    locked_4h := true
    dashStk_4h := false
if f_zoneInvalid(zt_6h, zb_6h, bias_6h)
    locked_6h := true
    dashStk_6h := false
if f_zoneInvalid(zt_8h, zb_8h, bias_8h)
    locked_8h := true
    dashStk_8h := false
if f_zoneInvalid(zt_12h, zb_12h, bias_12h)
    locked_12h := true
    dashStk_12h := false
if f_zoneInvalid(zt_Db, zb_Db, bias_D)
    locked_D := true
    dashStk_D := false
if f_zoneInvalid(zt_Wb, zb_Wb, bias_W)
    locked_W := true
    dashStk_W := false

f_matches(int candleBias, int ovBias) => ovBias != 0 and candleBias == ovBias

m_4h  = f_matches(bias_4h,  overallBias) and not locked_4h
m_6h  = f_matches(bias_6h,  overallBias) and not locked_6h
m_8h  = f_matches(bias_8h,  overallBias) and not locked_8h
m_12h = f_matches(bias_12h, overallBias) and not locked_12h
m_D   = f_matches(bias_D,   overallBias) and not locked_D
m_W   = f_matches(bias_W,   overallBias) and not locked_W

f_getZT(int z) => z == 1 ? zt_4h : z == 2 ? zt_6h : z == 3 ? zt_8h : z == 4 ? zt_12h : z == 5 ? zt_Db : z == 6 ? zt_Wb : na
f_getZB(int z) => z == 1 ? zb_4h : z == 2 ? zb_6h : z == 3 ? zb_8h : z == 4 ? zb_12h : z == 5 ? zb_Db : z == 6 ? zb_Wb : na

f_touching(float zt, float zb) =>
    not na(zt) and not na(zb) and low <= math.max(zt, zb) and high >= math.min(zt, zb)

bool touch_4h  = m_4h  and f_touching(zt_4h,  zb_4h)
bool touch_6h  = m_6h  and f_touching(zt_6h,  zb_6h)
bool touch_8h  = m_8h  and f_touching(zt_8h,  zb_8h)
bool touch_12h = m_12h and f_touching(zt_12h, zb_12h)
bool touch_D   = m_D   and f_touching(zt_Db,  zb_Db)
bool touch_W   = m_W   and f_touching(zt_Wb,  zb_Wb)

int touchCount = (touch_4h ? 1 : 0) + (touch_6h ? 1 : 0) + (touch_8h ? 1 : 0) + (touch_12h ? 1 : 0) + (touch_D ? 1 : 0) + (touch_W ? 1 : 0)

// ── STICKY TOUCH FLAGS (dashboard) ──
if touch_4h
    dashStk_4h := true
if touch_6h
    dashStk_6h := true
if touch_8h
    dashStk_8h := true
if touch_12h
    dashStk_12h := true
if touch_D
    dashStk_D := true
if touch_W
    dashStk_W := true

if not m_4h
    dashStk_4h := false
if not m_6h
    dashStk_6h := false
if not m_8h
    dashStk_8h := false
if not m_12h
    dashStk_12h := false
if not m_D
    dashStk_D := false
if not m_W
    dashStk_W := false

// ── 3-STEP SYSTEM: STEP 2 — Zone Touch Tracking ──
bool tapInWindow = windowTapsOnly ? mergedTW : true
if touchCount > 0 and overallBias != 0 and tapInWindow
    stepTwoMet  := true
    stepTwoBias := overallBias

bool anyDashTouched = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D or dashStk_W
if stepTwoMet and not anyDashTouched
    stepTwoMet  := false
    stepTwoBias := 0

bool stepTwoValid = stepTwoMet and stepTwoBias == overallBias and overallBias != 0

// Active zone selection
int activeZone = anyDashTouched ? (dashStk_4h ? 1 : dashStk_6h ? 2 : dashStk_8h ? 3 : dashStk_12h ? 4 : dashStk_D ? 5 : dashStk_W ? 6 : 0) : (m_4h ? 1 : m_6h ? 2 : m_8h ? 3 : m_12h ? 4 : m_D ? 5 : m_W ? 6 : 0)
float activeZT = f_getZT(activeZone)
float activeZB = f_getZB(activeZone)

string activeZoneStr = activeZone == 1 ? "4H" : activeZone == 2 ? "6H" : activeZone == 3 ? "8H" : activeZone == 4 ? "12H" : activeZone == 5 ? "Daily" : activeZone == 6 ? "Weekly" : "None"

int ms_4h  = 240  * 60 * 1000
int ms_6h  = 360  * 60 * 1000
int ms_8h  = 480  * 60 * 1000
int ms_12h = 720  * 60 * 1000
int ms_D   = 1440 * 60 * 1000
int ms_W   = 7 * 1440 * 60 * 1000

int activeOpenTime  = activeZone == 1 ? time_now_4h : activeZone == 2 ? time_now_6h : activeZone == 3 ? time_now_8h : activeZone == 4 ? time_now_12h : activeZone == 5 ? time_now_D : activeZone == 6 ? time_now_W : na
int activeMS        = activeZone == 1 ? ms_4h : activeZone == 2 ? ms_6h : activeZone == 3 ? ms_8h : activeZone == 4 ? ms_12h : activeZone == 5 ? ms_D : activeZone == 6 ? ms_W : 0
int activeCloseTime = not na(activeOpenTime) ? activeOpenTime + activeMS : na

// Shared predicate — trade is "frozen-zone" live iff a live trade exists AND risk
// is still on the line (TP1 not yet secured). Used by both §13 and §16.
bool tradeFrozen = (trade_Status == "Active" or trade_Status == "Triggered") and not na(tradeZone_ZT) and not trade_TP1hit

// ── SINGLE DISCOUNT BOX: shows as soon as zone is valid ──
autoZoneClr    = overallBias == 1 ? bull_fill : overallBias == -1 ? bear_fill : color.new(color.yellow, 80)
autoZoneBorder = overallBias == 1 ? bull_border : overallBias == -1 ? bear_border : color.yellow
autoMidClr     = overallBias == 1 ? color.new(color.green, 30) : overallBias == -1 ? color.new(color.red, 30) : color.new(color.yellow, 30)

var box  autoBox = na
var label autoLbl = na
var line  autoMid = na

if barstate.islast and autoDiscount
    box.delete(autoBox)
    label.delete(autoLbl)
    line.delete(autoMid)
    if activeZone != 0 and not na(activeZT) and not na(activeZB) and not na(activeOpenTime) and not tradeFrozen
        autoBox := box.new(activeOpenTime, activeZT, activeCloseTime, activeZB, xloc=xloc.bar_time, border_color=autoZoneBorder, bgcolor=autoZoneClr, border_width=1, border_style=line.style_dashed)
        autoLbl := label.new(activeCloseTime, math.avg(activeZT, activeZB), activeZoneStr + " Discount", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=autoZoneBorder, style=label.style_label_left, size=size.small)
        float midPrice = math.avg(activeZT, activeZB)
        autoMid := line.new(activeOpenTime, midPrice, activeCloseTime, midPrice, xloc=xloc.bar_time, color=autoMidClr, width=2, style=line.style_solid)


// ─────────────────────────────────────────────────────────────────────────────
// §14  DISCOUNT ZONE TOUCH SUMMARY (dashboard string)
// ─────────────────────────────────────────────────────────────────────────────

string touchZonesStr = ""
if dashStk_4h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "4H"
if dashStk_6h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "6H"
if dashStk_8h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "8H"
if dashStk_12h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "12H"
if dashStk_D
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "D"
if dashStk_W
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "W"
if touchZonesStr == ""
    touchZonesStr := "None"


// ─────────────────────────────────────────────────────────────────────────────
// §15  TRADE ZONE SNAPSHOT
// ─────────────────────────────────────────────────────────────────────────────

if (trade_Status == "Active" or trade_Status == "Triggered") and trade_Bar == bar_index and activeZone != 0
    tradeZone_ZT    := activeZT
    tradeZone_ZB    := activeZB
    tradeZone_Open  := activeOpenTime
    tradeZone_Close := activeCloseTime
    tradeZone_TF    := activeZoneStr
    tradeZone_Bias  := overallBias

if trade_Status == "Scanning" or trade_Status == "None"
    tradeZone_ZT    := na
    tradeZone_ZB    := na
    tradeZone_Open  := na
    tradeZone_Close := na
    tradeZone_TF    := na
    tradeZone_Bias  := 0


// ─────────────────────────────────────────────────────────────────────────────
// §16  FIXED R:R BOXES + TRADE ZONE BOX
// ─────────────────────────────────────────────────────────────────────────────

var box   rrBoxSL  = na
var box   rrBoxTP1 = na
var box   rrBoxTP2 = na
var line  rrEntry  = na
var label rrTP1lbl = na
var box   tradeZoneBox = na
var label tradeZoneLbl = na
var line  tradeZoneMid = na

bool hasActiveTrade = (trade_Status == "Active" or trade_Status == "Triggered") and not na(trade_Entry) and not na(trade_Bar)

if barstate.islast and showRR
    box.delete(rrBoxSL),  box.delete(rrBoxTP1), box.delete(rrBoxTP2)
    line.delete(rrEntry)
    label.delete(rrTP1lbl)

    if hasActiveTrade
        int rr_left  = trade_Bar
        int rr_right = bar_index + 15

        if trade_Bias == buy_c
            float sl_bottom = trade_TP1hit ? trade_Entry : trade_SL
            color sl_bg     = trade_TP1hit ? color.new(#FF9100, 92) : color.new(#FF1744, 88)
            color sl_bdr    = trade_TP1hit ? color.new(#FF9100, 60) : color.new(#FF1744, 60)
            rrBoxSL  := box.new(rr_left, trade_Entry, rr_right, sl_bottom, border_color=sl_bdr, bgcolor=sl_bg, border_width=1)
            rrBoxTP1 := box.new(rr_left, trade_TP1,   rr_right, trade_Entry, border_color=color.new(#00C853, 60), bgcolor=color.new(#00C853, 88), border_width=1)
            rrBoxTP2 := box.new(rr_left, trade_TP2,   rr_right, trade_TP1,   border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 92), border_width=1)
            rrEntry  := line.new(rr_left, trade_Entry, rr_right, trade_Entry, color=color.new(#FFFFFF, 30), style=line.style_solid, width=2)
            if trade_TP1hit
                rrTP1lbl := label.new(rr_right, trade_TP1, "1:1 ✓", color=color.new(#00C853, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

        else if trade_Bias == sell_c
            float sl_top = trade_TP1hit ? trade_Entry : trade_SL
            color sl_bg  = trade_TP1hit ? color.new(#FF9100, 92) : color.new(#FF1744, 88)
            color sl_bdr = trade_TP1hit ? color.new(#FF9100, 60) : color.new(#FF1744, 60)
            rrBoxSL  := box.new(rr_left, sl_top,      rr_right, trade_Entry, border_color=sl_bdr, bgcolor=sl_bg, border_width=1)
            rrBoxTP1 := box.new(rr_left, trade_Entry, rr_right, trade_TP1,   border_color=color.new(#00C853, 60), bgcolor=color.new(#00C853, 88), border_width=1)
            rrBoxTP2 := box.new(rr_left, trade_TP1,   rr_right, trade_TP2,   border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 92), border_width=1)
            rrEntry  := line.new(rr_left, trade_Entry, rr_right, trade_Entry, color=color.new(#FFFFFF, 30), style=line.style_solid, width=2)
            if trade_TP1hit
                rrTP1lbl := label.new(rr_right, trade_TP1, "1:1 ✓", color=color.new(#00C853, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

if barstate.islast and autoDiscount
    box.delete(tradeZoneBox)
    label.delete(tradeZoneLbl)
    line.delete(tradeZoneMid)
    if tradeFrozen and not na(tradeZone_ZB) and not na(tradeZone_Open)
        color tzFill   = tradeZone_Bias == 1 ? bull_fill : tradeZone_Bias == -1 ? bear_fill : color.new(color.yellow, 80)
        color tzBorder = tradeZone_Bias == 1 ? bull_border : tradeZone_Bias == -1 ? bear_border : color.yellow
        color tzMidClr = tradeZone_Bias == 1 ? color.new(color.green, 30) : tradeZone_Bias == -1 ? color.new(color.red, 30) : color.new(color.yellow, 30)
        string tzLabel = (na(tradeZone_TF) ? "" : tradeZone_TF) + " Discount"
        tradeZoneBox := box.new(tradeZone_Open, tradeZone_ZT, tradeZone_Close, tradeZone_ZB, xloc=xloc.bar_time, border_color=tzBorder, bgcolor=tzFill, border_width=1, border_style=line.style_solid)
        tradeZoneLbl := label.new(tradeZone_Close, math.avg(tradeZone_ZT, tradeZone_ZB), tzLabel, xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=tzBorder, style=label.style_label_left, size=size.small)
        float tzMid = math.avg(tradeZone_ZT, tradeZone_ZB)
        tradeZoneMid := line.new(tradeZone_Open, tzMid, tradeZone_Close, tzMid, xloc=xloc.bar_time, color=tzMidClr, width=2, style=line.style_solid)


// ─────────────────────────────────────────────────────────────────────────────
// §16b  TRADE HISTORY — draw completed trades on chart
// ─────────────────────────────────────────────────────────────────────────────

var box   lastBoxSL  = na
var box   lastBoxTP1 = na
var box   lastBoxTP2 = na
var line  lastEntry  = na
var label lastLbl    = na

if barstate.islast and showHistory
    box.delete(lastBoxSL), box.delete(lastBoxTP1), box.delete(lastBoxTP2)
    line.delete(lastEntry)
    label.delete(lastLbl)

    if last_valid and not na(last_time) and not na(last_exitTime)
        bool  isWin    = last_outcome == 1
        bool  isBE     = last_outcome == 0
        color slBG     = color.new(#FF1744, 92)
        color tp1BG    = color.new(#00C853, 92)
        color tp2BG    = color.new(#00E676, 94)
        int   minWidth = timeframe.in_seconds() * 1000 * 3
        int   hLeft    = last_time
        int   hRight   = math.max(last_exitTime, last_time + minWidth)

        if last_dir == 1
            lastBoxSL  := box.new(hLeft, last_entry, hRight, last_sl,    xloc=xloc.bar_time, border_color=color.new(#FF1744, 70), bgcolor=slBG,  border_width=1)
            lastBoxTP1 := box.new(hLeft, last_tp1,   hRight, last_entry, xloc=xloc.bar_time, border_color=color.new(#00C853, 70), bgcolor=tp1BG, border_width=1)
            lastBoxTP2 := box.new(hLeft, last_tp2,   hRight, last_tp1,   xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)
        else
            lastBoxSL  := box.new(hLeft, last_sl,    hRight, last_entry, xloc=xloc.bar_time, border_color=color.new(#FF1744, 70), bgcolor=slBG,  border_width=1)
            lastBoxTP1 := box.new(hLeft, last_entry, hRight, last_tp1,   xloc=xloc.bar_time, border_color=color.new(#00C853, 70), bgcolor=tp1BG, border_width=1)
            lastBoxTP2 := box.new(hLeft, last_tp1,   hRight, last_tp2,   xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)

        lastEntry := line.new(hLeft, last_entry, hRight, last_entry, xloc=xloc.bar_time, color=color.new(#FFFFFF, 60), style=line.style_dotted, width=1)

        string outTxt  = isWin ? "W" : isBE ? "1:1" : "L"
        color  outLblC = isWin ? color.new(#00C853, 20) : isBE ? color.new(#00C853, 30) : color.new(#FF1744, 20)
        int    lblTime = int(math.avg(hLeft, hRight))
        float  lblY    = last_tp2
        if last_dir == 1
            lastLbl := label.new(lblTime, lblY, outTxt, xloc=xloc.bar_time, color=outLblC, textcolor=color.white, style=label.style_label_down, size=size.tiny)
        else
            lastLbl := label.new(lblTime, lblY, outTxt, xloc=xloc.bar_time, color=outLblC, textcolor=color.white, style=label.style_label_up, size=size.tiny)


// ─────────────────────────────────────────────────────────────────────────────
// §17  ORIGINAL DISCOUNT ZONE BOX (draws when auto is off)
// ─────────────────────────────────────────────────────────────────────────────

int   extend_bars = 50
[tf_open, tf_high, tf_low, tf_close] = request.security(syminfo.tickerid, base_tf, [open[1], high[1], low[1], close[1]], barmerge.gaps_off, barmerge.lookahead_off)
int   tf_time_open = request.security(syminfo.tickerid, base_tf, time[1], barmerge.gaps_off, barmerge.lookahead_off)

int  base_ms       = timeframe.in_seconds(base_tf) * 1000
int  tf_time_close = tf_time_open + base_ms
bool new_tf        = timeframe.change(base_tf)

var box  fib_box  = na
var line fib_line = na

int right_time = tf_time_close + extend_bars * base_ms

if new_tf
    if not enableFib or autoDiscount
        if not na(fib_box)
            box.delete(fib_box)
            fib_box := na
        if not na(fib_line)
            line.delete(fib_line)
            fib_line := na
    else
        if not na(fib_box)
            box.delete(fib_box)
        if not na(fib_line)
            line.delete(fib_line)

        bool  is_bull  = tf_close > tf_open
        bool  is_bear  = tf_close < tf_open
        float tf_range = tf_high - tf_low

        float bull_p05  = tf_low + tf_range * 0.50
        float bull_p618 = tf_low + tf_range * 0.382
        float bull_p75  = tf_low + tf_range * 0.25

        float bear_p05  = tf_high - tf_range * 0.50
        float bear_p618 = tf_high - tf_range * 0.382
        float bear_p75  = tf_high - tf_range * 0.25

        float a          = na
        float b          = na
        float mid_price  = na
        color fill_col   = na
        color border_col = na

        if is_bull
            a          := bull_p05
            b          := bull_p75
            mid_price  := bull_p618
            fill_col   := bull_fill
            border_col := bull_border
        else if is_bear
            a          := bear_p05
            b          := bear_p75
            mid_price  := bear_p618
            fill_col   := bear_fill
            border_col := bear_border

        float top_price    = math.max(a, b)
        float bottom_price = math.min(a, b)

        if not na(top_price) and not na(bottom_price) and not na(mid_price)
            fib_box := box.new(left=tf_time_close, top=top_price, right=right_time, bottom=bottom_price, xloc=xloc.bar_time)
            box.set_bgcolor(fib_box, fill_col)
            box.set_border_color(fib_box, border_col)
            box.set_border_width(fib_box, 1)

            fib_line := line.new(x1=tf_time_close, y1=mid_price, x2=right_time, y2=mid_price, xloc=xloc.bar_time)
            line.set_color(fib_line, border_col)
            line.set_width(fib_line, line_width)

if barstate.islast and autoDiscount
    if not na(fib_box)
        box.delete(fib_box)
        fib_box := na
    if not na(fib_line)
        line.delete(fib_line)
        fib_line := na


// ─────────────────────────────────────────────────────────────────────────────
// §18  DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────

// ── System state string for dashboard ──
string systemStateStr = ""
color  systemStateClr = color.new(color.gray, 0)

if dailyProfitTaken and oneTradePerDay
    systemStateStr := "✓ Complete"
    systemStateClr := color.new(#00E676, 0)
else if not stepTwoValid and overallBias == 0
    systemStateStr := "No Bias"
    systemStateClr := color.new(color.yellow, 0)
else if not stepTwoValid and overallBias != 0
    systemStateStr := "Awaiting"
    systemStateClr := color.new(color.orange, 0)
else if stepTwoValid
    systemStateStr := "Ready"
    systemStateClr := color.new(#00E5FF, 0)

color step1Clr  = overallBias != 0 ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)
color step2Clr  = stepTwoValid and anyDashTouched ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)
bool  showTrade = trade_Status == "Active" or trade_Status == "Triggered"
color step3Clr  = showTrade ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)

// Dashboard build is confined to the last bar — all historical bars would
// paint identical values that are immediately overwritten, so doing it once
// on `islast` is a big runtime saver with zero visual change.
if showTable and barstate.islast
    color baseBG     = color.new(#111122, 0)
    color titleBG    = color.new(#0a0a1a, 0)
    color titleTxt   = color.new(#8899bb, 0)
    color labelTxt   = color.new(#7a7a9e, 0)
    color valueTxt   = color.new(#e8e8f0, 0)
    color dividerBG  = color.new(#1e1e38, 0)
    color frameBG    = color.new(#1e1e38, 0)
    color dotBG      = color.new(#111122, 0)

    tblSize = dashSize == "tiny" ? size.tiny : dashSize == "small" ? size.small : dashSize == "large" ? size.large : size.normal
    dotSize = dashSize == "large" ? size.normal : dashSize == "normal" ? size.small : size.tiny

    var table main_table = table.new(position.top_right, 3, 11, bgcolor=baseBG, border_color=frameBG, border_width=0, frame_color=frameBG, frame_width=1)

    table.cell(main_table, 0, 0, "", bgcolor=titleBG)
    table.cell(main_table, 1, 0, "DTG", text_color=valueTxt, text_size=tblSize, bgcolor=titleBG, text_halign=text.align_right)
    table.cell(main_table, 2, 0, "STRATEGY", text_color=titleTxt, text_size=tblSize, bgcolor=titleBG, text_halign=text.align_left)

    table.cell(main_table, 0, 1, "●", text_color=step1Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 1, "Bias", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 1, biasLabel, text_color=valueTxt, text_size=tblSize, bgcolor=color.new(biasColor, 30), text_halign=text.align_center)

    discClr = touchZonesStr != "None" ? biasColor : color.new(color.gray, 0)
    discTxtSize = str.length(touchZonesStr) > 12 ? size.tiny : str.length(touchZonesStr) > 5 ? size.small : tblSize
    table.cell(main_table, 0, 2, "●", text_color=step2Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 2, "Touched", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 2, touchZonesStr, text_color=valueTxt, text_size=discTxtSize, bgcolor=color.new(discClr, 30), text_halign=text.align_center)

    table.cell(main_table, 0, 3, "●", text_color=step3Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 3, "Signal", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 3, trade_Status, text_color=valueTxt, text_size=tblSize, bgcolor=color.new(noSignal_Bias, 30), text_halign=text.align_center)

    table.cell(main_table, 0, 4, "", bgcolor=dividerBG)
    table.cell(main_table, 1, 4, "System", text_color=labelTxt, text_size=tblSize, bgcolor=dividerBG, text_halign=text.align_right)
    table.cell(main_table, 2, 4, systemStateStr, text_color=color.white, text_size=tblSize, bgcolor=color.new(systemStateClr, 20), text_halign=text.align_center)

    string modelStr = showTrade and not na(trade_Model) ? trade_Model : "—"
    color  modelClr = trade_Bias
    table.cell(main_table, 0, 5, "", bgcolor=baseBG)
    table.cell(main_table, 1, 5, "Model", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 5, modelStr, text_color=valueTxt, text_size=tblSize, bgcolor=showTrade ? color.new(modelClr, 35) : baseBG, text_halign=text.align_center)

    if showTrade
        float riskPctVal_d = riskPct == "0.5%" ? 0.005 : riskPct == "1%" ? 0.01 : riskPct == "2%" ? 0.02 : 0.03
        float riskAmount_d = accountSize * riskPctVal_d
        float riskUSD_d    = riskAmount_d * fxRate
        float slDist_d     = math.abs(trade_Entry - trade_SL)
        float rPL_d = 0.0
        string lotUnit_d = "lots"
        if XAU
            rPL_d := slDist_d * 100
        else if XAG
            rPL_d := slDist_d * 5000
        else if isOil
            rPL_d := slDist_d * 1000
        else if isCrypto
            rPL_d := slDist_d * 1.0
            lotUnit_d := syminfo.basecurrency
        else if isIndex
            float idxPV = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
            rPL_d := slDist_d * idxPV
        else if FX
            bool isJPY_d = str.contains(syminfo.ticker, "JPY")
            float pipSz_d = isJPY_d ? 0.01 : 0.0001
            rPL_d := (slDist_d / pipSz_d) * 10.0
        else
            float fallbackPV = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
            rPL_d := slDist_d * fallbackPV
        float lotVal_d = rPL_d > 0 ? math.max(0.01, math.round(riskUSD_d / rPL_d, isCrypto ? 4 : 2)) : 0.01

        color tradeCellBG = color.new(trade_Bias, 55)
        table.cell(main_table, 0, 6, "", bgcolor=baseBG)
        table.cell(main_table, 1, 6, "Entry",     text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 6, str.tostring(trade_Entry, format.mintick), text_color=valueTxt, text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 7, "", bgcolor=baseBG)
        string slValue_d = trade_TP1hit ? "Moved To BE" : str.tostring(trade_SL, format.mintick)
        color  slCellBG  = trade_TP1hit ? color.new(#FF9100, 45) : tradeCellBG
        table.cell(main_table, 1, 7, "SL",        text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 7, slValue_d,   text_color=valueTxt, text_size=tblSize, bgcolor=slCellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 8, "", bgcolor=baseBG)
        color  tp1CellBG  = trade_TP1hit ? color.new(#00C853, 35) : tradeCellBG
        string tp1Value_d = trade_TP1hit ? "Secured" : str.tostring(trade_TP1, format.mintick)
        table.cell(main_table, 1, 8, "TP1",       text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 8, tp1Value_d,  text_color=valueTxt, text_size=tblSize, bgcolor=tp1CellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 9, "", bgcolor=baseBG)
        table.cell(main_table, 1, 9, "TP2",       text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 9, str.tostring(trade_TP2, format.mintick), text_color=valueTxt, text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
        table.cell(main_table, 0, 10, "", bgcolor=baseBG)
        table.cell(main_table, 1, 10, "Lots",     text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 10, str.tostring(lotVal_d, isCrypto ? "#.####" : "#.##") + " " + lotUnit_d, text_color=color.new(#00E5FF, 0), text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
    else
        table.clear(main_table, 0, 5, 2, 10)

// ─────────────────────────────────────────────────────────────────────────────
// §19  END
// ─────────────────────────────────────────────────────────────────────────────
