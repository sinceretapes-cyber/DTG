//@version=6
indicator("DTG Key Levels", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

//──────────────────────────────────────────────────────────────────────────────
// Inputs (DEFAULTS hard-coded to your screenshot values)
//──────────────────────────────────────────────────────────────────────────────
levelsEachSide = input.int(10, "Levels above/below price", minval=1, maxval=200)   // default: 10

// ── Spacing: Manual vs. Auto ───────────────────────────────────────────────
// Manual uses the value below verbatim (back-compatible: defaults to 25).
// Auto looks up the symbol in the override list first; if no match, it falls
// back to a price-magnitude heuristic so the grid lands on "nice" round
// numbers for any instrument without hand-tuning.
spacingMode    = input.string("Auto", "Spacing mode", options=["Auto", "Manual"], tooltip="Auto (default): produce 25/50/75/00 quarter-level grids on every instrument. Looks up the symbol in the override list first; falls back to a 0.25 × 10^N heuristic snapped to ≈ 0.5% of price. Manual: use 'Manual spacing' below.")
manualStep     = input.int(25, "Manual spacing", options=[25, 50, 100])            // default: 25 (used when Spacing mode = Manual)
overrideList   = input.string("ES=25, MES=25, NQ=25, MNQ=25, YM=25, MYM=25, RTY=2.5, CL=0.25, MCL=0.25, NG=0.025, GC=2.5, MGC=2.5, SI=0.25, MSI=0.25, ZB=0.25, ZN=0.25, BTC=250, BTCUSD=250, BTCUSDT=250, ETH=25, ETHUSD=25, ETHUSDT=25, XAGUSD=0.25, XAUUSD=2.5, XPTUSD=2.5, XPDUSD=2.5, EURUSD=0.0025, GBPUSD=0.0025, AUDUSD=0.0025, NZDUSD=0.0025, USDCAD=0.0025, USDCHF=0.0025, USDJPY=0.25, EURJPY=0.25, GBPJPY=0.25, AUDJPY=0.25, SPY=2.5, QQQ=2.5, IWM=0.25, DIA=0.25, AAPL=0.25, MSFT=0.25, NVDA=0.25, TSLA=0.25, GOOG=0.25, META=2.5, AMZN=0.25",
     "Auto: per-symbol overrides", tooltip="Comma-separated TICKER=STEP pairs that produce 25/50/75/00 quarter-level grids on each instrument. Every step value is from the 0.25 × 10^N family so adjacent levels always read as a quarter pattern (e.g. silver step 0.25 → 84.000 / 84.250 / 84.500 / 84.750; ES step 25 → 5000 / 5025 / 5050 / 5075; BTC step 250 → 70000 / 70250 / 70500 / 70750). Matched against syminfo.root first (futures), then syminfo.ticker (spot/equity/FX/crypto). First match wins; case-insensitive; spaces tolerated. Used only when Spacing mode = Auto.")

// ── Zone size: Manual vs. Auto ────────────────────────────────────────────
// Auto scales the zone half-width with the effective spacing, so the zones
// stay visually proportional on instruments that aren't 25-point-spaced
// (e.g. CL at 0.25, FX at 0.005). Manual keeps the original price-unit
// behaviour for back-compat.
zoneMode       = input.string("Auto", "Zone size mode", options=["Auto", "Manual"], tooltip="Auto (default): zone half-width = (fraction below) × effective spacing — keeps zones proportional on every instrument. Manual: zone is ±(value below) in price units.")
manualZoneSize = input.float(2.0, "Manual zone size (± around level)", minval=0.0)  // default: 2 (used when Zone size mode = Manual)
autoZoneFrac   = input.float(0.1, "Auto zone fraction of step", minval=0.0, maxval=0.5)  // default: 0.1 (used when Zone size mode = Auto)
showZones      = input.bool(true, "Show zone rectangles")                                 // default: true

lineColor      = input.color(color.new(color.gray, 0), "Base line color")
lineWidth      = input.int(1, "Line width", minval=1, maxval=4)                    // default: 1
styleOpt       = input.string("Solid", "Line style", options=["Solid", "Dashed", "Dotted"]) // default: Solid
lineStyle      = styleOpt == "Dashed" ? line.style_dashed : styleOpt == "Dotted" ? line.style_dotted : line.style_solid

baseZoneColor  = input.color(color.new(color.gray, 85), "Base zone fill")

// Highlights (DEFAULTS to match screenshot: all ON)
show25         = input.bool(true, "Highlight 25 levels (xx25/xx75)")       // NEW
col25          = input.color(color.new(color.blue, 85), "25-level zone fill") // NEW

show50         = input.bool(true, "Highlight 50 levels (xx50)")
col50          = input.color(color.new(color.aqua, 80), "50-level zone fill")

show100        = input.bool(true, "Highlight 100 levels (xx00)")
col100         = input.color(color.new(color.yellow, 80), "100-level zone fill")

show500        = input.bool(true, "Highlight 500 levels")
col500         = input.color(color.new(color.orange, 80), "500-level zone fill")

// Text labels (DEFAULTS to match screenshot)
showText       = input.bool(true, "Show text on highlighted levels")
labelFormat    = input.string("Auto", "Label format", options=["Auto", "Full price", "Compact (k / M)"],
     tooltip="Auto: full price below 10,000; 'X.XXk' between 10,000 and 1,000,000; 'X.XXM' above. Full: raw price (original behaviour). Compact: always use k/M suffix above 1,000. Decimal precision in every mode is derived from the effective spacing.")
textColor      = input.color(color.yellow, "Text colour")
textXOffset    = input.int(30, "Text X offset (bars to the right)", minval=0, maxval=500)  // default: 30
textSizeOpt    = input.string("Small", "Text size", options=["Tiny","Small","Normal","Large"])
textSize       = textSizeOpt == "Tiny" ? size.tiny : textSizeOpt == "Normal" ? size.normal : textSizeOpt == "Large" ? size.large : size.small

// “Full chart” span for zones (time-based) — HARD CODED and NOT in menu
const int leftYear  = 1900
const int rightYear = 2100

//──────────────────────────────────────────────────────────────────────────────
// Helpers
//──────────────────────────────────────────────────────────────────────────────
roundToStep(v, s) =>
    math.round(v / s) * s

toTicks(v) =>
    math.round(v / syminfo.mintick)

ticksFor(v) =>
    math.round(v / syminfo.mintick)

// Returns the step value matched against `ticker` in a "T1=S1, T2=S2, ..."
// list, or na if no match. Case-insensitive; tolerates surrounding spaces.
// First match wins.
parseOverride(ticker, list) =>
    matched = 0.0
    found   = false
    cleaned = str.replace_all(list, " ", "")
    parts   = str.split(cleaned, ",")
    sz = na(parts) ? 0 : array.size(parts)
    if sz > 0
        for i = 0 to sz - 1
            entry = array.get(parts, i)
            kv    = str.split(entry, "=")
            if not na(kv) and array.size(kv) == 2 and not found
                k = str.upper(array.get(kv, 0))
                v = array.get(kv, 1)
                if k == str.upper(ticker)
                    parsed = str.tonumber(v)
                    if not na(parsed)
                        matched := parsed
                        found   := true
    found ? matched : na

// Heuristic fallback for Auto mode when the symbol isn't in the override
// list. Always returns a step from the "quarter" family — i.e.
// step = 0.25 × 10^N for some integer N — so the grid lines always read
// as the 25 / 50 / 75 / 00 pattern in their natural decimal place,
// matching the original ES (5000 / 5025 / 5050 / 5075) behaviour at every
// price scale:
//   silver  $84      → step 0.25     → 84.000, 84.250, 84.500, 84.750, 85.000
//   ES      $5 000   → step 25       → 4975, 5000, 5025, 5050, 5075
//   NQ      $22 000  → step 25       → 21975, 22000, 22025, 22050, 22075
//   gold    $2 400   → step 2.5      → 2400.0, 2402.5, 2405.0, 2407.5, 2410.0
//   BTC     $70 000  → step 250      → 69750, 70000, 70250, 70500, 70750
//   EURUSD  1.10     → step 0.0025   → 1.0975, 1.1000, 1.1025, 1.1050
//   USDJPY  150      → step 0.25     → 149.75, 150.00, 150.25, 150.50
//
// Density target: step ≈ 0.5% of price (so 21 levels span ≈ 10% of price).
// N is the largest integer such that 0.25 × 10^N ≤ 0.5% × price, i.e.
//   N = floor( log10( 0.02 × price ) )
// because 0.5% / 0.25 = 0.02. Snaps down to the nearest quarter step so the
// grid is never finer than the conventional density on each instrument.
quarterStep(price) =>
    av = math.abs(price)
    av < 1e-12 ? 0.25 : 0.25 * math.pow(10, math.floor(math.log10(0.02 * av)))

// Number of decimal places required to render `s` exactly. Used to pick a
// "just enough" precision for label formatting:
//   step=25 → 0,  step=0.5 → 1,  step=0.25 → 2,  step=0.005 → 3,  step=0.0001 → 4.
// Multiplies by 10 until the value is (approximately) an integer; the small
// tolerance absorbs the float drift you get from chained multiplications.
decimalsForStep(s) =>
    d = 0
    v = math.abs(s)
    for i = 0 to 10
        if math.abs(v - math.round(v)) < 1e-9 or d >= 8
            break
        v := v * 10
        d := d + 1
    d

// Convert a decimal count into a Pine format string. `#` is "optional digit"
// so trailing zeros are dropped, e.g. 30.0 → "30", 30.50 → "30.5".
decimalsToFmt(d) =>
    d <= 0 ? "#" :
     d == 1 ? "#.#" :
     d == 2 ? "#.##" :
     d == 3 ? "#.###" :
     d == 4 ? "#.####" :
     d == 5 ? "#.#####" :
     d == 6 ? "#.######" :
     d == 7 ? "#.#######" : "#.########"

// Render a price level for display next to a grid line.
//   mode = "Full price"     : raw str.tostring (original behaviour).
//   mode = "Compact (k / M)": k-suffix above 1 000, M-suffix above 1 000 000.
//   mode = "Auto" (default) : full below 10 000, k between 10 000 and 1 000 000,
//                             M above 1 000 000. Decimal precision in every
//                             branch is derived from the effective step so
//                             the label always has just enough digits to
//                             distinguish adjacent levels.
formatLevel(value, stepRef, mode) =>
    av = math.abs(value)
    useM = (mode == "Compact (k / M)" or mode == "Auto") and av >= 1000000.0
    useK = not useM and ((mode == "Compact (k / M)" and av >= 1000.0) or (mode == "Auto" and av >= 10000.0))
    result = ""
    if useM
        kd = math.min(decimalsForStep(stepRef / 1000000.0), 3)
        result := str.tostring(value / 1000000.0, decimalsToFmt(kd)) + "M"
    else if useK
        kd = math.min(decimalsForStep(stepRef / 1000.0), 3)
        result := str.tostring(value / 1000.0, decimalsToFmt(kd)) + "k"
    else if mode == "Full price"
        result := str.tostring(value)
    else
        d = math.min(decimalsForStep(stepRef), 8)
        result := str.tostring(value, decimalsToFmt(d))
    result

//──────────────────────────────────────────────────────────────────────────────
// Persistent objects
//──────────────────────────────────────────────────────────────────────────────
total = 2 * levelsEachSide + 1

// Computed once: full-chart time span used for both lines and boxes.
// Giving the lines a real horizontal span (instead of a 1ms point + extend.both)
// prevents the "solid grey stub at the most recent candle" artifact that can
// appear after a tab suspend/resume, where the renderer briefly shows a line's
// literal stored geometry before re-applying the extend attribute.
var int leftT  = timestamp(leftYear,  1, 1, 0, 0)
var int rightT = timestamp(rightYear, 1, 1, 0, 0)

// Effective spacing + tier thresholds + zone size, resolved once on the first
// bar so the grid is stable across the chart instead of re-snapping bar-to-bar.
// In Manual mode the tier thresholds stay at the original absolute values
// (25/50/100/500 price units) for back-compat. In Auto mode they scale with
// the effective step (1×/2×/4×/20×) so the visual hierarchy is preserved on
// any instrument: e.g. step=0.25 → tiers at 0.25/0.5/1/5; step=50 → 50/100/200/1000.
var float step     = na
var float tier25   = na
var float tier50   = na
var float tier100  = na
var float tier500  = na
var float zoneSize = na

var line[]  Ls = array.new_line()
var box[]   Bs = array.new_box()
var label[] Ts = array.new_label()

if barstate.isfirst
    if spacingMode == "Auto"
        ov = parseOverride(syminfo.root, overrideList)
        if na(ov)
            ov := parseOverride(syminfo.ticker, overrideList)
        step    := not na(ov) ? ov : quarterStep(close)
        tier25  := step
        tier50  := step * 2
        tier100 := step * 4
        tier500 := step * 20
    else
        step    := manualStep * 1.0  // int → float promotion
        tier25  := 25.0
        tier50  := 50.0
        tier100 := 100.0
        tier500 := 500.0
    zoneSize := zoneMode == "Auto" ? step * autoZoneFrac : manualZoneSize

    for _ = 0 to total - 1
        // Time-based line spanning the full chart so extend.both is belt-and-suspenders
        // rather than the only thing making the line visible.
        ln = line.new(leftT, close, rightT, close,
            xloc=xloc.bar_time, extend=extend.both, color=lineColor, width=lineWidth, style=lineStyle)

        // Time-based box (we'll stretch left/right by timestamps)
        bx = box.new(time, close + zoneSize, time + 1, close - zoneSize,
            xloc=xloc.bar_time, bgcolor=baseZoneColor, border_color=color.new(lineColor, 70))

        // CENTERED text label (transparent background so it looks text-only)
        lb = label.new(bar_index, close, "",
            xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_center, size=textSize,
            textcolor=textColor, color=color.new(color.black, 100))

        array.push(Ls, ln)
        array.push(Bs, bx)
        array.push(Ts, lb)

//──────────────────────────────────────────────────────────────────────────────
// Update (RUN ON EVERY BAR CALCULATION — fixes soft reload / app resume glitch)
//──────────────────────────────────────────────────────────────────────────────
anchor = roundToStep(close, step)

t25  = ticksFor(tier25)
t50  = ticksFor(tier50)
t100 = ticksFor(tier100)
t500 = ticksFor(tier500)

for idx = 0 to total - 1
    offset   = idx - levelsEachSide
    lvl      = anchor + offset * step
    lvlTicks = toTicks(lvl)

    is500 = show500 and (t500 > 0) and (lvlTicks % t500 == 0)
    is100 = show100 and (t100 > 0) and (lvlTicks % t100 == 0)
    is50  = show50  and (t50  > 0) and (lvlTicks % t50  == 0) and not is100

    // "25 tier" = grid levels that land on the 25-tier multiple but NOT on a
    // higher tier. With Manual mode this is exactly the original behaviour
    // (xx25 / xx75 levels when spacing is 25; no-op when spacing is 50/100,
    // since no level lands on a 25-multiple between 50-multiples). With Auto
    // mode tier25 == step, so this fires for every grid level that isn't
    // already promoted to 50/100/500 — i.e. the quarter levels of the chosen
    // instrument's effective spacing.
    is25  = show25 and (t25 > 0) and (lvlTicks % t25 == 0) and not is50 and not is100 and not is500

    // Zone color priority: 500 > 100 > 50 > 25 > base
    zCol = is500 ? col500 :
           is100 ? col100 :
           is50  ? col50  :
           is25  ? col25  :
           baseZoneColor

    // Zones visible toggle
    bFill = showZones ? zCol : color.new(zCol, 100)
    bBord = showZones ? color.new(zCol, 55) : color.new(zCol, 100)

    // Line: full-chart time span + extend both directions.
    // Using leftT/rightT (not `time`) so the line's stored geometry is already
    // chart-wide; if extend.both is momentarily not applied during a re-render
    // (suspend/resume), the line still draws across the chart instead of
    // collapsing to a 1ms stub at the most recent bar.
    ln = array.get(Ls, idx)
    line.set_xy1(ln, leftT,  lvl)
    line.set_xy2(ln, rightT, lvl)
    line.set_extend(ln, extend.both)
    line.set_color(ln, lineColor)
    line.set_width(ln, lineWidth)
    line.set_style(ln, lineStyle)

    // Box: time-based full span (no bar_index distance limits)
    bx = array.get(Bs, idx)
    box.set_left(bx, leftT)
    box.set_right(bx, rightT)
    box.set_top(bx, lvl + zoneSize)
    box.set_bottom(bx, lvl - zoneSize)
    box.set_bgcolor(bx, bFill)
    box.set_border_color(bx, bBord)

    // Text labels: label any level that fires a tier. On a 25-grid (Manual
    // step=25, or Auto where step is the 25-tier) every level is at least an
    // is25, so all levels get labelled — matching the original behaviour.
    // On coarser grids (Manual step=50/100) is25 never fires; only the
    // highlighted tiers get text, also matching the original behaviour.
    lb = array.get(Ts, idx)
    wantText = showText and (is25 or is50 or is100 or is500)

    label.set_x(lb, bar_index + textXOffset)
    label.set_y(lb, lvl)
    label.set_size(lb, textSize)
    // Use style_none when there's no text so the label has no frame to flash
    // during a re-hydrate after suspend/resume; switch back to centered when
    // there is text to display.
    label.set_style(lb, wantText ? label.style_label_center : label.style_none)
    label.set_textcolor(lb, textColor)
    label.set_color(lb, color.new(color.black, 100))  // invisible background

    label.set_text(lb, wantText ? formatLevel(lvl, step, labelFormat) : "")
