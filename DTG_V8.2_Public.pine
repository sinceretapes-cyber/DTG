//@version=6
indicator("DTG V8.2", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500, dynamic_requests=true)

// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  DTG DZ STRATEGY — Public Release                                        ║
// ║  Single Entry Model (EM1) · Multi-TF bias · Auto-discount zones          ║
// ║  3-Step System: Bias → Zone Touch → Signal                               ║
// ╚═══════════════════════════════════════════════════════════════════════════╝


// ─────────────────────────────────────────────────────────────────────────────
// §1  INPUTS
// ─────────────────────────────────────────────────────────────────────────────
// Inputs are organised into 5 logical groups:
//   1. System Preset  — single dropdown that bundles trading philosophy
//   2. Signals        — what to display when a setup fires
//   3. Visuals        — dashboard, zones, RR boxes, history, windows
//   4. Risk Management — account size, currency, risk per trade
//
// Hardcoded internals (not exposed to keep the menu clean):
//   • EM1 entry model   — always enabled (the only model in this build)
//   • Bias countdown    — always shown (small, useful, no reason to hide)
const bool enableEM1         = true
const bool showBiasCountdown = true

// ── SYSTEM PRESET (top of menu — the most consequential decision) ──
// Single dropdown that bundles 4 system rules + the TP1/BE behaviour into
// one named mode. Presets are a clearer, less-error-prone way for members
// to switch between trading philosophies than 5 separate checkboxes.
//
//   V8 Pro      — original strict gating with TP1→BE trail
//   Funded Pro  — strict gating, NO TP1, NO BE move; binary Entry→TP2 or
//                 Entry→SL exits. Matches funded-account preferences.
//   V8 Unlocked — every system filter off; raw pattern fires. NOT recommended
//                 for live trading — see warning rendered on chart when active.
grpSystem       = "System Preset"
preset          = input.string("V8 Pro", "Mode", options=["V8 Pro", "Funded Pro", "V8 Unlocked"], group=grpSystem, tooltip="V8 Pro — original strict 3-step system with TP1→BE trail (recommended default).\n\nFunded Pro — strict gating, but trade is binary: Entry hits TP2 (Win) or SL (Loss). No TP1, no break-even move. Matches funded-account requirements.\n\n⚠ V8 Unlocked — every system filter off. Fires on raw EM1 pattern + bias only. Expect significantly more signals but unverified win rate. Use at your own risk — NOT recommended for live trading.")

// Derive the four legacy rule booleans from the preset choice. Downstream
// code keeps reading these names so nothing else changes.
bool excludeNonTW   = preset != "V8 Unlocked"
bool windowTapsOnly = preset != "V8 Unlocked"
bool oneTradePerDay = preset != "V8 Unlocked"
bool requireZoneTap = preset != "V8 Unlocked"
// Funded Pro disables TP1 management entirely — exit is binary (TP2 or SL).
bool tp1Enabled     = preset != "Funded Pro"

// ── SIGNALS ──
grpSig        = "Signals"
showLabel     = input.string("Buy / Sell", "Signal Style", options=["Buy / Sell", "Symbol", "Off"], inline="S1", group=grpSig)
showMax       = input.int(1, "Signals on Chart", minval=1, maxval=500, inline="S1", group=grpSig)
buy_c         = input.color(color.new(#056656, 0), "Buy",  inline="S2", group=grpSig)
sell_c        = input.color(color.new(#b22833, 0), "Sell", inline="S2", group=grpSig)
txt_c         = input.color(color.new(color.white, 0), "Text", inline="S2", group=grpSig)
inputSpread   = input.int(3, "Spread Buffer", minval=0, maxval=20, group=grpSig, tooltip="Spread pips added to entry and SL buffer.")

// ── VISUALS ──
grpVis        = "Visuals"
// Dashboard line — toggle + size
showTable     = input.bool(true, "Dashboard", inline="V_Dash", group=grpVis)
dashSize      = input.string("normal", "Size", options=["tiny","small","normal","large"], inline="V_Dash", group=grpVis)
// On-chart visuals (singles)
showRR        = input.bool(true, "RR Boxes on Chart", group=grpVis, tooltip="Show Entry/SL/TP1/TP2 boxes during active trades.")
showHistory   = input.bool(true, "Show Last Trade",   group=grpVis, tooltip="Keep the last completed trade visible on chart with W/1:1/L label.")
// Trading-window background — toggle + color picker on one line
tradingWindow = input.bool(true, "Trading Window Background", inline="V_TW", group=grpVis)
TW_color      = input.color(color.new(color.gray, 85), "",    inline="V_TW", group=grpVis)
// Discount-zone block — toggle, mode, fallback TF, then colors
enableFib     = input.bool(true,  "Discount Zones",      group=grpVis)
autoDiscount  = input.bool(true,  "Auto-Escalate Zones", group=grpVis, tooltip="Automatically selects the best discount zone across 4H→6H→8H→12H→D→W. Turn off to use manual zone timeframe below.")
base_tf       = input.timeframe("240", "Manual Zone TF", options=["60","120","180","240","360","480","600","720","D","W","M"], group=grpVis, tooltip="Only used when Auto-Escalate is OFF.")
// Zone fill + border colors paired by direction
bull_fill     = input.color(color.new(color.green, 80), "Bull Fill",   inline="V_Fill",   group=grpVis)
bear_fill     = input.color(color.new(color.red, 80),   "Bear Fill",   inline="V_Fill",   group=grpVis)
bull_border   = input.color(color.green,                "Bull Border", inline="V_Border", group=grpVis)
bear_border   = input.color(color.red,                  "Bear Border", inline="V_Border", group=grpVis)
line_width    = input.int(1, "Zone Mid Line", minval=1, maxval=6, group=grpVis)

// ── RISK MANAGEMENT ──
grpRisk       = "Risk Management"
accountSize   = input.float(10000, "Account Size",  minval=100, step=500, group=grpRisk)
acctCurrency  = input.string("USD", "Account Currency", options=["USD", "AUD", "EUR", "GBP"], group=grpRisk, tooltip="Select your account currency. Lot sizes auto-adjust using live exchange rates.")
riskPct       = input.string("1%",  "Risk Per Trade",   options=["0.5%", "1%", "2%", "3%"], group=grpRisk)

// (System Preset moved to top of §1 — see beginning of file.)


// ─────────────────────────────────────────────────────────────────────────────
// §4  UTILITY FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────

f_DTG_algo(_lname, _lbar, _lval, _lpos, _lcol, _lstyle, _ltext, _ltextc, _lsize) =>
    array.push(_lname, label.new(x=_lbar, y=_lval, yloc=_lpos, color=_lcol, style=_lstyle, text=_ltext, textcolor=_ltextc, size=_lsize))

f_LABEL_truncate(_ArrayL, _NumToKeepL) =>
    if array.size(_ArrayL) >= _NumToKeepL + 1
        label.delete(array.shift(_ArrayL))

BiasV(v1)      => v1 > 0 ? 1 : v1 < 0 ? -1 : 0
BiasC(c1)      => c1 > 0 ? buy_c : c1 < 0 ? sell_c : color.yellow


// ─────────────────────────────────────────────────────────────────────────────
// §6  H4 COUNTER & FILTER FLAGS
// ─────────────────────────────────────────────────────────────────────────────

var int H4_counter = 0
if timeframe.change("D")
    H4_counter := 1
if timeframe.change("240") and not timeframe.change("D")
    H4_counter := nz(H4_counter) + 1

int  TmF            = timeframe.multiplier
bool intradayFilter = timeframe.isintraday and TmF <= 240
bool mergedTW       = intradayFilter and (H4_counter >= 3 and H4_counter <= 5)
bool XAU            = str.contains(str.upper(syminfo.ticker), "XAU")
bool XAG            = str.contains(str.upper(syminfo.ticker), "XAG")
bool FX             = syminfo.type == "forex"
bool isCrypto       = syminfo.type == "crypto"
bool isIndex        = str.contains(syminfo.ticker, "US30") or str.contains(syminfo.ticker, "NAS100") or str.contains(syminfo.ticker, "SPX500") or str.contains(syminfo.ticker, "US500") or str.contains(syminfo.ticker, "DE40") or str.contains(syminfo.ticker, "UK100") or str.contains(syminfo.ticker, "JP225") or str.contains(syminfo.ticker, "AUS200")
bool isOil          = str.contains(syminfo.ticker, "USOIL") or str.contains(syminfo.ticker, "UKOIL") or str.contains(syminfo.ticker, "WTI") or str.contains(syminfo.ticker, "BRENT") or str.contains(syminfo.ticker, "CL") or str.contains(syminfo.ticker, "BCO")
bool XAU_XAG        = XAU or XAG
bool assetsFilter   = true
bool intradayTF     = timeframe.isintraday and (not XAU_XAG ? TmF >= 15 : true)
bool buLTF_XAU_XAG  = XAU_XAG and TmF < 15
bool beLTF_XAU_XAG  = XAU_XAG and TmF < 15

bgcolor(tradingWindow and mergedTW ? TW_color : na)


// ─────────────────────────────────────────────────────────────────────────────
// §7  EMA & MARKET DATA
// ─────────────────────────────────────────────────────────────────────────────

ema8       = ta.ema(close, 8)
ema20      = ta.ema(close, 20)
trend_avg  = (ema8 + ema20) / 2
pct_change = 100 * (ema8 - ema20) / trend_avg

spread_tick = syminfo.mintick * (XAU ? 100 : (XAG ? 1000 : (FX ? 10 : 0)))
digits      = int(math.log10(1 / syminfo.mintick) - 1)
TF_num      = timeframe.isintraday ? (TmF < 60 ? TmF : math.round(TmF / 60, 0)) : TmF
TF_HRmn     = timeframe.isintraday ? (TmF < 60 ? "minute timeframe." : "hour timeframe.") : "minute timeframe."
TF_txt      = str.tostring(TF_num, "") + " " + TF_HRmn


// ─────────────────────────────────────────────────────────────────────────────
// §8  TRADE STATE (UDT — user-defined types)
// ─────────────────────────────────────────────────────────────────────────────

// ── Active trade being tracked on the current day ──
type TradeState
    int    bar          = na
    int    triggerBar   = na
    int    time         = na
    string status       = na
    float  entry        = na
    float  sl           = na
    float  tp1          = na
    float  tp2          = na
    color  bias         = na
    string model        = na
    string zoneTF       = na
    bool   tp1hit       = false

// ── Discount-zone snapshot frozen at signal time ──
type ZoneSnapshot
    float  zt           = na
    float  zb           = na
    int    openTime     = na
    int    closeTime    = na
    string tfLabel      = na
    int    bias         = 0

// ── Background monitor — Triggered trade carried past a day roll ──
type BgTrade
    float  entry        = na
    float  sl           = na
    float  tp1          = na
    float  tp2          = na
    int    bar          = na
    int    time         = na
    int    dir          = 0
    bool   active       = false
    bool   tp1hit       = false

// ── Last-completed-trade record (single slot — for chart history visual) ──
type TradeHistory
    int    bar          = na
    int    exitBar      = na
    int    time         = na
    int    exitTime     = na
    float  entry        = na
    float  sl           = na
    float  tp1          = na
    float  tp2          = na
    int    dir          = 0
    int    outcome      = 0
    bool   valid        = false

var TradeState    trade = TradeState.new()
var ZoneSnapshot  zone  = ZoneSnapshot.new()
var BgTrade       bg    = BgTrade.new()
var TradeHistory  hist  = TradeHistory.new()

// ── 3-STEP SYSTEM STATE ──
var bool stepTwoMet        = false
var int  stepTwoBias       = 0
var bool dailyProfitTaken  = false

// Dashboard sticky flags — declared early so EM1 gate (§10) can read them
var bool dashStk_4h  = false
var bool dashStk_6h  = false
var bool dashStk_8h  = false
var bool dashStk_12h = false
var bool dashStk_D   = false
var bool dashStk_W   = false

bool buySignal  = false
bool sellSignal = false

// Daily reset — full system reset at start of each new day.
// If a Triggered trade is still live, move it to background monitoring so it can
// still complete (TP2/SL) across day boundaries. Main system resets freely.
if timeframe.change("D")
    if trade.status == "Triggered" and not na(trade.entry)
        bg.entry  := trade.entry
        bg.sl     := trade.sl
        bg.tp1    := trade.tp1
        bg.tp2    := trade.tp2
        bg.bar    := trade.bar
        bg.time   := trade.time
        bg.dir    := trade.bias == buy_c ? 1 : -1
        bg.tp1hit := trade.tp1hit
        bg.active := true
    stepTwoMet       := false
    stepTwoBias      := 0
    dailyProfitTaken := false
    trade.status     := "Scanning"
    trade.bar        := na
    trade.triggerBar := na
    trade.time       := na
    trade.entry      := na
    trade.sl         := na
    trade.tp1        := na
    trade.tp2        := na
    trade.bias       := na
    trade.model      := na
    trade.zoneTF     := na
    trade.tp1hit     := false
    zone.zt          := na
    zone.zb          := na
    zone.openTime    := na
    zone.closeTime   := na
    zone.tfLabel     := na
    zone.bias        := 0

// ── BACKGROUND TRADE MONITOR ──
// Tracks old Triggered trades that survived the daily reset. Runs every bar.
// When TP2 or SL is hit, captures to hist record and clears. Does NOT block new
// signals. Outcomes: +1 = Win (TP2), 0 = 1:1 Secured, -1 = Loss (SL no TP1).
if bg.active
    bool bg_isBuy     = bg.dir == 1
    bool bg_wasTP1hit = bg.tp1hit
    bool bg_checkTP1  = (bg_isBuy and high > bg.tp1) or (not bg_isBuy and low < bg.tp1)
    if bg_checkTP1
        bg.tp1hit := true
    bool bg_hitTP2 = (bg_isBuy and high > bg.tp2) or (not bg_isBuy and low < bg.tp2)
    bool bg_hitSL  = not bg_wasTP1hit and ((bg_isBuy and low < bg.sl) or (not bg_isBuy and high > bg.sl))
    bool bg_hitBE  = bg_wasTP1hit and ((bg_isBuy and low < bg.entry) or (not bg_isBuy and high > bg.entry))
    if bg_hitTP2 or bg_hitBE or bg_hitSL
        if showHistory
            hist.bar := bg.bar, hist.exitBar := bar_index
            hist.time := bg.time, hist.exitTime := time
            hist.entry := bg.entry, hist.sl := bg.sl
            hist.tp1 := bg.tp1, hist.tp2 := bg.tp2
            hist.dir := bg.dir
            hist.outcome := bg_hitTP2 ? 1 : bg_hitBE ? 0 : -1
            hist.valid := true
        bg.active := false
        bg.tp1hit := false


// ─────────────────────────────────────────────────────────────────────────────
// §8b  MULTI-TF DATA — Consolidated
// ─────────────────────────────────────────────────────────────────────────────

[open_4h, close_4h, high_4h, low_4h]     = request.security(syminfo.tickerid, "240", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_6h, close_6h, high_6h, low_6h]     = request.security(syminfo.tickerid, "360", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_8h, close_8h, high_8h, low_8h]     = request.security(syminfo.tickerid, "480", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_12h, close_12h, high_12h, low_12h] = request.security(syminfo.tickerid, "720", [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_Db, close_Db, high_Db, low_Db]     = request.security(syminfo.tickerid, "D",   [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)
[open_Wb, close_Wb, high_Wb, low_Wb]     = request.security(syminfo.tickerid, "W",   [open[1], close[1], high[1], low[1]], lookahead=barmerge.lookahead_on)

f_tf_bias(c, o) => c > o ? 1 : c < o ? -1 : 0

bias_4h  = f_tf_bias(close_4h, open_4h)
bias_6h  = f_tf_bias(close_6h, open_6h)
bias_8h  = f_tf_bias(close_8h, open_8h)
bias_12h = f_tf_bias(close_12h, open_12h)
bias_D   = f_tf_bias(close_Db, open_Db)
bias_W   = f_tf_bias(close_Wb, open_Wb)

sum_bias   = bias_4h + bias_6h + bias_8h + bias_12h + bias_D + bias_W
biasLabel  = sum_bias >= 2 ? "Bullish" : sum_bias <= -2 ? "Bearish" : "Neutral"
biasColor  = sum_bias >= 2 ? color.new(color.green, 0) : sum_bias <= -2 ? color.new(color.red, 0) : color.new(color.yellow, 0)

int overallBias = sum_bias >= 2 ? 1 : sum_bias <= -2 ? -1 : 0

color H4_c = BiasC(close_4h - open_4h)
int   mult = BiasV(close_4h - open_4h)

// ── EXCHANGE RATE (single conditional call) ──
// Only one of the three rates is needed at any time — fetch the one that matches
// the selected account currency.
string fxSym   = acctCurrency == "AUD" ? "FX:AUDUSD" : acctCurrency == "GBP" ? "FX:GBPUSD" : "FX:EURUSD"
float  fxClose = request.security(fxSym, "D", close, barmerge.gaps_off, barmerge.lookahead_on)
float  fxRate  = acctCurrency == "AUD" ? nz(fxClose, 0.65) : acctCurrency == "EUR" ? nz(fxClose, 1.08) : acctCurrency == "GBP" ? nz(fxClose, 1.27) : 1.0


// ─────────────────────────────────────────────────────────────────────────────
// §9  EM1 PATTERN DETECTION
// ─────────────────────────────────────────────────────────────────────────────
// 3-candle reversal pattern. Buy: bearish [3] → bullish [2] → bullish [1] with
// HH+HL on [1] vs [2]. Sell mirror. Plus EMA-trend slope filter and bias gate.

bool filt_common_buy  = (excludeNonTW ? mergedTW : true) and assetsFilter and intradayTF and (buLTF_XAU_XAG ? mult >= 0 : true) and overallBias == 1
bool filt_common_sell = (excludeNonTW ? mergedTW : true) and assetsFilter and intradayTF and (beLTF_XAU_XAG ? mult <= 0 : true) and overallBias == -1

buyC1  = close[3] < open[3]
buyC2  = close[2] > open[2]
buyC3  = close[1] > open[1]
buyC4a = high[1] > high[2]
buyC4b = low[1] > low[2]
buySignal := buyC1 and buyC2 and buyC3 and buyC4a and buyC4b and (pct_change > 0.006) and filt_common_buy

sellC1  = close[3] > open[3]
sellC2  = close[2] < open[2]
sellC3  = close[1] < open[1]
sellC4a = low[1] < low[2]
sellC4b = high[1] < high[2]
sellSignal := sellC1 and sellC2 and sellC3 and sellC4a and sellC4b and (pct_change < -0.006) and filt_common_sell


// ─────────────────────────────────────────────────────────────────────────────
// §13  AUTO-ESCALATING DISCOUNT ZONES
// ─────────────────────────────────────────────────────────────────────────────

// Fib 50%-75% zone based on each TF's own candle direction
f_discountZone(float lo, float hi, int candleBias) =>
    float rng = hi - lo
    float zt = na
    float zb = na
    if candleBias == 1
        zt := hi - 0.5  * rng
        zb := hi - 0.75 * rng
    else if candleBias == -1
        zb := lo + 0.5  * rng
        zt := lo + 0.75 * rng
    [zt, zb]

[zt_4h,  zb_4h]  = f_discountZone(low_4h,  high_4h,  bias_4h)
[zt_6h,  zb_6h]  = f_discountZone(low_6h,  high_6h,  bias_6h)
[zt_8h,  zb_8h]  = f_discountZone(low_8h,  high_8h,  bias_8h)
[zt_12h, zb_12h] = f_discountZone(low_12h, high_12h, bias_12h)
[zt_Db,  zb_Db]  = f_discountZone(low_Db,  high_Db,  bias_D)
[zt_Wb,  zb_Wb]  = f_discountZone(low_Wb,  high_Wb,  bias_W)

// Invalidation uses chart timeframe automatically
f_zoneInvalid(float zt, float zb, int candleBias) =>
    bool inv = false
    if candleBias == 1 and not na(zb)
        float lower = math.min(zt, zb)
        inv := close[2] < lower and close[1] < lower
    else if candleBias == -1 and not na(zt)
        float upper = math.max(zt, zb)
        inv := close[2] > upper and close[1] > upper
    inv

// Native HTF timing — replaces 6 request.security() calls.
int time_now_4h  = time("240")
int time_now_6h  = time("360")
int time_now_8h  = time("480")
int time_now_12h = time("720")
int time_now_D   = time("D")
int time_now_W   = time("W")

bool new_4h  = timeframe.change("240")
bool new_6h  = timeframe.change("360")
bool new_8h  = timeframe.change("480")
bool new_12h = timeframe.change("720")
bool new_D   = timeframe.change("D")
bool new_W   = timeframe.change("W")

var bool locked_4h  = false
var bool locked_6h  = false
var bool locked_8h  = false
var bool locked_12h = false
var bool locked_D   = false
var bool locked_W   = false

// Pre-compute every ta.change() unconditionally so each one evaluates on every bar.
float chg_zt_4h  = ta.change(zt_4h)
float chg_zb_4h  = ta.change(zb_4h)
float chg_zt_6h  = ta.change(zt_6h)
float chg_zb_6h  = ta.change(zb_6h)
float chg_zt_8h  = ta.change(zt_8h)
float chg_zb_8h  = ta.change(zb_8h)
float chg_zt_12h = ta.change(zt_12h)
float chg_zb_12h = ta.change(zb_12h)
float chg_zt_D   = ta.change(zt_Db)
float chg_zb_D   = ta.change(zb_Db)
float chg_zt_W   = ta.change(zt_Wb)
float chg_zb_W   = ta.change(zb_Wb)

bool newZone_4h  = chg_zt_4h  != 0 or chg_zb_4h  != 0
bool newZone_6h  = chg_zt_6h  != 0 or chg_zb_6h  != 0
bool newZone_8h  = chg_zt_8h  != 0 or chg_zb_8h  != 0
bool newZone_12h = chg_zt_12h != 0 or chg_zb_12h != 0
bool newZone_D   = chg_zt_D   != 0 or chg_zb_D   != 0
bool newZone_W   = chg_zt_W   != 0 or chg_zb_W   != 0

if newZone_4h
    locked_4h := false
    dashStk_4h := false
if newZone_6h
    locked_6h := false
    dashStk_6h := false
if newZone_8h
    locked_8h := false
    dashStk_8h := false
if newZone_12h
    locked_12h := false
    dashStk_12h := false
if newZone_D
    locked_D := false
    dashStk_D := false
if newZone_W
    locked_W := false
    dashStk_W := false

if f_zoneInvalid(zt_4h, zb_4h, bias_4h)
    locked_4h := true
    dashStk_4h := false
if f_zoneInvalid(zt_6h, zb_6h, bias_6h)
    locked_6h := true
    dashStk_6h := false
if f_zoneInvalid(zt_8h, zb_8h, bias_8h)
    locked_8h := true
    dashStk_8h := false
if f_zoneInvalid(zt_12h, zb_12h, bias_12h)
    locked_12h := true
    dashStk_12h := false
if f_zoneInvalid(zt_Db, zb_Db, bias_D)
    locked_D := true
    dashStk_D := false
if f_zoneInvalid(zt_Wb, zb_Wb, bias_W)
    locked_W := true
    dashStk_W := false

f_matches(int candleBias, int ovBias) => ovBias != 0 and candleBias == ovBias

m_4h  = f_matches(bias_4h,  overallBias) and not locked_4h
m_6h  = f_matches(bias_6h,  overallBias) and not locked_6h
m_8h  = f_matches(bias_8h,  overallBias) and not locked_8h
m_12h = f_matches(bias_12h, overallBias) and not locked_12h
m_D   = f_matches(bias_D,   overallBias) and not locked_D
m_W   = f_matches(bias_W,   overallBias) and not locked_W

f_getZT(int z) => z == 1 ? zt_4h : z == 2 ? zt_6h : z == 3 ? zt_8h : z == 4 ? zt_12h : z == 5 ? zt_Db : z == 6 ? zt_Wb : na
f_getZB(int z) => z == 1 ? zb_4h : z == 2 ? zb_6h : z == 3 ? zb_8h : z == 4 ? zb_12h : z == 5 ? zb_Db : z == 6 ? zb_Wb : na

f_touching(float zt, float zb) =>
    not na(zt) and not na(zb) and low <= math.max(zt, zb) and high >= math.min(zt, zb)

bool touch_4h  = m_4h  and f_touching(zt_4h,  zb_4h)
bool touch_6h  = m_6h  and f_touching(zt_6h,  zb_6h)
bool touch_8h  = m_8h  and f_touching(zt_8h,  zb_8h)
bool touch_12h = m_12h and f_touching(zt_12h, zb_12h)
bool touch_D   = m_D   and f_touching(zt_Db,  zb_Db)
bool touch_W   = m_W   and f_touching(zt_Wb,  zb_Wb)

int touchCount = (touch_4h ? 1 : 0) + (touch_6h ? 1 : 0) + (touch_8h ? 1 : 0) + (touch_12h ? 1 : 0) + (touch_D ? 1 : 0) + (touch_W ? 1 : 0)

// ── STICKY TOUCH FLAGS (dashboard) ──
if touch_4h
    dashStk_4h := true
if touch_6h
    dashStk_6h := true
if touch_8h
    dashStk_8h := true
if touch_12h
    dashStk_12h := true
if touch_D
    dashStk_D := true
if touch_W
    dashStk_W := true

if not m_4h
    dashStk_4h := false
if not m_6h
    dashStk_6h := false
if not m_8h
    dashStk_8h := false
if not m_12h
    dashStk_12h := false
if not m_D
    dashStk_D := false
if not m_W
    dashStk_W := false

// ── 3-STEP SYSTEM: STEP 2 — Zone Touch Tracking ──
// Weekly zone is excluded from Step-2 eligibility — only 4H/6H/8H/12H/Daily
// taps can arm the system. A weekly-only tap must not flip stepTwoMet.
bool tapInWindow = windowTapsOnly ? mergedTW : true
int  signalTouchCount = (touch_4h ? 1 : 0) + (touch_6h ? 1 : 0) + (touch_8h ? 1 : 0) + (touch_12h ? 1 : 0) + (touch_D ? 1 : 0)
if signalTouchCount > 0 and overallBias != 0 and tapInWindow
    stepTwoMet  := true
    stepTwoBias := overallBias

bool anyDashTouched = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D or dashStk_W
bool anyDashTouchedSignalable = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D
if stepTwoMet and not anyDashTouchedSignalable
    stepTwoMet  := false
    stepTwoBias := 0

bool stepTwoValid = stepTwoMet and stepTwoBias == overallBias and overallBias != 0

// Active zone selection
int activeZone = anyDashTouched ? (dashStk_4h ? 1 : dashStk_6h ? 2 : dashStk_8h ? 3 : dashStk_12h ? 4 : dashStk_D ? 5 : dashStk_W ? 6 : 0) : (m_4h ? 1 : m_6h ? 2 : m_8h ? 3 : m_12h ? 4 : m_D ? 5 : m_W ? 6 : 0)
float activeZT = f_getZT(activeZone)
float activeZB = f_getZB(activeZone)

string activeZoneStr = activeZone == 1 ? "4H" : activeZone == 2 ? "6H" : activeZone == 3 ? "8H" : activeZone == 4 ? "12H" : activeZone == 5 ? "Daily" : activeZone == 6 ? "Weekly" : "None"

int ms_4h  = 240  * 60 * 1000
int ms_6h  = 360  * 60 * 1000
int ms_8h  = 480  * 60 * 1000
int ms_12h = 720  * 60 * 1000
int ms_D   = 1440 * 60 * 1000
int ms_W   = 7 * 1440 * 60 * 1000

int activeOpenTime  = activeZone == 1 ? time_now_4h : activeZone == 2 ? time_now_6h : activeZone == 3 ? time_now_8h : activeZone == 4 ? time_now_12h : activeZone == 5 ? time_now_D : activeZone == 6 ? time_now_W : na
int activeMS        = activeZone == 1 ? ms_4h : activeZone == 2 ? ms_6h : activeZone == 3 ? ms_8h : activeZone == 4 ? ms_12h : activeZone == 5 ? ms_D : activeZone == 6 ? ms_W : 0
int activeCloseTime = not na(activeOpenTime) ? activeOpenTime + activeMS : na

// Shared predicate — trade is "frozen-zone" live iff a live trade exists AND
// risk is still on the line (TP1 not yet secured). Used by both §13 and §16.
bool tradeFrozen = (trade.status == "Active" or trade.status == "Triggered") and not na(zone.zt) and not trade.tp1hit

// ── SINGLE DISCOUNT BOX: shows as soon as zone is valid ──
autoZoneClr    = overallBias == 1 ? bull_fill : overallBias == -1 ? bear_fill : color.new(color.yellow, 80)
autoZoneBorder = overallBias == 1 ? bull_border : overallBias == -1 ? bear_border : color.yellow
autoMidClr     = overallBias == 1 ? color.new(color.green, 30) : overallBias == -1 ? color.new(color.red, 30) : color.new(color.yellow, 30)

var box  autoBox = na
var label autoLbl = na
var line  autoMid = na

if barstate.islast and autoDiscount
    box.delete(autoBox)
    label.delete(autoLbl)
    line.delete(autoMid)
    if activeZone != 0 and not na(activeZT) and not na(activeZB) and not na(activeOpenTime) and not tradeFrozen
        autoBox := box.new(activeOpenTime, activeZT, activeCloseTime, activeZB, xloc=xloc.bar_time, border_color=autoZoneBorder, bgcolor=autoZoneClr, border_width=1, border_style=line.style_dashed)
        autoLbl := label.new(activeCloseTime, math.avg(activeZT, activeZB), activeZoneStr + " Discount", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=autoZoneBorder, style=label.style_label_left, size=size.small)
        float midPrice = math.avg(activeZT, activeZB)
        autoMid := line.new(activeOpenTime, midPrice, activeCloseTime, midPrice, xloc=xloc.bar_time, color=autoMidClr, width=2, style=line.style_solid)


// ─────────────────────────────────────────────────────────────────────────────
// §10  SIGNAL LABELS & TRADE ENTRY  (single model — EM1 only)
// ─────────────────────────────────────────────────────────────────────────────

var DTG_Signal = array.new_label()
label_size = showLabel == "Symbol" ? size.auto : size.tiny
buy_style  = showLabel == "Symbol" ? label.style_triangleup   : label.style_label_up
sell_style = showLabel == "Symbol" ? label.style_triangledown : label.style_label_down
em1_text   = showLabel == "Symbol" ? "" : "EM1"

// ── 3-STEP SYSTEM GATE ──
// Weekly discount zone is excluded from signal eligibility (still drawn).
bool em1_hasTouchedZones = dashStk_4h or dashStk_6h or dashStk_8h or dashStk_12h or dashStk_D
bool em1_stepTwoValid = requireZoneTap ? (stepTwoMet and stepTwoBias == overallBias and overallBias != 0 and em1_hasTouchedZones) : (overallBias != 0)
bool em1_systemReady  = em1_stepTwoValid and (not oneTradePerDay or not dailyProfitTaken)
bool em1_allowed      = trade.status != "Triggered" and em1_systemReady

bool validBuy  = buySignal and enableEM1 and em1_allowed and showLabel != "Off"
bool validSell = sellSignal and enableEM1 and em1_allowed and showLabel != "Off"

// Raw pattern signals (no system gate) — for alertcondition
bool rawBuy  = buySignal and enableEM1 and trade.status != "Triggered" and overallBias == 1
bool rawSell = sellSignal and enableEM1 and trade.status != "Triggered" and overallBias == -1

if validBuy
    trade.bar        := bar_index
    trade.triggerBar := na
    trade.time       := time
    trade.status     := "Active"
    trade.entry      := math.round(high[1] + inputSpread * spread_tick, digits)
    trade.sl         := math.round(low[1] - 3 * spread_tick, digits)
    trade.tp1        := math.round(2 * trade.entry - trade.sl, digits)
    trade.tp2        := math.round(3 * trade.entry - 2 * trade.sl, digits)
    trade.bias       := buy_c
    trade.model      := "EM1"
    trade.tp1hit     := false
    f_DTG_algo(DTG_Signal, bar_index, low, yloc.belowbar, buy_c, buy_style, em1_text, txt_c, label_size)

if validSell
    trade.bar        := bar_index
    trade.triggerBar := na
    trade.time       := time
    trade.status     := "Active"
    trade.entry      := math.round(low[1] - inputSpread * spread_tick, digits)
    trade.sl         := math.round(high[1] + 3 * spread_tick, digits)
    trade.tp1        := math.round(2 * trade.entry - trade.sl, digits)
    trade.tp2        := math.round(3 * trade.entry - 2 * trade.sl, digits)
    trade.bias       := sell_c
    trade.model      := "EM1"
    trade.tp1hit     := false
    f_DTG_algo(DTG_Signal, bar_index, high, yloc.abovebar, sell_c, sell_style, em1_text, txt_c, label_size)

f_LABEL_truncate(DTG_Signal, showMax)

// (Unified alert() emitter lives below §12 — it covers signal / triggered /
// invalid in a single TradingView alert configuration.)


// ─────────────────────────────────────────────────────────────────────────────
// §12  TRADE STATUS MACHINE
// ─────────────────────────────────────────────────────────────────────────────

if trade.status == "Active" and (bar_index - nz(trade.bar)) == 0
    if trade.bias == sell_c and low < trade.entry
        trade.status     := "Triggered"
        trade.triggerBar := bar_index
    else if trade.bias == buy_c and high > trade.entry
        trade.status     := "Triggered"
        trade.triggerBar := bar_index
    else
        trade.status := "Active"

if trade.status == "Active" and (bar_index - nz(trade.bar)) == 1
    trade.status := "Invalid"

if trade.status == "Invalid"
    if bar_index - nz(trade.bar) > 1
        trade.status := "Scanning"

// Triggered = live trade. Exit logic depends on preset:
//   V8 Pro / V8 Unlocked — three exits: TP2 (W), TP1→BE (1:1 secured), SL (L)
//   Funded Pro           — two exits: TP2 (W) or SL (L). No TP1 management,
//                          no stop-to-entry move. trade.tp1hit stays false
//                          forever so every TP1/BE-conditional visual falls
//                          back to its 'pre-TP1' state automatically.
//
// V8.1 FIX #1: wasTP1hit snapshot prevents same-bar TP1+BE race.
// V8.1 FIX #2: gate with bar_index > trade.triggerBar — skip the trigger bar
//              so a pre-trigger wick through SL isn't counted as a loss.
if trade.status == "Triggered" and bar_index > nz(trade.triggerBar)
    bool wasTP1hit = trade.tp1hit
    // TP1 detection only when the preset enables it (Funded Pro skips this)
    bool checkTP1  = tp1Enabled and ((trade.bias == buy_c and high > trade.tp1) or (trade.bias == sell_c and low < trade.tp1))
    if checkTP1
        trade.tp1hit := true
    bool hitTP2 = (trade.bias == sell_c and low < trade.tp2) or (trade.bias == buy_c and high > trade.tp2)
    bool hitSL  = not wasTP1hit and ((trade.bias == sell_c and high > trade.sl) or (trade.bias == buy_c and low < trade.sl))
    // hitBE only meaningful when TP1 is enabled — gate by tp1Enabled so it
    // can never fire under Funded Pro (where wasTP1hit is always false anyway).
    bool hitBE  = tp1Enabled and wasTP1hit and ((trade.bias == buy_c and low < trade.entry) or (trade.bias == sell_c and high > trade.entry))
    if hitTP2 or hitBE or hitSL
        if hitTP2
            dailyProfitTaken := true
        if showHistory
            hist.bar := trade.bar, hist.exitBar := bar_index
            hist.time := trade.time, hist.exitTime := time
            hist.entry := trade.entry, hist.sl := trade.sl
            hist.tp1 := trade.tp1, hist.tp2 := trade.tp2
            hist.dir := trade.bias == buy_c ? 1 : -1
            hist.outcome := hitTP2 ? 1 : hitBE ? 0 : -1
            hist.valid := true
        trade.status := "Scanning"
        trade.tp1hit := false

if na(trade.status)
    trade.status := "None"

noSignal_Bias = (trade.status == "Scanning" or trade.status == "None") ? H4_c : trade.bias


// ─────────────────────────────────────────────────────────────────────────────
// §12b  UNIFIED ALERT EMITTER
// ─────────────────────────────────────────────────────────────────────────────
// Single alert() call per event so members can set up ONE TradingView alert
// using "Any alert() function call" and receive a different message body
// depending on which lifecycle event fired:
//
//   Signal     — Active state begins (a valid V8 signal just appeared)
//   Triggered  — Active → Triggered (price crossed entry, trade is live)
//   Invalid    — Active → Invalid   (entry never hit, setup expired)
//
// alertconditions kept below for backward compatibility — members with old
// per-event alerts continue to work unchanged.

// Detect the three transitions on this bar. For Signal we use validBuy/Sell
// directly (only fires on the actual signal-fire bar). For Triggered/Invalid
// we use trade.status[1] history operator so the alert fires exactly once
// at the moment of state transition rather than every bar while the trade
// lingers in that state.
bool emit_signal    = validBuy or validSell
bool emit_triggered = trade.status == "Triggered" and trade.status[1] != "Triggered"
bool emit_invalid   = trade.status == "Invalid"   and trade.status[1] != "Invalid"

// Each alert message is prefixed with the active preset in [brackets] so a
// member running multiple charts with different presets can instantly tell
// which mode produced the notification. The preset is also what controls
// the alert volume — V8 Pro / Funded Pro filter more signals (fewer alerts),
// V8 Unlocked is unfiltered (more alerts) — so members get exactly the
// signal volume their chosen mode produces.
//
// Independent if-blocks (not else-if) so a same-bar signal+trigger sends
// two distinct alerts — one announcing the signal, one announcing the
// immediate trigger.
string presetTag = "[" + preset + "] "
if emit_signal
    string sigDir = validBuy ? "BUY" : "SELL"
    alert(presetTag + "DTG V8 — " + sigDir + " SIGNAL on " + syminfo.ticker + " " + TF_txt + " Entry " + str.tostring(trade.entry, format.mintick) + " · SL " + str.tostring(trade.sl, format.mintick) + " · TP2 " + str.tostring(trade.tp2, format.mintick), alert.freq_once_per_bar)
if emit_triggered
    string trgDir = trade.bias == buy_c ? "BUY" : "SELL"
    alert(presetTag + "DTG V8 — " + trgDir + " TRIGGERED on " + syminfo.ticker + " " + TF_txt + " Price hit entry " + str.tostring(trade.entry, format.mintick) + " · SL " + str.tostring(trade.sl, format.mintick) + " · TP2 " + str.tostring(trade.tp2, format.mintick), alert.freq_once_per_bar)
if emit_invalid
    alert(presetTag + "DTG V8 — Setup INVALID on " + syminfo.ticker + " " + TF_txt + " Entry not hit, setup expired.", alert.freq_once_per_bar)


// ── Backward-compatible alertconditions (old-style per-event alerts) ──
alertcondition(emit_signal,    title="System Signal",    message="DTG V8: Valid SYSTEM signal. Check dashboard for trade details.")
alertcondition(rawBuy or rawSell, title="Pattern Signal", message="DTG V8: EM1 pattern detected (system rules not applied).")
alertcondition(emit_triggered, title="System Triggered", message="DTG V8: System signal TRIGGERED — price hit entry. Check dashboard for SL/TP levels.")
alertcondition(emit_invalid,   title="System Invalid",   message="DTG V8: System signal INVALID — entry not hit, setup expired.")


// ─────────────────────────────────────────────────────────────────────────────
// §14  DISCOUNT ZONE TOUCH SUMMARY (dashboard string)
// ─────────────────────────────────────────────────────────────────────────────

string touchZonesStr = ""
if dashStk_4h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "4H"
if dashStk_6h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "6H"
if dashStk_8h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "8H"
if dashStk_12h
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "12H"
if dashStk_D
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "D"
if dashStk_W
    touchZonesStr := touchZonesStr + (touchZonesStr != "" ? " · " : "") + "W"
if touchZonesStr == ""
    touchZonesStr := "None"


// ─────────────────────────────────────────────────────────────────────────────
// §15  TRADE ZONE SNAPSHOT
// ─────────────────────────────────────────────────────────────────────────────

if (trade.status == "Active" or trade.status == "Triggered") and trade.bar == bar_index and activeZone != 0
    zone.zt        := activeZT
    zone.zb        := activeZB
    zone.openTime  := activeOpenTime
    zone.closeTime := activeCloseTime
    zone.tfLabel   := activeZoneStr
    zone.bias      := overallBias
    trade.zoneTF   := activeZoneStr

if trade.status == "Scanning" or trade.status == "None"
    zone.zt        := na
    zone.zb        := na
    zone.openTime  := na
    zone.closeTime := na
    zone.tfLabel   := na
    zone.bias      := 0


// ─────────────────────────────────────────────────────────────────────────────
// §16  FIXED R:R BOXES + TRADE ZONE BOX
// ─────────────────────────────────────────────────────────────────────────────

var box   rrBoxSL  = na
var box   rrBoxTP1 = na
var box   rrBoxTP2 = na
var line  rrEntry  = na
var label rrTP1lbl = na
var box   tradeZoneBox = na
var label tradeZoneLbl = na
var line  tradeZoneMid = na

bool hasActiveTrade = (trade.status == "Active" or trade.status == "Triggered") and not na(trade.entry) and not na(trade.bar)

if barstate.islast and showRR
    box.delete(rrBoxSL),  box.delete(rrBoxTP1), box.delete(rrBoxTP2)
    line.delete(rrEntry)
    label.delete(rrTP1lbl)

    if hasActiveTrade
        int rr_left  = trade.bar
        int rr_right = bar_index + 15

        if trade.bias == buy_c
            float sl_bottom = trade.tp1hit ? trade.entry : trade.sl
            color sl_bg     = trade.tp1hit ? color.new(#FF9100, 92) : color.new(#FF1744, 88)
            color sl_bdr    = trade.tp1hit ? color.new(#FF9100, 60) : color.new(#FF1744, 60)
            rrBoxSL  := box.new(rr_left, trade.entry, rr_right, sl_bottom, border_color=sl_bdr, bgcolor=sl_bg, border_width=1)
            if tp1Enabled
                // V8 Pro / V8 Unlocked — split TP1/TP2 bands
                rrBoxTP1 := box.new(rr_left, trade.tp1, rr_right, trade.entry, border_color=color.new(#00C853, 60), bgcolor=color.new(#00C853, 88), border_width=1)
                rrBoxTP2 := box.new(rr_left, trade.tp2, rr_right, trade.tp1,   border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 92), border_width=1)
            else
                // Funded Pro — single green band from Entry to TP2 (no TP1 split)
                rrBoxTP2 := box.new(rr_left, trade.tp2, rr_right, trade.entry, border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 90), border_width=1)
            rrEntry  := line.new(rr_left, trade.entry, rr_right, trade.entry, color=color.new(#FFFFFF, 30), style=line.style_solid, width=2)
            if tp1Enabled and trade.tp1hit
                rrTP1lbl := label.new(rr_right, trade.tp1, "1:1 ✓", color=color.new(#00C853, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

        else if trade.bias == sell_c
            float sl_top = trade.tp1hit ? trade.entry : trade.sl
            color sl_bg  = trade.tp1hit ? color.new(#FF9100, 92) : color.new(#FF1744, 88)
            color sl_bdr = trade.tp1hit ? color.new(#FF9100, 60) : color.new(#FF1744, 60)
            rrBoxSL  := box.new(rr_left, sl_top, rr_right, trade.entry, border_color=sl_bdr, bgcolor=sl_bg, border_width=1)
            if tp1Enabled
                rrBoxTP1 := box.new(rr_left, trade.entry, rr_right, trade.tp1, border_color=color.new(#00C853, 60), bgcolor=color.new(#00C853, 88), border_width=1)
                rrBoxTP2 := box.new(rr_left, trade.tp1,   rr_right, trade.tp2, border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 92), border_width=1)
            else
                rrBoxTP2 := box.new(rr_left, trade.entry, rr_right, trade.tp2, border_color=color.new(#00E676, 60), bgcolor=color.new(#00E676, 90), border_width=1)
            rrEntry  := line.new(rr_left, trade.entry, rr_right, trade.entry, color=color.new(#FFFFFF, 30), style=line.style_solid, width=2)
            if tp1Enabled and trade.tp1hit
                rrTP1lbl := label.new(rr_right, trade.tp1, "1:1 ✓", color=color.new(#00C853, 20), textcolor=color.white, style=label.style_label_left, size=size.tiny)

if barstate.islast and autoDiscount
    box.delete(tradeZoneBox)
    label.delete(tradeZoneLbl)
    line.delete(tradeZoneMid)
    if tradeFrozen and not na(zone.zb) and not na(zone.openTime)
        color tzFill   = zone.bias == 1 ? bull_fill : zone.bias == -1 ? bear_fill : color.new(color.yellow, 80)
        color tzBorder = zone.bias == 1 ? bull_border : zone.bias == -1 ? bear_border : color.yellow
        color tzMidClr = zone.bias == 1 ? color.new(color.green, 30) : zone.bias == -1 ? color.new(color.red, 30) : color.new(color.yellow, 30)
        string tzLabel = (na(zone.tfLabel) ? "" : zone.tfLabel) + " Discount"
        tradeZoneBox := box.new(zone.openTime, zone.zt, zone.closeTime, zone.zb, xloc=xloc.bar_time, border_color=tzBorder, bgcolor=tzFill, border_width=1, border_style=line.style_solid)
        tradeZoneLbl := label.new(zone.closeTime, math.avg(zone.zt, zone.zb), tzLabel, xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=tzBorder, style=label.style_label_left, size=size.small)
        float tzMid = math.avg(zone.zt, zone.zb)
        tradeZoneMid := line.new(zone.openTime, tzMid, zone.closeTime, tzMid, xloc=xloc.bar_time, color=tzMidClr, width=2, style=line.style_solid)


// ─────────────────────────────────────────────────────────────────────────────
// §16b  TRADE HISTORY — draw last completed trade on chart
// ─────────────────────────────────────────────────────────────────────────────

var box   lastBoxSL  = na
var box   lastBoxTP1 = na
var box   lastBoxTP2 = na
var line  lastEntry  = na
var label lastLbl    = na

if barstate.islast and showHistory
    box.delete(lastBoxSL), box.delete(lastBoxTP1), box.delete(lastBoxTP2)
    line.delete(lastEntry)
    label.delete(lastLbl)

    if hist.valid and not na(hist.time) and not na(hist.exitTime)
        bool  isWin    = hist.outcome == 1
        bool  isBE     = hist.outcome == 0
        color slBG     = color.new(#FF1744, 92)
        color tp1BG    = color.new(#00C853, 92)
        color tp2BG    = color.new(#00E676, 94)
        int   minWidth = timeframe.in_seconds() * 1000 * 3
        int   hLeft    = hist.time
        int   hRight   = math.max(hist.exitTime, hist.time + minWidth)

        // History visual mirrors the live RR-box layout: 3-band (SL/TP1/TP2)
        // when TP1 management is on; 2-band (SL/TP2) under Funded Pro.
        if hist.dir == 1
            lastBoxSL  := box.new(hLeft, hist.entry, hRight, hist.sl,    xloc=xloc.bar_time, border_color=color.new(#FF1744, 70), bgcolor=slBG,  border_width=1)
            if tp1Enabled
                lastBoxTP1 := box.new(hLeft, hist.tp1, hRight, hist.entry, xloc=xloc.bar_time, border_color=color.new(#00C853, 70), bgcolor=tp1BG, border_width=1)
                lastBoxTP2 := box.new(hLeft, hist.tp2, hRight, hist.tp1,   xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)
            else
                lastBoxTP2 := box.new(hLeft, hist.tp2, hRight, hist.entry, xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)
        else
            lastBoxSL  := box.new(hLeft, hist.sl, hRight, hist.entry, xloc=xloc.bar_time, border_color=color.new(#FF1744, 70), bgcolor=slBG,  border_width=1)
            if tp1Enabled
                lastBoxTP1 := box.new(hLeft, hist.entry, hRight, hist.tp1, xloc=xloc.bar_time, border_color=color.new(#00C853, 70), bgcolor=tp1BG, border_width=1)
                lastBoxTP2 := box.new(hLeft, hist.tp1,   hRight, hist.tp2, xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)
            else
                lastBoxTP2 := box.new(hLeft, hist.entry, hRight, hist.tp2, xloc=xloc.bar_time, border_color=color.new(#00E676, 70), bgcolor=tp2BG, border_width=1)

        lastEntry := line.new(hLeft, hist.entry, hRight, hist.entry, xloc=xloc.bar_time, color=color.new(#FFFFFF, 60), style=line.style_dotted, width=1)

        string outTxt  = isWin ? "W" : isBE ? "1:1" : "L"
        color  outLblC = isWin ? color.new(#00C853, 20) : isBE ? color.new(#00C853, 30) : color.new(#FF1744, 20)
        int    lblTime = int(math.avg(hLeft, hRight))
        float  lblY    = hist.tp2
        if hist.dir == 1
            lastLbl := label.new(lblTime, lblY, outTxt, xloc=xloc.bar_time, color=outLblC, textcolor=color.white, style=label.style_label_down, size=size.tiny)
        else
            lastLbl := label.new(lblTime, lblY, outTxt, xloc=xloc.bar_time, color=outLblC, textcolor=color.white, style=label.style_label_up, size=size.tiny)


// ─────────────────────────────────────────────────────────────────────────────
// §17  ORIGINAL DISCOUNT ZONE BOX (draws when auto is off)
// ─────────────────────────────────────────────────────────────────────────────

int   extend_bars = 50
[tf_open, tf_high, tf_low, tf_close] = request.security(syminfo.tickerid, base_tf, [open[1], high[1], low[1], close[1]], barmerge.gaps_off, barmerge.lookahead_off)
int   tf_time_open = request.security(syminfo.tickerid, base_tf, time[1], barmerge.gaps_off, barmerge.lookahead_off)

int  base_ms       = timeframe.in_seconds(base_tf) * 1000
int  tf_time_close = tf_time_open + base_ms
bool new_tf        = timeframe.change(base_tf)

var box  fib_box  = na
var line fib_line = na

int right_time = tf_time_close + extend_bars * base_ms

if new_tf
    if not enableFib or autoDiscount
        if not na(fib_box)
            box.delete(fib_box)
            fib_box := na
        if not na(fib_line)
            line.delete(fib_line)
            fib_line := na
    else
        if not na(fib_box)
            box.delete(fib_box)
        if not na(fib_line)
            line.delete(fib_line)

        bool  is_bull  = tf_close > tf_open
        bool  is_bear  = tf_close < tf_open
        float tf_range = tf_high - tf_low

        float bull_p05  = tf_low + tf_range * 0.50
        float bull_p618 = tf_low + tf_range * 0.382
        float bull_p75  = tf_low + tf_range * 0.25

        float bear_p05  = tf_high - tf_range * 0.50
        float bear_p618 = tf_high - tf_range * 0.382
        float bear_p75  = tf_high - tf_range * 0.25

        float a          = na
        float b          = na
        float mid_price  = na
        color fill_col   = na
        color border_col = na

        if is_bull
            a          := bull_p05
            b          := bull_p75
            mid_price  := bull_p618
            fill_col   := bull_fill
            border_col := bull_border
        else if is_bear
            a          := bear_p05
            b          := bear_p75
            mid_price  := bear_p618
            fill_col   := bear_fill
            border_col := bear_border

        float top_price    = math.max(a, b)
        float bottom_price = math.min(a, b)

        if not na(top_price) and not na(bottom_price) and not na(mid_price)
            fib_box := box.new(left=tf_time_close, top=top_price, right=right_time, bottom=bottom_price, xloc=xloc.bar_time)
            box.set_bgcolor(fib_box, fill_col)
            box.set_border_color(fib_box, border_col)
            box.set_border_width(fib_box, 1)

            fib_line := line.new(x1=tf_time_close, y1=mid_price, x2=right_time, y2=mid_price, xloc=xloc.bar_time)
            line.set_color(fib_line, border_col)
            line.set_width(fib_line, line_width)

if barstate.islast and autoDiscount
    if not na(fib_box)
        box.delete(fib_box)
        fib_box := na
    if not na(fib_line)
        line.delete(fib_line)
        fib_line := na


// ─────────────────────────────────────────────────────────────────────────────
// §18  DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────

// ── System state string for dashboard ──
string systemStateStr = ""
color  systemStateClr = color.new(color.gray, 0)

if dailyProfitTaken and oneTradePerDay
    systemStateStr := "✓ Complete"
    systemStateClr := color.new(#00E676, 0)
else if not stepTwoValid and overallBias == 0
    systemStateStr := "No Bias"
    systemStateClr := color.new(color.yellow, 0)
else if not stepTwoValid and overallBias != 0
    systemStateStr := "Awaiting"
    systemStateClr := color.new(color.orange, 0)
else if stepTwoValid
    systemStateStr := "Ready"
    systemStateClr := color.new(#00E5FF, 0)

color step1Clr  = overallBias != 0 ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)
color step2Clr  = stepTwoValid and anyDashTouched ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)
bool  showTrade = trade.status == "Active" or trade.status == "Triggered"
color step3Clr  = showTrade ? color.new(#00E676, 0) : color.new(#3a3a5c, 0)

// Typography constants — at global scope so any future companion table can share.
tblSize = dashSize == "tiny" ? size.tiny : dashSize == "small" ? size.small : dashSize == "large" ? size.large : size.normal
dotSize = dashSize == "large" ? size.normal : dashSize == "normal" ? size.small : size.tiny

// Dashboard build is confined to the last bar — saves runtime on long histories.
if showTable and barstate.islast
    color baseBG     = color.new(#111122, 0)
    color titleBG    = color.new(#0a0a1a, 0)
    color titleTxt   = color.new(#8899bb, 0)
    color labelTxt   = color.new(#7a7a9e, 0)
    color valueTxt   = color.new(#e8e8f0, 0)
    color dividerBG  = color.new(#1e1e38, 0)
    color frameBG    = color.new(#1e1e38, 0)
    color dotBG      = color.new(#111122, 0)

    // Table layout (3 columns × 11 rows):
    //   Row 0    — Title bar
    //   Row 1-3  — Bias / Touched / Signal (the 3-step dots)
    //   Row 4    — System state divider
    //   Row 5-9  — Trade levels (Entry/SL/TP1/TP2/Lots) when trade active
    //   Row 10   — Bias Recalc countdown (always shown — hardcoded on)
    var table main_table = table.new(position.top_right, 3, 11, bgcolor=baseBG, border_color=frameBG, border_width=0, frame_color=frameBG, frame_width=1)

    table.cell(main_table, 0, 0, "", bgcolor=titleBG)
    table.cell(main_table, 1, 0, "DTG", text_color=valueTxt, text_size=tblSize, bgcolor=titleBG, text_halign=text.align_right)
    table.cell(main_table, 2, 0, "STRATEGY", text_color=titleTxt, text_size=tblSize, bgcolor=titleBG, text_halign=text.align_left)

    table.cell(main_table, 0, 1, "●", text_color=step1Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 1, "Bias", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 1, biasLabel, text_color=valueTxt, text_size=tblSize, bgcolor=color.new(biasColor, 30), text_halign=text.align_center)

    discClr = touchZonesStr != "None" ? biasColor : color.new(color.gray, 0)
    discTxtSize = str.length(touchZonesStr) > 12 ? size.tiny : str.length(touchZonesStr) > 5 ? size.small : tblSize
    table.cell(main_table, 0, 2, "●", text_color=step2Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 2, "Touched", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 2, touchZonesStr, text_color=valueTxt, text_size=discTxtSize, bgcolor=color.new(discClr, 30), text_halign=text.align_center)

    table.cell(main_table, 0, 3, "●", text_color=step3Clr, text_size=dotSize, bgcolor=dotBG, text_halign=text.align_center)
    table.cell(main_table, 1, 3, "Signal", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
    table.cell(main_table, 2, 3, trade.status, text_color=valueTxt, text_size=tblSize, bgcolor=color.new(noSignal_Bias, 30), text_halign=text.align_center)

    // System state row — only meaningful while scanning (Awaiting / Ready /
    // ✓ Complete / No Bias). During an Active / Triggered trade the user is
    // already focused on the trade levels below, so we blank the row to
    // keep the dashboard quiet.
    if not showTrade
        table.cell(main_table, 0, 4, "", bgcolor=dividerBG)
        table.cell(main_table, 1, 4, "System", text_color=labelTxt, text_size=tblSize, bgcolor=dividerBG, text_halign=text.align_right)
        table.cell(main_table, 2, 4, systemStateStr, text_color=color.white, text_size=tblSize, bgcolor=color.new(systemStateClr, 20), text_halign=text.align_center)
    else
        table.clear(main_table, 0, 4, 2, 4)

    if showTrade
        float riskPctVal_d = riskPct == "0.5%" ? 0.005 : riskPct == "1%" ? 0.01 : riskPct == "2%" ? 0.02 : 0.03
        float riskAmount_d = accountSize * riskPctVal_d
        float riskUSD_d    = riskAmount_d * fxRate
        float slDist_d     = math.abs(trade.entry - trade.sl)
        float rPL_d = 0.0
        string lotUnit_d = "lots"
        if XAU
            rPL_d := slDist_d * 100
        else if XAG
            rPL_d := slDist_d * 5000
        else if isOil
            rPL_d := slDist_d * 1000
        else if isCrypto
            rPL_d := slDist_d * 1.0
            lotUnit_d := syminfo.basecurrency
        else if isIndex
            float idxPV = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
            rPL_d := slDist_d * idxPV
        else if FX
            bool isJPY_d = str.contains(syminfo.ticker, "JPY")
            float pipSz_d = isJPY_d ? 0.01 : 0.0001
            rPL_d := (slDist_d / pipSz_d) * 10.0
        else
            float fallbackPV = syminfo.pointvalue > 0 ? syminfo.pointvalue : 1.0
            rPL_d := slDist_d * fallbackPV
        float lotVal_d = rPL_d > 0 ? math.max(0.01, math.round(riskUSD_d / rPL_d, isCrypto ? 4 : 2)) : 0.01

        color tradeCellBG = color.new(trade.bias, 55)
        // Trade levels layout depends on preset:
        //   tp1Enabled (V8 Pro / V8 Unlocked):   Entry · SL · TP1 · TP2 · Lots → rows 5-9
        //   else (Funded Pro):                   Entry · SL · TP2 · Lots         → rows 5-8 (TP1 row blanked)
        //
        // Entry row — always row 5
        table.cell(main_table, 0, 5, "", bgcolor=baseBG)
        table.cell(main_table, 1, 5, "Entry",     text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 5, str.tostring(trade.entry, format.mintick), text_color=valueTxt, text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
        // SL row — always row 6. 'Moved To BE' label only meaningful when
        // TP1 management is enabled (Funded Pro never gets there).
        table.cell(main_table, 0, 6, "", bgcolor=baseBG)
        string slValue_d = (tp1Enabled and trade.tp1hit) ? "Moved To BE" : str.tostring(trade.sl, format.mintick)
        color  slCellBG  = (tp1Enabled and trade.tp1hit) ? color.new(#FF9100, 45) : tradeCellBG
        table.cell(main_table, 1, 6, "SL",        text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 6, slValue_d,   text_color=valueTxt, text_size=tblSize, bgcolor=slCellBG, text_halign=text.align_center)
        if tp1Enabled
            // TP1 row (row 7) — only rendered when preset uses TP1 management
            color  tp1CellBG  = trade.tp1hit ? color.new(#00C853, 35) : tradeCellBG
            string tp1Value_d = trade.tp1hit ? "Secured" : str.tostring(trade.tp1, format.mintick)
            table.cell(main_table, 0, 7, "", bgcolor=baseBG)
            table.cell(main_table, 1, 7, "TP1",       text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
            table.cell(main_table, 2, 7, tp1Value_d,  text_color=valueTxt, text_size=tblSize, bgcolor=tp1CellBG, text_halign=text.align_center)
            // TP2 row 8, Lots row 9
            table.cell(main_table, 0, 8, "", bgcolor=baseBG)
            table.cell(main_table, 1, 8, "TP2",       text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
            table.cell(main_table, 2, 8, str.tostring(trade.tp2, format.mintick), text_color=valueTxt, text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
            table.cell(main_table, 0, 9, "", bgcolor=baseBG)
            table.cell(main_table, 1, 9, "Lots",      text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
            table.cell(main_table, 2, 9, str.tostring(lotVal_d, isCrypto ? "#.####" : "#.##") + " " + lotUnit_d, text_color=color.new(#00E5FF, 0), text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
        else
            // Funded Pro — TP1 row blanked. TP2 moves up to row 7, Lots to row 8.
            // Row 9 cleared so no stale cell from a previous V8 Pro render lingers.
            table.clear(main_table, 0, 7, 2, 7)
            table.cell(main_table, 0, 7, "", bgcolor=baseBG)
            table.cell(main_table, 1, 7, "TP2",       text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
            table.cell(main_table, 2, 7, str.tostring(trade.tp2, format.mintick), text_color=valueTxt, text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
            table.cell(main_table, 0, 8, "", bgcolor=baseBG)
            table.cell(main_table, 1, 8, "Lots",      text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
            table.cell(main_table, 2, 8, str.tostring(lotVal_d, isCrypto ? "#.####" : "#.##") + " " + lotUnit_d, text_color=color.new(#00E5FF, 0), text_size=tblSize, bgcolor=tradeCellBG, text_halign=text.align_center)
            table.clear(main_table, 0, 9, 2, 9)
    else
        table.clear(main_table, 0, 5, 2, 9)

    // ── Row 10 — Bias Recalc countdown (always shown) ──
    // Bias can flip when ANY of 4H/6H/8H/12H/D/W closes (whichever is soonest).
    // Pick the minimum time_close(tf) - timenow across the six TFs.
    //
    // CRITICAL: use 'timenow' (real wallclock), NOT 'time' (current bar's open
    // time). On a 1H chart, 'time' could be up to 1 hour stale; on a 4H chart,
    // up to 4 hours stale — that produced different countdown values per
    // chart timeframe even though the actual time to the next HTF close is
    // identical. 'timenow' is independent of chart timeframe so the countdown
    // reads correctly on 1m, 5m, 15m, 1H, 4H, etc.
    if showBiasCountdown
        int bigMs = 10 * 365 * 24 * 60 * 60 * 1000
        int d_4h  = nz(time_close("240") - timenow, bigMs)
        int d_6h  = nz(time_close("360") - timenow, bigMs)
        int d_8h  = nz(time_close("480") - timenow, bigMs)
        int d_12h = nz(time_close("720") - timenow, bigMs)
        int d_D   = nz(time_close("D")   - timenow, bigMs)
        int d_W   = nz(time_close("W")   - timenow, bigMs)
        int soonestMs = math.min(math.min(math.min(d_4h, d_6h), math.min(d_8h, d_12h)), math.min(d_D, d_W))
        // Force integer truncation on every step — Pine v6 'int / int' can leak
        // a fractional series float in some code paths.
        int ccSec  = int(math.max(0, math.floor(soonestMs / 1000)))
        int ccHr   = int(math.floor(ccSec / 3600))
        int ccRem  = ccSec - ccHr * 3600
        int ccMin  = int(math.floor(ccRem / 60))
        int ccSs   = ccRem - ccMin * 60
        string ccTxt = ccHr > 0 ? str.tostring(ccHr) + "h " + str.tostring(ccMin) + "m" : str.tostring(ccMin) + ":" + (ccSs < 10 ? "0" : "") + str.tostring(ccSs)
        color  ccBG  = ccHr == 0 and ccMin < 15 ? color.new(#00E5FF, 60) : color.new(#5A5A8F, 70)
        table.cell(main_table, 0, 10, "", bgcolor=baseBG)
        table.cell(main_table, 1, 10, "Rescan", text_color=labelTxt, text_size=tblSize, bgcolor=baseBG, text_halign=text.align_right)
        table.cell(main_table, 2, 10, ccTxt,    text_color=valueTxt, text_size=tblSize, bgcolor=ccBG, text_halign=text.align_center)


// ─────────────────────────────────────────────────────────────────────────────
// §18b  V8 UNLOCKED — chart warning banner (Option C, surface #2)
// ─────────────────────────────────────────────────────────────────────────────
// Tooltip on the preset dropdown is surface #1 (always available on hover
// inside the menu). This second surface puts an unmissable red label on the
// chart whenever V8 Unlocked is the active preset, so users can't forget
// they've switched to the unfiltered mode. Anchored top-left in its own
// 1x1 table so it doesn't push the main dashboard around.

// Declare the warning table once; clear & repopulate (or blank) on every
// last bar so it appears/disappears immediately when the user switches preset.
// Anchored bottom-center so it sits above the time scale.
//
// IMPORTANT: table itself uses fully-transparent bgcolor / frame / border
// (transparency=100, width=0) so an empty/cleared table renders invisibly.
// All visible color is carried by the populated cell — when the cell is
// cleared, the table leaves no visual artifact (no red dot or frame leak).
var table warn_table = table.new(position.bottom_center, 1, 1, bgcolor=color.new(color.white, 100), border_color=color.new(color.white, 100), border_width=0, frame_color=color.new(color.white, 100), frame_width=0)
if barstate.islast
    if preset == "V8 Unlocked"
        table.cell(warn_table, 0, 0, "⚠ Caution — V8 Unlocked removes all 4 system filters. Expect more signals but unverified win rate. Use at your own risk.", text_color=color.white, text_size=size.small, bgcolor=color.new(#FF1744, 70), text_halign=text.align_center)
    else
        table.clear(warn_table, 0, 0, 0, 0)


// ─────────────────────────────────────────────────────────────────────────────
// §19  END
// ─────────────────────────────────────────────────────────────────────────────
