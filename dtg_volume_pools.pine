//@version=6
// DTG Volume Pools — Pine Script v6.1
//
// Cross-timeframe rebuild. All bucket aggregation and value-area math now
// run inside a single 1-minute request.security() call, so the volume pool
// produced on screen is driven by the same source clock and the same source
// data regardless of the chart timeframe.
//
// Changes vs v6.0:
//   #1  Bucket aggregation + profile calculation moved into calcVolumePool()
//       and executed via request.security(sym, "1", ...). The chart timeframe
//       is now display-only — VAH/VAL on a 15m chart are byte-identical to
//       VAH/VAL on a 1m chart for the same instrument and HTF setting.
//   #2  Snapshot of the just-completed bucket fires on barstate.isnew of the
//       first 1m bar of the new HTF window, BEFORE that bar's own data is
//       appended. The bucket arrays at that instant already contain every
//       confirmed 1m bar of the just-closed bucket, so the snapshot is
//       byte-identical to the v6.0 end-of-first-bar snapshot — only the
//       firing moment moves. This removes the one-chart-bar realtime lag at
//       every HTF rollover.
//   #3  request.security_lower_tf calls and the appendSamples helper are no
//       longer needed — the 1m security context provides 1m bars directly.
//
// Behavioural contract preserved from v6.0:
//   - Closed-bucket VAH/VAL is byte-identical (same row geometry, same
//     half-open rows, same value-area expansion order, same tie-break, same
//     "last accepted" rollback when the running total crosses the target).
//   - First partial bucket on chart load is not emitted as a profile.
//   - Bias logic (six HTF previous-close votes, lookahead_on + [1]) is
//     unchanged.
//   - Pool box / midline / debug table appearance and inputs are unchanged.
indicator("DTG Volume Pools (v6)", overlay = true, max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

profileTimeframe = input.string("4H", "Profile Timeframe", options = ["4H", "6H", "8H", "12H", "Daily", "Weekly"])
poolBufferRows   = input.float(1.0, "Pool Buffer (Rows)", minval = 0.25, step = 0.25)
bullPoolColor    = input.color(color.new(color.teal, 78), "Bullish Pool")
bearPoolColor    = input.color(color.new(color.red,  78), "Bearish Pool")
bullMidlineColor = input.color(color.new(color.teal,  0), "Bullish Midline")
bearMidlineColor = input.color(color.new(color.red,   0), "Bearish Midline")

const string ROWS_LAYOUT    = "Number of Rows"
const int    ROW_SIZE       = 24
const int    VALUE_AREA_PCT = 70
const string POOL_LTF       = "1"

profileTimeframeString = switch profileTimeframe
    "4H"     => "240"
    "6H"     => "360"
    "8H"     => "480"
    "12H"    => "720"
    "Daily"  => "1D"
    "Weekly" => "1W"
    =>          "240"

profileTimeframeLabel = switch profileTimeframe
    "Daily"  => "1D"
    "Weekly" => "1W"
    =>          profileTimeframe

maxSupportedSeconds = timeframe.in_seconds(profileTimeframeString)
chartSeconds        = timeframe.in_seconds()
isSupportedChart    = not na(chartSeconds) and chartSeconds <= maxSupportedSeconds

getClosedBull(simple string tf) =>
    prevOpen  = request.security(syminfo.tickerid, tf, open[1],  lookahead = barmerge.lookahead_on)
    prevClose = request.security(syminfo.tickerid, tf, close[1], lookahead = barmerge.lookahead_on)
    prevClose > prevOpen ? 1 : 0

fourHourBull   = getClosedBull("240")
sixHourBull    = getClosedBull("360")
eightHourBull  = getClosedBull("480")
twelveHourBull = getClosedBull("720")
dailyBull      = getClosedBull("1D")
weeklyBull     = getClosedBull("1W")

bullVotes      = fourHourBull + sixHourBull + eightHourBull + twelveHourBull + dailyBull + weeklyBull
bearVotes      = 6 - bullVotes
isBullishBias  = bullVotes >= 4
isBearishBias  = bearVotes >= 4
biasText       = isBullishBias ? "Bullish" : isBearishBias ? "Bearish" : "Neutral"

formatVolume(float value) =>
    switch
        value >= 1000000 => str.tostring(value / 1000000.0, "#.##") + "M"
        value >= 1000    => str.tostring(value / 1000.0,    "#.##") + "K"
        =>                  str.tostring(math.round(value))

resolveGeometry(float rangeLow, float rangeHigh) =>
    int   bottomTick  = int(math.floor(rangeLow  / syminfo.mintick))
    int   topTick     = int(math.ceil (rangeHigh / syminfo.mintick))
    int   totalTicks  = math.max(topTick - bottomTick, 1)
    int   ticksPerRow = 1
    int   rowCount    = 1

    if ROWS_LAYOUT == "Ticks Per Row"
        ticksPerRow := math.max(ROW_SIZE, 1)
        rowCount    := math.max(1, int(math.ceil(totalTicks / ticksPerRow)))
    else
        float rawTicksPerRow = totalTicks / math.max(float(ROW_SIZE), 1.0)
        int   floorTicks     = math.max(1, int(math.floor(rawTicksPerRow)))
        int   ceilTicks      = math.max(1, int(math.ceil (rawTicksPerRow)))
        int   rowsWithFloor  = int(math.ceil(totalTicks / floorTicks))
        int   rowsWithCeil   = int(math.ceil(totalTicks / ceilTicks))
        ticksPerRow := math.abs(rowsWithFloor - ROW_SIZE) <= math.abs(rowsWithCeil - ROW_SIZE) ? floorTicks : ceilTicks
        rowCount    := math.max(1, int(math.ceil(totalTicks / ticksPerRow)))

    float profileBottom = bottomTick * syminfo.mintick
    float rowHeight     = ticksPerRow * syminfo.mintick
    [rowCount, rowHeight, profileBottom]

// Verbatim from v6.0 — same expansion order, same tie-break, same "last
// accepted" rollback when the running total crosses the target.
calculateValueArea(array<float> rowTotals, int pocIndex, float totalVolume) =>
    int   rowCount          = rowTotals.size()
    int   upperIndex        = pocIndex
    int   lowerIndex        = pocIndex
    float accumulated       = rowCount > 0 ? rowTotals.get(pocIndex) : 0.0
    float targetVolume      = totalVolume * VALUE_AREA_PCT / 100.0
    int   lastAcceptedUpper = upperIndex
    int   lastAcceptedLower = lowerIndex

    while accumulated < targetVolume and (lowerIndex > 0 or upperIndex < rowCount - 1)
        float nextUp   = upperIndex < rowCount - 1 ? rowTotals.get(upperIndex + 1) : -1.0
        float nextDown = lowerIndex > 0            ? rowTotals.get(lowerIndex - 1) : -1.0

        if nextUp > nextDown
            upperIndex  += 1
            accumulated += nextUp
            if accumulated <= targetVolume
                lastAcceptedUpper := upperIndex
                lastAcceptedLower := lowerIndex
        else if nextDown > nextUp
            lowerIndex  -= 1
            accumulated += nextDown
            if accumulated <= targetVolume
                lastAcceptedUpper := upperIndex
                lastAcceptedLower := lowerIndex
        else if nextUp >= 0
            int distUp   = (upperIndex + 1) - pocIndex
            int distDown = pocIndex - (lowerIndex - 1)

            if distUp < distDown
                upperIndex  += 1
                accumulated += nextUp
                if accumulated <= targetVolume
                    lastAcceptedUpper := upperIndex
                    lastAcceptedLower := lowerIndex
            else if distDown < distUp
                lowerIndex  -= 1
                accumulated += nextDown
                if accumulated <= targetVolume
                    lastAcceptedUpper := upperIndex
                    lastAcceptedLower := lowerIndex
            else
                upperIndex  += 1
                accumulated += nextUp
                if accumulated <= targetVolume
                    lastAcceptedUpper := upperIndex
                    lastAcceptedLower := lowerIndex
        else if nextDown >= 0
            lowerIndex  -= 1
            accumulated += nextDown
            if accumulated <= targetVolume
                lastAcceptedUpper := upperIndex
                lastAcceptedLower := lowerIndex

    int finalLower = accumulated > targetVolume ? lastAcceptedLower : lowerIndex
    int finalUpper = accumulated > targetVolume ? lastAcceptedUpper : upperIndex
    [finalLower, finalUpper]

calculateProfile(float rangeLow, float rangeHigh, array<float> sourceHighs, array<float> sourceLows, array<float> sourceVolumes) =>
    float computedVah          = na
    float computedVal          = na
    float computedRowHeight    = na
    float computedVahRowVolume = na
    float computedValRowVolume = na
    float computedTotalVolume  = na

    int sourceCount = sourceHighs.size()

    if sourceCount > 0
        float effectiveLow  = rangeLow
        float effectiveHigh = rangeHigh

        for sampleIndex = 0 to sourceCount - 1
            effectiveLow  := math.min(effectiveLow,  sourceLows .get(sampleIndex))
            effectiveHigh := math.max(effectiveHigh, sourceHighs.get(sampleIndex))

        [rowCount, rowHeight, profileBottom] = resolveGeometry(effectiveLow, effectiveHigh)
        array<float> rowTotals = array.new<float>(rowCount, 0.0)
        float totalVolume = 0.0
        float pocVolume   = 0.0
        int   pocIndex    = 0

        for sourceIndex = 0 to sourceCount - 1
            float sourceHigh   = sourceHighs.get(sourceIndex)
            float sourceLow    = sourceLows .get(sourceIndex)
            float sourceVolume = nz(sourceVolumes.get(sourceIndex), 0.0)
            float sourceRange  = sourceHigh - sourceLow

            for rowIndex = 0 to rowCount - 1
                float rowLow  = profileBottom + rowIndex * rowHeight
                float rowHigh = rowLow + rowHeight

                float overlap = math.min(sourceHigh, rowHigh) - math.max(sourceLow, rowLow)
                bool  singlePriceHit = sourceRange == 0 and sourceHigh >= rowLow and sourceHigh <= rowHigh

                if overlap > 0 or singlePriceHit
                    float allocatedVolume = sourceRange > 0 ? sourceVolume * overlap / sourceRange : sourceVolume
                    float newTotal = rowTotals.get(rowIndex) + allocatedVolume
                    rowTotals.set(rowIndex, newTotal)
                    totalVolume += allocatedVolume

                    if newTotal > pocVolume
                        pocVolume := newTotal
                        pocIndex  := rowIndex

        [valIndex, vahIndex]   = calculateValueArea(rowTotals, pocIndex, totalVolume)
        computedVah            := profileBottom + (vahIndex + 1) * rowHeight
        computedVal            := profileBottom + valIndex * rowHeight
        computedRowHeight      := rowHeight
        computedVahRowVolume   := rowTotals.get(vahIndex)
        computedValRowVolume   := rowTotals.get(valIndex)
        computedTotalVolume    := totalVolume

    [computedVah, computedVal, computedRowHeight, computedVahRowVolume, computedValRowVolume, computedTotalVolume]

// 1-minute driver. All bucket state lives here, owned by the 1m security
// context, so the result is independent of the chart's timeframe.
//
// Timing model:
//   - barstate.isnew  + newBucket → snapshot the prior bucket (whose arrays
//                                   are already complete from prior
//                                   barstate.isconfirmed appends) and clear.
//   - barstate.isconfirmed        → append THIS 1m bar's data into the
//                                   currently open bucket. Also handles
//                                   first-ever initialization and the
//                                   first-partial-bucket guard.
//
// On historical bars both barstate flags fire in the same evaluation pass.
// Pine executes top-to-bottom, so the snapshot block runs before the
// accumulate block, which is the correct order: snapshot the previous bucket
// first, then start populating the new one with this bar's data.
calcVolumePool() =>
    var array<float> bucketHighs   = array.new<float>()
    var array<float> bucketLows    = array.new<float>()
    var array<float> bucketVolumes = array.new<float>()

    var float bucketHigh               = na
    var float bucketLow                = na
    var int   previousBucketTime       = na
    var bool  isInitialized            = false
    var bool  hasFullBucketStarted     = false

    var float latestClosedVah          = na
    var float latestClosedVal          = na
    var float latestClosedRowHeight    = na
    var float latestClosedVahRowVolume = na
    var float latestClosedValRowVolume = na
    var float latestClosedTotalVolume  = na
    var float latestClosedRangeLow     = na
    var float latestClosedRangeHigh    = na
    var int   latestClosedBucketTime   = na

    int  ctxBucketTime = time(profileTimeframeString)
    bool newBucket     = ta.change(ctxBucketTime) != 0

    if barstate.isnew and newBucket and isInitialized and hasFullBucketStarted and bucketHighs.size() > 0 and not na(bucketLow) and not na(bucketHigh)
        [snapVah, snapVal, snapRowHeight, snapVahRowVol, snapValRowVol, snapTotVol] = calculateProfile(bucketLow, bucketHigh, bucketHighs, bucketLows, bucketVolumes)
        latestClosedVah          := snapVah
        latestClosedVal          := snapVal
        latestClosedRowHeight    := snapRowHeight
        latestClosedVahRowVolume := snapVahRowVol
        latestClosedValRowVolume := snapValRowVol
        latestClosedTotalVolume  := snapTotVol
        latestClosedRangeLow     := bucketLow
        latestClosedRangeHigh    := bucketHigh
        latestClosedBucketTime   := previousBucketTime

        bucketHighs  .clear()
        bucketLows   .clear()
        bucketVolumes.clear()
        bucketHigh         := na
        bucketLow          := na
        previousBucketTime := ctxBucketTime

    if barstate.isconfirmed
        if not isInitialized
            previousBucketTime   := ctxBucketTime
            isInitialized        := true
            hasFullBucketStarted := false
        else if newBucket and not hasFullBucketStarted
            bucketHighs  .clear()
            bucketLows   .clear()
            bucketVolumes.clear()
            bucketHigh           := high
            bucketLow            := low
            previousBucketTime   := ctxBucketTime
            hasFullBucketStarted := true
            bucketHighs  .push(high)
            bucketLows   .push(low)
            bucketVolumes.push(nz(volume, 0.0))
        else if hasFullBucketStarted
            bucketHigh := na(bucketHigh) ? high : math.max(bucketHigh, high)
            bucketLow  := na(bucketLow)  ? low  : math.min(bucketLow,  low)
            bucketHighs  .push(high)
            bucketLows   .push(low)
            bucketVolumes.push(nz(volume, 0.0))

    [latestClosedVah, latestClosedVal, latestClosedRowHeight, latestClosedVahRowVolume, latestClosedValRowVolume, latestClosedTotalVolume, latestClosedRangeLow, latestClosedRangeHigh, latestClosedBucketTime]

[poolVah, poolVal, poolRowHeight, poolVahRowVolume, poolValRowVolume, poolTotalVolume, poolRangeLow, poolRangeHigh, poolBucketTime] = request.security(syminfo.tickerid, POOL_LTF, calcVolumePool(), lookahead = barmerge.lookahead_on)

var label timeframeWarning = na
var box   activePoolBox    = na
var line  activePoolLine   = na
var table debugTable       = table.new(position.bottom_right, 2, 12, border_width = 1)

if not isSupportedChart
    if barstate.islast and na(timeframeWarning)
        timeframeWarning := label.new(bar_index, high, "Use this indicator on " + profileTimeframeLabel + " or lower.", style = label.style_label_down, color = color.new(color.orange, 0), textcolor = color.white)
else
    if not na(timeframeWarning)
        timeframeWarning.delete()
        timeframeWarning := na

    int currentBucketOpenTime  = time(profileTimeframeString)
    int currentBucketCloseTime = time_close(profileTimeframeString)

    bool showBullPool = isBullishBias and not na(poolVal)
    bool showBearPool = isBearishBias and not na(poolVah)

    float  activePoolMid        = showBullPool ? poolVal : showBearPool ? poolVah : na
    float  activePoolHalfBuffer = math.max(nz(poolRowHeight, syminfo.mintick) * poolBufferRows, syminfo.mintick)
    color  activePoolFill       = showBullPool ? bullPoolColor : showBearPool ? bearPoolColor : na
    color  activePoolLineColor  = showBullPool ? bullMidlineColor : showBearPool ? bearMidlineColor : na
    float  activePoolRowVolume  = showBullPool ? poolValRowVolume : showBearPool ? poolVahRowVolume : na
    string activePoolVolume     = not na(activePoolRowVolume) ? formatVolume(activePoolRowVolume) : ""

    if not na(activePoolMid)
        if na(activePoolBox)
            activePoolBox := box.new(left = currentBucketOpenTime, top = activePoolMid + activePoolHalfBuffer, right = currentBucketCloseTime, bottom = activePoolMid - activePoolHalfBuffer, xloc = xloc.bar_time, bgcolor = activePoolFill, border_color = na, text = "Volume Pool\n" + activePoolVolume, text_color = color.white, text_size = size.small, text_halign = text.align_center, text_valign = text.align_center)
        else
            activePoolBox.set_left   (currentBucketOpenTime)
            activePoolBox.set_right  (currentBucketCloseTime)
            activePoolBox.set_top    (activePoolMid + activePoolHalfBuffer)
            activePoolBox.set_bottom (activePoolMid - activePoolHalfBuffer)
            activePoolBox.set_bgcolor(activePoolFill)
            activePoolBox.set_text   ("Volume Pool\n" + activePoolVolume)

        if na(activePoolLine)
            activePoolLine := line.new(x1 = currentBucketOpenTime, y1 = activePoolMid, x2 = currentBucketCloseTime, y2 = activePoolMid, xloc = xloc.bar_time, color = activePoolLineColor, width = 2)
        else
            activePoolLine.set_x1   (currentBucketOpenTime)
            activePoolLine.set_x2   (currentBucketCloseTime)
            activePoolLine.set_y1   (activePoolMid)
            activePoolLine.set_y2   (activePoolMid)
            activePoolLine.set_color(activePoolLineColor)
    else
        if not na(activePoolBox)
            activePoolBox.delete()
            activePoolBox := na
        if not na(activePoolLine)
            activePoolLine.delete()
            activePoolLine := na

    if barstate.islast
        color bullCell    = color.new(color.teal, 70)
        color bearCell    = color.new(color.red,  70)
        color neutralCell = color.new(color.gray, 75)
        color panelBg     = color.new(color.black, 15)

        debugTable.cell(0, 0, "TF",    text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 0, "State", text_color = color.white, bgcolor = panelBg)

        debugTable.cell(0, 1, "4H",  text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 1, fourHourBull   == 1 ? "Bull" : "Bear", text_color = color.white, bgcolor = fourHourBull   == 1 ? bullCell : bearCell)

        debugTable.cell(0, 2, "6H",  text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 2, sixHourBull    == 1 ? "Bull" : "Bear", text_color = color.white, bgcolor = sixHourBull    == 1 ? bullCell : bearCell)

        debugTable.cell(0, 3, "8H",  text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 3, eightHourBull  == 1 ? "Bull" : "Bear", text_color = color.white, bgcolor = eightHourBull  == 1 ? bullCell : bearCell)

        debugTable.cell(0, 4, "12H", text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 4, twelveHourBull == 1 ? "Bull" : "Bear", text_color = color.white, bgcolor = twelveHourBull == 1 ? bullCell : bearCell)

        debugTable.cell(0, 5, "1D",  text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 5, dailyBull      == 1 ? "Bull" : "Bear", text_color = color.white, bgcolor = dailyBull      == 1 ? bullCell : bearCell)

        debugTable.cell(0, 6, "1W",  text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 6, weeklyBull     == 1 ? "Bull" : "Bear", text_color = color.white, bgcolor = weeklyBull     == 1 ? bullCell : bearCell)

        debugTable.cell(0, 7, "Votes", text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 7, str.tostring(bullVotes) + " Bull / " + str.tostring(bearVotes) + " Bear", text_color = color.white, bgcolor = panelBg)

        debugTable.cell(0, 8, "Bias", text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 8, biasText, text_color = color.white, bgcolor = isBullishBias ? bullCell : isBearishBias ? bearCell : neutralCell)

        debugTable.cell(0, 9, "Closed", text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 9, na(poolBucketTime) ? "n/a" : str.format("{0,time,HH:mm}", poolBucketTime), text_color = color.white, bgcolor = panelBg)

        string rangeText  = na(poolRangeLow) ? "n/a" : str.tostring(poolRangeLow, format.mintick) + " — " + str.tostring(poolRangeHigh, format.mintick)
        string totVolText = na(poolTotalVolume) ? "n/a" : formatVolume(poolTotalVolume)

        debugTable.cell(0, 10, "Range", text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 10, rangeText, text_color = color.white, bgcolor = panelBg)

        debugTable.cell(0, 11, "TotVol", text_color = color.white, bgcolor = panelBg)
        debugTable.cell(1, 11, totVolText, text_color = color.white, bgcolor = panelBg)
